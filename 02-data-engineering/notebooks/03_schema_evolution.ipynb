# ── Cell 4: Expand/Contract DB Migration Simulator ────────────────────────────

class Column:
    def __init__(self, name: str, col_type: str, nullable: bool = True, default=None):
        self.name = name
        self.col_type = col_type
        self.nullable = nullable
        self.default = default

class DBTable:
    def __init__(self, name: str):
        self.name = name
        self.columns: Dict[str, Column] = {}
        self.rows: List[dict] = []

    def add_column(self, col: Column) -> None:
        self.columns[col.name] = col
        # Backfill existing rows with default
        for row in self.rows:
            if col.name not in row:
                row[col.name] = col.default
        print(f"  [EXPAND]  Added column '{col.name}' ({col.col_type}, default={col.default})")

    def drop_column(self, name: str) -> None:
        if name in self.columns:
            del self.columns[name]
            for row in self.rows:
                row.pop(name, None)
            print(f"  [CONTRACT] Dropped column '{name}'")
        else:
            print(f"  [ERROR] Column '{name}' not found")

    def insert(self, row: dict) -> None:
        full_row = {col: self.columns[col].default for col in self.columns}
        full_row.update(row)
        self.rows.append(full_row)

    def show(self) -> None:
        cols = list(self.columns.keys())
        print(f"\n  Table: {self.name}")
        print(f"  Columns: {cols}")
        for r in self.rows[:4]:
            print(f"    {r}")

# Phase 1: Original schema
table = DBTable("users")
table.columns = {
    "user_id": Column("user_id", "VARCHAR", nullable=False),
    "name":    Column("name",    "VARCHAR"),
    "username":Column("username","VARCHAR"),
}
for i in range(3):
    table.insert({"user_id": f"u{i}", "name": f"User {i}", "username": f"user{i}"})

print("Expand/Contract Migration: rename 'username' → 'email'")
table.show()

# Phase 2: Expand — add new column
print()
table.add_column(Column("email", "VARCHAR", nullable=True, default=None))

# Phase 3: Backfill (simulate)
print("  [MIGRATE] Backfilling email from username...")
for row in table.rows:
    row["email"] = row["username"] + "@example.com"

# Phase 4: Contract — drop old column
print()
table.drop_column("username")

table.show()
