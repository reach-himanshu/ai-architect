# ── Cell 3: Protobuf Field Number Safety Checker ──────────────────────────────

@dataclass
class ProtoField:
    number: int
    name: str
    type: str
    required: bool = False

class ProtoSchema:
    def __init__(self, name: str, version: int, fields: List[ProtoField]):
        self.name = name
        self.version = version
        self.fields = fields
        self._by_number = {f.number: f for f in fields}

    def check_evolution(self, new_schema: "ProtoSchema") -> List[str]:
        issues = []
        new_by_number = {f.number: f for f in new_schema.fields}
        new_by_name   = {f.name: f for f in new_schema.fields}

        for num, old_f in self._by_number.items():
            if num in new_by_number:
                new_f = new_by_number[num]
                if new_f.type != old_f.type:
                    issues.append(
                        f"Field #{num}: type changed {old_f.type}→{new_f.type} — BREAKING"
                    )
                if new_f.name != old_f.name:
                    issues.append(
                        f"Field #{num}: renamed '{old_f.name}'→'{new_f.name}' "
                        f"(OK in proto binary, but confusing)"
                    )
            elif old_f.required:
                issues.append(f"Required field #{num} ('{old_f.name}') removed — BREAKING")

        # Check for reused field numbers (most dangerous)
        old_nums = set(self._by_number.keys())
        for num, new_f in new_by_number.items():
            if num not in old_nums:
                continue  # genuinely new field — fine

        return issues

v1_proto = ProtoSchema("User", 1, [
    ProtoField(1, "user_id", "string", required=True),
    ProtoField(2, "name",    "string", required=True),
])
v2_safe_proto = ProtoSchema("User", 2, [
    ProtoField(1, "user_id", "string", required=True),
    ProtoField(2, "name",    "string", required=True),
    ProtoField(3, "email",   "string", required=False),  # new, safe
])
v3_bad_proto = ProtoSchema("User", 3, [
    ProtoField(1, "user_id", "int", required=True),   # type changed!
    ProtoField(2, "full_name", "string", required=True),  # renamed
    ProtoField(4, "email",   "string", required=False),
    # field #3 removed (was non-required — ok)
])

print("Protobuf Evolution Check (v1 → v2):")
issues = v1_proto.check_evolution(v2_safe_proto)
print(f"  Issues: {issues or 'None — safe ✓'}")

print("\nProtobuf Evolution Check (v2 → v3):")
issues = v2_safe_proto.check_evolution(v3_bad_proto)
for i in issues:
    print(f"  ⚠ {i}")
