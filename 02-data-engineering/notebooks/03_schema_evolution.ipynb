# ── Cell 2: Avro-Style Field Resolution ───────────────────────────────────────

def avro_resolve(writer_schema: Schema, reader_schema: Schema, record: dict) -> dict:
    """
    Resolve a record written with writer_schema using reader_schema.
    - Fields in reader not in writer → use reader default
    - Fields in writer not in reader → ignored
    """
    writer_fields = writer_schema.field_map()
    reader_fields = reader_schema.field_map()
    resolved = {}

    for fname, rf in reader_fields.items():
        if fname in record:
            # Field present in data
            resolved[fname] = record[fname]
        elif fname in writer_fields:
            # Field was in writer but missing from record — use reader default
            resolved[fname] = rf.default
        elif rf.default is not None:
            # Field new in reader, has a default
            resolved[fname] = rf.default
        elif not rf.required:
            resolved[fname] = None
        else:
            raise ValueError(f"Cannot resolve required field '{fname}' — no value or default")

    # Fields in writer not in reader are dropped (ignored)
    return resolved

# Simulate reading old data (written with v1) using new schema (v2)
old_record_v1 = {"user_id": "u42", "name": "Alice"}
resolved = avro_resolve(v1, v2_safe, old_record_v1)
print("Avro-Style Field Resolution:")
print(f"  Old record (v1) : {old_record_v1}")
print(f"  Resolved (v2)   : {resolved}")
print()

# Simulate reading new data (written with v2) using old schema (v1)
new_record_v2 = {"user_id": "u43", "name": "Bob", "email": "bob@example.com"}
resolved_old = avro_resolve(v2_safe, v1, new_record_v2)
print(f"  New record (v2) : {new_record_v2}")
print(f"  Resolved (v1)   : {resolved_old}  (email field ignored)")
