# Schema Evolution — Hands-On

Implementations of a schema registry, compatibility checker, Avro-style field resolution,
and an expand/contract database migration simulator. Standard-library Python only.
</cell id="cell-0">

<cell id="cell-1">
# ── Cell 1: Schema Registry with Compatibility Checks ────────────────────────
from dataclasses import dataclass, field
from typing import Dict, List, Optional, Any
from enum import Enum
import json

class CompatibilityMode(Enum):
    NONE = "NONE"
    BACKWARD = "BACKWARD"
    FORWARD = "FORWARD"
    FULL = "FULL"

@dataclass
class FieldDef:
    name: str
    type: str         # "string", "int", "float", "bool", "null|string", etc.
    required: bool = True
    default: Any = None
    aliases: List[str] = field(default_factory=list)

@dataclass
class Schema:
    name: str
    version: int
    fields: List[FieldDef]

    def field_map(self) -> Dict[str, FieldDef]:
        return {f.name: f for f in self.fields}

def check_backward_compat(writer: Schema, reader: Schema) -> List[str]:
    """
    Backward compat: reader (new schema) can read data written with writer (old schema).
    Old consumers (using old schema) must still be able to read new data.
    """
    issues = []
    reader_fields = reader.field_map()
    writer_fields = writer.field_map()

    # Any field in reader that is required but not in writer must have a default
    for fname, rf in reader_fields.items():
        if fname not in writer_fields:
            if rf.required and rf.default is None:
                issues.append(
                    f"Field '{fname}' is required in reader but missing in writer with no default"
                )
    return issues

def check_forward_compat(writer: Schema, reader: Schema) -> List[str]:
    """
    Forward compat: reader (old schema) can read data written with writer (new schema).
    """
    issues = []
    reader_fields = reader.field_map()
    writer_fields = writer.field_map()

    # Any field in writer that is required but not in reader is a problem
    for fname, wf in writer_fields.items():
        if fname not in reader_fields and wf.required:
            issues.append(
                f"Field '{fname}' is required in writer but unknown to reader (no default)"
            )
    return issues

class SchemaRegistry:
    def __init__(self, mode: CompatibilityMode = CompatibilityMode.BACKWARD):
        self.mode = mode
        self._schemas: Dict[str, List[Schema]] = {}

    def register(self, schema: Schema) -> bool:
        subject = schema.name
        if subject not in self._schemas:
            self._schemas[subject] = [schema]
            print(f"  [Registry] Registered {subject} v{schema.version} (first version)")
            return True

        latest = self._schemas[subject][-1]
        issues = []
        if self.mode in (CompatibilityMode.BACKWARD, CompatibilityMode.FULL):
            issues += check_backward_compat(latest, schema)
        if self.mode in (CompatibilityMode.FORWARD, CompatibilityMode.FULL):
            issues += check_forward_compat(latest, schema)

        if issues:
            print(f"  [Registry] REJECTED {subject} v{schema.version}: {issues}")
            return False

        self._schemas[subject].append(schema)
        print(f"  [Registry] Registered {subject} v{schema.version} ✓")
        return True

    def get_latest(self, subject: str) -> Optional[Schema]:
        return self._schemas.get(subject, [None])[-1]

# Demo
registry = SchemaRegistry(mode=CompatibilityMode.BACKWARD)

v1 = Schema("User", 1, [
    FieldDef("user_id", "string", required=True),
    FieldDef("name",    "string", required=True),
])
v2_safe = Schema("User", 2, [
    FieldDef("user_id", "string", required=True),
    FieldDef("name",    "string", required=True),
    FieldDef("email",   "null|string", required=False, default=None),  # optional — safe
])
v3_unsafe = Schema("User", 3, [
    FieldDef("user_id",   "string", required=True),
    FieldDef("name",      "string", required=True),
    FieldDef("email",     "null|string", required=False, default=None),
    FieldDef("age",       "int", required=True),   # required, no default — UNSAFE
])

print("Schema Registry (BACKWARD mode):")
registry.register(v1)
registry.register(v2_safe)
registry.register(v3_unsafe)
