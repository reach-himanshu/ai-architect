# ── Cell 1: Parquet-Style Row Group Predicate Pushdown ───────────────────────
import random, math, time
from dataclasses import dataclass, field
from typing import List, Dict, Any, Optional, Callable

@dataclass
class RowGroup:
    group_id: int
    rows: List[dict]
    # Column statistics (stored in footer)
    stats: Dict[str, dict] = field(default_factory=dict)

    def __post_init__(self):
        if not self.stats and self.rows:
            self._compute_stats()

    def _compute_stats(self):
        numeric_cols = [k for k, v in self.rows[0].items() if isinstance(v, (int, float))]
        for col in numeric_cols:
            vals = [r[col] for r in self.rows if r[col] is not None]
            self.stats[col] = {"min": min(vals), "max": max(vals)}

def build_parquet(rows: List[dict], row_group_size: int = 100) -> List[RowGroup]:
    groups = []
    for i in range(0, len(rows), row_group_size):
        chunk = rows[i:i+row_group_size]
        groups.append(RowGroup(group_id=i//row_group_size, rows=chunk))
    return groups

def scan_with_pushdown(groups: List[RowGroup], predicate_col: str,
                       predicate_op: str, predicate_val: float,
                       projection: List[str]) -> tuple:
    """Simulate Parquet predicate pushdown. Returns (results, groups_scanned, groups_skipped)."""
    ops = {"gt": lambda mn, mx: mx > predicate_val,
           "lt": lambda mn, mx: mn < predicate_val,
           "eq": lambda mn, mx: mn <= predicate_val <= mx}
    op_fn = ops[predicate_op]

    results, scanned, skipped = [], 0, 0
    for g in groups:
        s = g.stats.get(predicate_col, {})
        if s and not op_fn(s["min"], s["max"]):
            skipped += 1
            continue
        scanned += 1
        for row in g.rows:
            val = row.get(predicate_col)
            if val is not None:
                passed = (predicate_op == "gt" and val > predicate_val or
                          predicate_op == "lt" and val < predicate_val or
                          predicate_op == "eq" and val == predicate_val)
                if passed:
                    results.append({k: row[k] for k in projection if k in row})
    return results, scanned, skipped

# Generate 1000 rows, age 0-100
random.seed(42)
rows = [{"user_id": f"u{i}", "age": random.randint(0, 100),
         "revenue": round(random.gauss(500, 150), 2)} for i in range(1000)]
groups = build_parquet(rows, row_group_size=100)

print(f"Parquet Predicate Pushdown: age > 80")
print(f"  Row groups: {len(groups)} (100 rows each)")
results, scanned, skipped = scan_with_pushdown(groups, "age", "gt", 80, ["user_id","age"])
print(f"  Groups scanned : {scanned}  |  Groups skipped: {skipped}")
print(f"  Matching rows  : {len(results)}")
print(f"  Efficiency     : {skipped}/{len(groups)} groups skipped ({skipped/len(groups):.0%})")
