# ── Cell 2: Dictionary Encoding Compression Demo ──────────────────────────────
import sys

def estimate_size_raw(values: List[Any]) -> int:
    """Approximate size of storing values as strings (CSV-like)."""
    return sum(len(str(v)) + 1 for v in values)  # +1 for delimiter

def dictionary_encode(values: List[Any]) -> tuple:
    """
    Returns (dictionary, encoded_indices).
    dictionary: sorted unique values
    encoded_indices: integer index into dictionary per value
    """
    dictionary = sorted(set(values), key=str)
    lookup = {v: i for i, v in enumerate(dictionary)}
    indices = [lookup[v] for v in values]
    return dictionary, indices

def estimate_dict_size(dictionary: list, indices: List[int]) -> int:
    dict_size = sum(len(str(v)) + 1 for v in dictionary)
    # Index size: ceil(log2(len(dict))) bits per value, packed
    bits_per_index = max(1, math.ceil(math.log2(max(len(dictionary), 2))))
    index_size = math.ceil(len(indices) * bits_per_index / 8)
    return dict_size + index_size

# High cardinality (UUID-like) — dictionary encoding doesn't help
import uuid
random.seed(1)
high_card = [str(uuid.UUID(int=random.getrandbits(128))) for _ in range(10000)]
hc_dict, hc_idx = dictionary_encode(high_card)

# Low cardinality (status column)
low_card = random.choices(["active", "inactive", "pending", "suspended"], k=10000)
lc_dict, lc_idx = dictionary_encode(low_card)

print("Dictionary Encoding Compression:")
print(f"\n  High-Cardinality (UUIDs, n=10000):")
raw = estimate_size_raw(high_card)
enc = estimate_dict_size(hc_dict, hc_idx)
print(f"    Raw size    : {raw:>10,} bytes")
print(f"    Encoded     : {enc:>10,} bytes  (ratio: {enc/raw:.2f}x — little benefit)")

print(f"\n  Low-Cardinality (status, 4 values, n=10000):")
raw = estimate_size_raw(low_card)
enc = estimate_dict_size(lc_dict, lc_idx)
print(f"    Raw size    : {raw:>10,} bytes")
print(f"    Encoded     : {enc:>10,} bytes  (ratio: {enc/raw:.2f}x — {raw//enc}x compression)")
print(f"    Dictionary  : {lc_dict}")
