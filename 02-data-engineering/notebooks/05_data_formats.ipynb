# ── Cell 4: Arrow-Style Columnar Memory Simulation ────────────────────────────

class ArrowColumn:
    """Columnar storage for a single typed column."""
    def __init__(self, name: str, data: list):
        self.name = name
        self.data = data
        self._null_bitmap = [v is not None for v in data]

    def __len__(self): return len(self.data)
    def filter(self, mask: List[bool]) -> "ArrowColumn":
        return ArrowColumn(self.name, [v for v, m in zip(self.data, mask) if m])
    def take(self, indices: List[int]) -> "ArrowColumn":
        return ArrowColumn(self.name, [self.data[i] for i in indices])
    def sum(self) -> float:
        return sum(v for v in self.data if v is not None)
    def mean(self) -> float:
        vals = [v for v in self.data if v is not None]
        return sum(vals) / len(vals) if vals else 0.0

class ArrowTable:
    """Zero-copy columnar in-memory table (Arrow-inspired)."""
    def __init__(self, columns: List[ArrowColumn]):
        self.columns = {c.name: c for c in columns}
        self.num_rows = len(columns[0]) if columns else 0

    @classmethod
    def from_rows(cls, rows: List[dict]) -> "ArrowTable":
        if not rows: return cls([])
        keys = list(rows[0].keys())
        return cls([ArrowColumn(k, [r.get(k) for r in rows]) for k in keys])

    def column(self, name: str) -> ArrowColumn:
        return self.columns[name]

    def filter(self, col: str, op: str, val: Any) -> "ArrowTable":
        """Return new table (zero-copy mask, no data movement)."""
        ops = {"gt": lambda x: x is not None and x > val,
               "lt": lambda x: x is not None and x < val,
               "eq": lambda x: x == val}
        mask = [ops[op](v) for v in self.columns[col].data]
        filtered_cols = [c.filter(mask) for c in self.columns.values()]
        return ArrowTable(filtered_cols)

    def select(self, *col_names: str) -> "ArrowTable":
        return ArrowTable([self.columns[n] for n in col_names if n in self.columns])

    def to_rows(self) -> List[dict]:
        keys = list(self.columns.keys())
        return [{k: self.columns[k].data[i] for k in keys} for i in range(self.num_rows)]

    def __repr__(self): return f"ArrowTable({self.num_rows} rows × {len(self.columns)} cols)"

# Demo
random.seed(3)
rows = [{"user_id": f"u{i}", "age": random.randint(18,70),
         "revenue": round(random.gauss(500,150), 2),
         "active": random.choice([True, False])} for i in range(1000)]

table = ArrowTable.from_rows(rows)
print(f"Original: {table}")

# Column scan (no row deserialization)
t0 = _time.perf_counter()
revenue_col = table.column("revenue")
total_revenue = revenue_col.sum()
mean_revenue  = revenue_col.mean()
t1 = _time.perf_counter()
print(f"Column scan (sum/mean): {(t1-t0)*1e6:.0f}μs  →  total=${total_revenue:,.0f}  mean=${mean_revenue:.0f}")

# Filter + project (predicate pushdown simulation)
high_value = table.filter("revenue", "gt", 700).select("user_id", "revenue")
print(f"After filter revenue>700: {high_value}")
print(f"Sample: {high_value.to_rows()[:3]}")
