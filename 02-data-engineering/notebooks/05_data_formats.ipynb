# ── Cell 3: Delta Lake Transaction Log Simulation ─────────────────────────────
import json, time as _time
from copy import deepcopy

@dataclass
class DeltaAction:
    action_type: str   # "add", "remove", "metadata", "commitInfo"
    path: Optional[str] = None
    data: Optional[dict] = None

class DeltaLog:
    """Simulates a Delta Lake _delta_log with ACID semantics."""

    def __init__(self, table_path: str):
        self.table_path = table_path
        self._log: List[dict] = []   # list of transactions
        self._active_files: Dict[str, dict] = {}  # path → stats
        self._version = -1

    @property
    def version(self) -> int:
        return self._version

    def _commit(self, actions: List[DeltaAction], operation: str, params: dict) -> int:
        self._version += 1
        txn = {
            "version": self._version,
            "timestamp": _time.time(),
            "operation": operation,
            "operationParameters": params,
            "actions": [],
        }
        for a in actions:
            txn["actions"].append({"type": a.action_type, "path": a.path, "data": a.data})
            if a.action_type == "add" and a.path:
                self._active_files[a.path] = a.data or {}
            elif a.action_type == "remove" and a.path:
                self._active_files.pop(a.path, None)
        self._log.append(txn)
        return self._version

    def create_table(self, schema: dict) -> int:
        return self._commit(
            [DeltaAction("metadata", data={"schema": schema})],
            "CREATE TABLE", {"schema": str(schema)}
        )

    def insert(self, files: List[str], row_counts: List[int]) -> int:
        actions = [DeltaAction("add", f, {"numRows": rc})
                   for f, rc in zip(files, row_counts)]
        return self._commit(actions, "WRITE", {"mode": "append"})

    def overwrite(self, new_files: List[str], row_counts: List[int]) -> int:
        removes = [DeltaAction("remove", f) for f in list(self._active_files.keys())]
        adds = [DeltaAction("add", f, {"numRows": rc})
                for f, rc in zip(new_files, row_counts)]
        return self._commit(removes + adds, "WRITE", {"mode": "overwrite"})

    def time_travel(self, version: int) -> List[str]:
        """Return active files at a given historical version."""
        active = {}
        for txn in self._log:
            if txn["version"] > version:
                break
            for a in txn["actions"]:
                if a["type"] == "add" and a["path"]:
                    active[a["path"]] = True
                elif a["type"] == "remove" and a["path"]:
                    active.pop(a["path"], None)
        return list(active.keys())

    def show_log(self) -> None:
        print(f"\nDelta Log for {self.table_path}:")
        for txn in self._log:
            n_add = sum(1 for a in txn["actions"] if a["type"] == "add")
            n_rem = sum(1 for a in txn["actions"] if a["type"] == "remove")
            print(f"  v{txn['version']:02d} | {txn['operation']:<20} | +{n_add} files  -{n_rem} files")
        print(f"  Current active files: {len(self._active_files)}")

log = DeltaLog("s3://bucket/users/")
log.create_table({"fields": [{"name": "user_id"}, {"name": "age"}]})
log.insert(["part-00001.parquet", "part-00002.parquet"], [500, 500])
log.insert(["part-00003.parquet"], [300])
log.overwrite(["part-00004.parquet"], [1500])  # new day's full overwrite
log.insert(["part-00005.parquet"], [200])
log.show_log()

print(f"\nTime travel to v2: {log.time_travel(2)}")
print(f"Current (v{log.version}): {list(log._active_files.keys())}")
