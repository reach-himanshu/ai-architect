# ── Cell 1: Micro-Batch Pipeline Simulator ────────────────────────────────────
import time
import random
from collections import defaultdict, deque
from dataclasses import dataclass, field
from typing import List, Dict, Optional, Callable

@dataclass
class Event:
    event_id: str
    event_time: float   # Unix timestamp (simulated)
    processing_time: float
    payload: dict

def generate_events(n: int, base_ts: float = 1_700_000_000.0) -> List[Event]:
    random.seed(42)
    events = []
    for i in range(n):
        # Simulate some late events (event_time < processing_time)
        delay = random.choice([0, 0, 0, 5, 30, 120])  # seconds late
        et = base_ts + i * 2 - delay
        pt = base_ts + i * 2
        events.append(Event(
            event_id=f"evt-{i:04d}",
            event_time=et,
            processing_time=pt,
            payload={"value": random.randint(1, 100), "user": f"u{i%10}"},
        ))
    return events

class MicroBatchPipeline:
    """Collects events and processes them in fixed-size time windows."""

    def __init__(self, window_seconds: float = 10.0):
        self.window_seconds = window_seconds
        self.buffer: List[Event] = []
        self.results: List[dict] = []

    def ingest(self, event: Event) -> None:
        self.buffer.append(event)

    def flush(self, current_time: float) -> Optional[dict]:
        """Process all events in buffer older than window_seconds."""
        window_events = [e for e in self.buffer if e.processing_time <= current_time]
        self.buffer = [e for e in self.buffer if e.processing_time > current_time]

        if not window_events:
            return None

        total = sum(e.payload["value"] for e in window_events)
        result = {
            "window_end": current_time,
            "count": len(window_events),
            "sum": total,
            "avg": total / len(window_events),
        }
        self.results.append(result)
        return result

# Demo
events = generate_events(40)
pipeline = MicroBatchPipeline(window_seconds=10.0)
base = 1_700_000_000.0

print("Micro-Batch Pipeline (10s windows):")
for e in events:
    pipeline.ingest(e)

# Simulate 4 micro-batch flushes
for tick in range(4):
    t = base + tick * 10
    r = pipeline.flush(t)
    if r:
        print(f"  Window @{tick*10:>3}s: count={r['count']}  sum={r['sum']}  avg={r['avg']:.1f}")
