# ── Cell 4: Write-Audit-Publish Pattern ───────────────────────────────────────
import json
from datetime import date

class DataLake:
    """In-memory simulation of a partitioned data lake."""
    def __init__(self):
        self._staging: Dict[str, list] = {}
        self._production: Dict[str, list] = {}
        self._audit_log: list = []

    def write_staging(self, partition: str, rows: list) -> None:
        self._staging[partition] = rows
        print(f"  [WRITE]  staging/{partition}  ({len(rows)} rows)")

    def audit(self, partition: str, expected_min_rows: int, required_columns: list) -> bool:
        rows = self._staging.get(partition, [])
        issues = []
        if len(rows) < expected_min_rows:
            issues.append(f"row count {len(rows)} < {expected_min_rows}")
        if rows:
            for col in required_columns:
                if col not in rows[0]:
                    issues.append(f"missing column '{col}'")
            null_rate = sum(1 for r in rows if any(v is None for v in r.values())) / len(rows)
            if null_rate > 0.1:
                issues.append(f"null rate {null_rate:.0%} > 10%")

        passed = len(issues) == 0
        self._audit_log.append({"partition": partition, "passed": passed, "issues": issues})
        status = "✓ PASS" if passed else f"✗ FAIL: {issues}"
        print(f"  [AUDIT]  staging/{partition}  {status}")
        return passed

    def publish(self, partition: str) -> bool:
        if partition not in self._staging:
            print(f"  [PUBLISH] ERROR: no staged data for {partition}")
            return False
        # Atomic swap
        self._production[partition] = self._staging.pop(partition)
        print(f"  [PUBLISH] staging/{partition} → production/{partition}  ✓")
        return True

    def run_pipeline(self, partition: str, rows: list,
                     expected_min_rows: int, required_columns: list) -> bool:
        print(f"\n--- WAP Pipeline for partition: {partition} ---")
        self.write_staging(partition, rows)
        if self.audit(partition, expected_min_rows, required_columns):
            return self.publish(partition)
        else:
            print(f"  [SKIP]   Audit failed — production partition unchanged")
            return False

lake = DataLake()

# Good batch
good_rows = [{"user_id": f"u{i}", "revenue": i*10, "date": "2025-01-15"} for i in range(100)]
lake.run_pipeline("date=2025-01-15", good_rows, expected_min_rows=50, required_columns=["user_id","revenue","date"])

# Bad batch (too few rows)
bad_rows = [{"user_id": "u1", "revenue": 10, "date": "2025-01-16"} for _ in range(5)]
lake.run_pipeline("date=2025-01-16", bad_rows, expected_min_rows=50, required_columns=["user_id","revenue","date"])

print(f"\nProduction partitions available: {list(lake._production.keys())}")
