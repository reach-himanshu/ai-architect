# ── Cell 3: Watermark-Based Event-Time Windowing ──────────────────────────────

@dataclass
class WindowResult:
    window_start: float
    window_end: float
    count: int
    total: float

class WatermarkWindowProcessor:
    """
    Tumbling event-time window processor with watermark and allowed lateness.
    """
    def __init__(self, window_size: float, allowed_lateness: float, watermark_lag: float):
        self.window_size = window_size
        self.allowed_lateness = allowed_lateness
        self.watermark_lag = watermark_lag
        self._max_event_time: float = 0.0
        self._windows: Dict[float, List[float]] = defaultdict(list)
        self._emitted: set = set()
        self.late_dropped = 0

    @property
    def watermark(self) -> float:
        return self._max_event_time - self.watermark_lag

    def _window_start(self, event_time: float) -> float:
        return math.floor(event_time / self.window_size) * self.window_size

    def process(self, event_time: float, value: float) -> Optional[WindowResult]:
        self._max_event_time = max(self._max_event_time, event_time)
        ws = self._window_start(event_time)
        we = ws + self.window_size

        if event_time < self.watermark - self.allowed_lateness:
            self.late_dropped += 1
            return None  # Too late — drop

        self._windows[ws].append(value)

        # Emit windows that are past watermark
        to_emit = [w for w in self._windows if w + self.window_size < self.watermark and w not in self._emitted]
        if to_emit:
            ws_emit = min(to_emit)
            self._emitted.add(ws_emit)
            values = self._windows[ws_emit]
            return WindowResult(ws_emit, ws_emit + self.window_size, len(values), sum(values))
        return None

# Simulate events with some arriving late
base = 1000.0
processor = WatermarkWindowProcessor(window_size=10.0, allowed_lateness=5.0, watermark_lag=3.0)

event_stream = [
    (base+1, 10), (base+2, 20), (base+3, 15),   # window [1000, 1010)
    (base+11, 30), (base+12, 25),                 # window [1010, 1020)
    (base+4, 5),                                  # late but within allowed_lateness
    (base+21, 40),                                # window [1020, 1030) — triggers emit
    (base+2, 99),                                 # too late, dropped
]

print("Watermark-Based Windowing (window=10s, allowed_lateness=5s, lag=3s):")
for et, val in event_stream:
    result = processor.process(et, val)
    wm = processor.watermark
    status = f"  event_time={et-base:.0f}s  watermark={wm-base:.0f}s"
    if result:
        status += f"  → EMIT window [{result.window_start-base:.0f},{result.window_end-base:.0f}) count={result.count} total={result.total}"
    print(status)

print(f"\nLate events dropped: {processor.late_dropped}")
