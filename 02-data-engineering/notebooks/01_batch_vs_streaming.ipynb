# ── Cell 2: Kafka-Style Topic with Consumer Groups ────────────────────────────
from typing import Iterator
import math

@dataclass
class KafkaMessage:
    offset: int
    key: str
    value: dict
    timestamp: float

class KafkaPartition:
    def __init__(self, partition_id: int):
        self.partition_id = partition_id
        self._log: List[KafkaMessage] = []
        self._offsets: Dict[str, int] = {}   # group_id -> committed offset

    def produce(self, key: str, value: dict, timestamp: float) -> int:
        offset = len(self._log)
        self._log.append(KafkaMessage(offset, key, value, timestamp))
        return offset

    def poll(self, group_id: str, max_records: int = 10) -> List[KafkaMessage]:
        committed = self._offsets.get(group_id, 0)
        records = self._log[committed: committed + max_records]
        return records

    def commit(self, group_id: str, offset: int) -> None:
        self._offsets[group_id] = offset

class KafkaTopic:
    def __init__(self, name: str, num_partitions: int = 3):
        self.name = name
        self.partitions = [KafkaPartition(i) for i in range(num_partitions)]

    def produce(self, key: str, value: dict, timestamp: float = 0.0) -> tuple:
        # Hash key to partition
        p_idx = hash(key) % len(self.partitions)
        offset = self.partitions[p_idx].produce(key, value, timestamp)
        return (p_idx, offset)

    def assign_partitions(self, group_id: str, consumer_count: int) -> Dict[int, List[int]]:
        """Round-robin partition assignment."""
        assignment: Dict[int, List[int]] = defaultdict(list)
        for p_idx in range(len(self.partitions)):
            consumer_id = p_idx % consumer_count
            assignment[consumer_id].append(p_idx)
        return dict(assignment)

# Demo
topic = KafkaTopic("user-events", num_partitions=3)
random.seed(1)

# Produce 15 messages
for i in range(15):
    key = f"user-{i % 5}"
    topic.produce(key, {"action": "click", "item": i}, timestamp=float(i))

# Consume with 2 consumers in the same group
assignment = topic.assign_partitions("analytics-group", consumer_count=2)
print("Partition Assignment for 'analytics-group' (2 consumers):")
for consumer_id, parts in assignment.items():
    print(f"  Consumer-{consumer_id}: partitions {parts}")

print("\nConsuming records:")
GROUP = "analytics-group"
for consumer_id, parts in assignment.items():
    for p_idx in parts:
        p = topic.partitions[p_idx]
        records = p.poll(GROUP, max_records=10)
        for r in records:
            print(f"  Consumer-{consumer_id} | P{p_idx} | offset={r.offset} | key={r.key}")
        if records:
            p.commit(GROUP, len(records))
