# ── Cell 3: PSI Drift Detector ────────────────────────────────────────────────

def compute_psi(expected: List[float], actual: List[float], n_bins: int = 10) -> float:
    """
    Population Stability Index between two distributions.
    PSI < 0.1 → stable; 0.1-0.2 → moderate; > 0.2 → significant drift.
    """
    # Use expected to define bin edges
    min_val = min(min(expected), min(actual))
    max_val = max(max(expected), max(actual))
    bin_width = (max_val - min_val) / n_bins

    def bin_counts(data):
        counts = [0] * n_bins
        for v in data:
            idx = min(int((v - min_val) / bin_width), n_bins - 1)
            counts[idx] += 1
        return counts

    exp_counts = bin_counts(expected)
    act_counts = bin_counts(actual)
    n_exp, n_act = len(expected), len(actual)

    psi = 0.0
    for e, a in zip(exp_counts, act_counts):
        e_pct = max(e / n_exp, 1e-6)
        a_pct = max(a / n_act, 1e-6)
        psi += (a_pct - e_pct) * math.log(a_pct / e_pct)
    return psi

def interpret_psi(psi: float) -> str:
    if psi < 0.1: return "✓ Stable"
    if psi < 0.2: return "⚠ Moderate drift — monitor"
    return "✗ Significant drift — investigate"

random.seed(42)
# Baseline distribution (training)
baseline = [random.gauss(50, 10) for _ in range(1000)]

scenarios = {
    "Same dist (no drift)": [random.gauss(50, 10) for _ in range(500)],
    "Slight shift (mean+5)": [random.gauss(55, 10) for _ in range(500)],
    "Large shift (mean+20)": [random.gauss(70, 10) for _ in range(500)],
    "Different shape (bimodal)": [random.gauss(35,5) if random.random()<0.5 else random.gauss(65,5) for _ in range(500)],
}

print(f"PSI Drift Analysis (baseline: N(50,10), n=1000):")
print(f"{'Scenario':<35} {'PSI':>6}  {'Interpretation'}")
print("-" * 65)
for name, dist in scenarios.items():
    psi = compute_psi(baseline, dist)
    print(f"  {name:<33} {psi:>6.4f}  {interpret_psi(psi)}")
