# ── Cell 4: Z-Score Anomaly Detection + DLQ Pipeline ─────────────────────────

class AnomalyDetector:
    """Running Z-score anomaly detector for streaming metrics."""

    def __init__(self, window: int = 50, threshold: float = 3.0):
        self.window = window
        self.threshold = threshold
        self._history: List[float] = []

    def _stats(self):
        n = len(self._history)
        mean = sum(self._history) / n
        std = (sum((x-mean)**2 for x in self._history) / n) ** 0.5
        return mean, std

    def check(self, value: float) -> dict:
        self._history.append(value)
        if len(self._history) > self.window:
            self._history.pop(0)
        if len(self._history) < 10:
            return {"value": value, "anomaly": False, "z_score": 0.0}
        mean, std = self._stats()
        z = abs(value - mean) / max(std, 1e-9)
        return {"value": value, "mean": round(mean, 2), "std": round(std, 2),
                "z_score": round(z, 2), "anomaly": z > self.threshold}

class DLQPipeline:
    """Route bad records to Dead Letter Queue, good records to output."""

    def __init__(self, validator: SchemaValidator):
        self.validator = validator
        self.output: List[dict] = []
        self.dlq: List[dict] = []

    def process(self, row: dict, row_id: int) -> None:
        result = self.validator.validate_row(row)
        if result.passed:
            self.output.append(row)
        else:
            self.dlq.append({"row_id": row_id, "original": row, "errors": result.errors})

    def summary(self) -> None:
        total = len(self.output) + len(self.dlq)
        print(f"\nDLQ Pipeline Summary:")
        print(f"  Total processed : {total}")
        print(f"  Output (good)   : {len(self.output)}  ({len(self.output)/total:.0%})")
        print(f"  DLQ (bad)       : {len(self.dlq)}  ({len(self.dlq)/total:.0%})")
        if self.dlq:
            print(f"  First DLQ entry : {self.dlq[0]}")

# Demo anomaly detection on row-count metrics
detector = AnomalyDetector(window=30, threshold=3.0)
random.seed(99)
counts = [random.randint(90, 110) for _ in range(40)] + [5, 250]  # 2 anomalies at end

print("Z-Score Anomaly Detection on Row Counts:")
for i, c in enumerate(counts):
    result = detector.check(c)
    if result["anomaly"]:
        print(f"  ⚠ ANOMALY at t={i}: count={c}  z={result['z_score']}  (mean={result['mean']}, std={result['std']})")

# Demo DLQ pipeline
pipeline = DLQPipeline(validator)
mixed_rows = [
    {"user_id": "u1", "age": 25, "email": "a@b.com", "status": "active"},
    {"user_id": "u2", "age": -5, "email": "bad", "status": "unknown"},
    {"user_id": "u3", "age": 30, "email": "c@d.com", "status": "inactive"},
    {"age": 40, "email": "e@f.com", "status": "active"},
    {"user_id": "u5", "age": 22, "email": "g@h.com", "status": "active"},
]
for i, row in enumerate(mixed_rows):
    pipeline.process(row, row_id=i)
pipeline.summary()
