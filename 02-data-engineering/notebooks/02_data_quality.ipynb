# ── Cell 2: Statistical Profiler ──────────────────────────────────────────────

class ColumnProfiler:
    """Compute descriptive statistics for a column of values."""

    @staticmethod
    def profile(values: List[Any], col_name: str = "col") -> dict:
        non_null = [v for v in values if v is not None]
        null_count = len(values) - len(non_null)
        n = len(non_null)
        if n == 0:
            return {"col": col_name, "count": 0, "null_rate": 1.0}

        numeric = all(isinstance(v, (int, float)) for v in non_null)
        result = {
            "col": col_name,
            "count": len(values),
            "null_rate": null_count / len(values),
            "unique": len(set(non_null)),
            "cardinality": len(set(non_null)) / n,
        }

        if numeric:
            sorted_vals = sorted(non_null)
            mean = sum(non_null) / n
            variance = sum((x - mean) ** 2 for x in non_null) / n
            result.update({
                "mean": round(mean, 4),
                "std": round(variance ** 0.5, 4),
                "min": sorted_vals[0],
                "p25": sorted_vals[int(n * 0.25)],
                "p50": sorted_vals[int(n * 0.50)],
                "p75": sorted_vals[int(n * 0.75)],
                "max": sorted_vals[-1],
            })
        return result

random.seed(5)
ages    = [random.randint(18, 65) for _ in range(200)] + [None] * 10
revenues = [random.gauss(500, 150) for _ in range(200)] + [None] * 30
statuses = random.choices(["active", "inactive", "pending"], weights=[7,2,1], k=200)

print("Column Profiles:")
for col, vals in [("age", ages), ("revenue", revenues), ("status", statuses)]:
    p = ColumnProfiler.profile(vals, col)
    print(f"\n  [{col}]")
    for k, v in p.items():
        if k != "col":
            print(f"    {k}: {v}")
