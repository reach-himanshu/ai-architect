# ── Cell 1: Schema Validator ──────────────────────────────────────────────────
from dataclasses import dataclass, field
from typing import Any, Dict, List, Optional, Callable
import re, math, random
from collections import defaultdict

@dataclass
class ColumnRule:
    name: str
    required: bool = True
    nullable: bool = False
    dtype: Optional[type] = None
    min_val: Optional[float] = None
    max_val: Optional[float] = None
    regex: Optional[str] = None
    allowed_values: Optional[set] = None

@dataclass
class ValidationResult:
    passed: bool
    errors: List[str] = field(default_factory=list)
    warnings: List[str] = field(default_factory=list)

class SchemaValidator:
    def __init__(self, rules: List[ColumnRule]):
        self.rules = {r.name: r for r in rules}

    def validate_row(self, row: dict) -> ValidationResult:
        errors, warnings = [], []
        for col, rule in self.rules.items():
            if rule.required and col not in row:
                errors.append(f"Missing required column '{col}'")
                continue
            val = row.get(col)
            if val is None:
                if not rule.nullable:
                    errors.append(f"'{col}' is null but not nullable")
                continue
            if rule.dtype and not isinstance(val, rule.dtype):
                errors.append(f"'{col}' expected {rule.dtype.__name__}, got {type(val).__name__}")
            if rule.min_val is not None and val < rule.min_val:
                errors.append(f"'{col}'={val} < min {rule.min_val}")
            if rule.max_val is not None and val > rule.max_val:
                errors.append(f"'{col}'={val} > max {rule.max_val}")
            if rule.regex and not re.match(rule.regex, str(val)):
                errors.append(f"'{col}'='{val}' fails regex {rule.regex}")
            if rule.allowed_values and val not in rule.allowed_values:
                errors.append(f"'{col}'='{val}' not in {rule.allowed_values}")
        return ValidationResult(passed=len(errors) == 0, errors=errors, warnings=warnings)

    def validate_dataset(self, rows: List[dict]) -> dict:
        results = [self.validate_row(r) for r in rows]
        n_pass = sum(1 for r in results if r.passed)
        all_errors = [e for r in results for e in r.errors]
        return {
            "total": len(rows), "passed": n_pass, "failed": len(rows) - n_pass,
            "pass_rate": n_pass / max(len(rows), 1),
            "top_errors": list(set(all_errors))[:5],
        }

# Demo
rules = [
    ColumnRule("user_id", required=True, dtype=str),
    ColumnRule("age", required=True, dtype=int, min_val=0, max_val=120),
    ColumnRule("email", required=True, dtype=str, regex=r"^[^@]+@[^@]+\.[^@]+$"),
    ColumnRule("status", required=True, allowed_values={"active", "inactive"}),
    ColumnRule("revenue", nullable=True, dtype=float),
]
validator = SchemaValidator(rules)

rows = [
    {"user_id": "u1", "age": 25, "email": "a@b.com", "status": "active", "revenue": 10.5},
    {"user_id": "u2", "age": -1,  "email": "bad-email", "status": "unknown"},
    {"user_id": "u3", "age": 30, "email": "c@d.com", "status": "inactive", "revenue": None},
    {"age": 40, "email": "e@f.com", "status": "active"},  # missing user_id
]

summary = validator.validate_dataset(rows)
print("Dataset Validation Summary:")
for k, v in summary.items():
    print(f"  {k}: {v}")
