# ── Cell 3: SLA Monitor ───────────────────────────────────────────────────────
from datetime import datetime, timedelta

@dataclass
class SLARule:
    dag_id: str
    task_id: str
    max_duration_s: float        # task must complete within this
    expected_by_offset_s: float  # expected finish time = schedule + offset

class SLAMonitor:
    def __init__(self, rules: List[SLARule]):
        self.rules = {(r.dag_id, r.task_id): r for r in rules}
        self.misses: List[dict] = []

    def check(self, dag_id: str, task_id: str,
              scheduled_time: float, start_time: float, end_time: float) -> Optional[dict]:
        key = (dag_id, task_id)
        rule = self.rules.get(key)
        if not rule:
            return None

        duration = end_time - start_time
        expected_by = scheduled_time + rule.expected_by_offset_s
        issues = []

        if duration > rule.max_duration_s:
            issues.append(f"duration {duration:.1f}s > max {rule.max_duration_s}s")
        if end_time > expected_by:
            overdue_s = end_time - expected_by
            issues.append(f"finished {overdue_s:.1f}s after expected deadline")

        if issues:
            miss = {"dag_id": dag_id, "task_id": task_id, "issues": issues}
            self.misses.append(miss)
            return miss
        return None

rules = [
    SLARule("user_feature_pipeline", "extract",   max_duration_s=30,  expected_by_offset_s=60),
    SLARule("user_feature_pipeline", "transform",  max_duration_s=120, expected_by_offset_s=200),
    SLARule("user_feature_pipeline", "load",       max_duration_s=60,  expected_by_offset_s=300),
]
monitor = SLAMonitor(rules)

scheduled = time.time()
scenarios = [
    ("extract",   scheduled,    scheduled,    scheduled + 25),   # OK
    ("transform", scheduled,    scheduled+60, scheduled+200),    # duration OK, late finish
    ("load",      scheduled,    scheduled+200,scheduled+280),    # OK
]

print("SLA Monitoring:")
for task_id, sched, start, end in scenarios:
    miss = monitor.check("user_feature_pipeline", task_id, sched, start, end)
    status = f"⚠ SLA MISS: {miss['issues']}" if miss else "✓ within SLA"
    print(f"  {task_id:<15} {status}")

print(f"\nTotal SLA misses: {len(monitor.misses)}")
