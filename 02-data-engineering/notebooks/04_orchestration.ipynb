# ── Cell 2: DAG Executor with Retry + Exponential Back-off ───────────────────
import random as _random

class TaskInstance:
    def __init__(self, task: Task, run_id: str):
        self.task = task
        self.run_id = run_id
        self.status = "pending"
        self.start_time: Optional[float] = None
        self.end_time: Optional[float] = None
        self.output: Any = None
        self.error: Optional[str] = None

def run_with_retry(task: Task, context: dict, attempt: int = 0) -> tuple:
    """Returns (success: bool, output or error)."""
    base_delay = 0.5  # seconds (reduced for simulation)
    max_attempts = task.retries + 1

    while attempt < max_attempts:
        try:
            result = task.func(context)
            return True, result
        except Exception as e:
            attempt += 1
            if attempt >= max_attempts:
                return False, str(e)
            # Exponential back-off with jitter
            delay = base_delay * (2 ** attempt) * (1 + _random.uniform(-0.2, 0.2))
            delay = min(delay, task.retry_delay_s * 10 or 2.0)
            print(f"    [RETRY] {task.task_id} attempt {attempt+1}/{max_attempts} after {delay:.2f}s")
            time.sleep(min(delay, 0.05))  # capped for demo speed
    return False, "Max retries exceeded"

class DAGRunner:
    def __init__(self, dag: DAG):
        self.dag = dag
        self.run_id = f"run-{int(time.time())}"
        self.instances: Dict[str, TaskInstance] = {}
        self.context: dict = {}

    def run(self) -> bool:
        order = self.dag.topological_order()
        print(f"\nRunning DAG '{self.dag.dag_id}' (run_id={self.run_id})")
        all_success = True

        for tid in order:
            task = self.dag._tasks[tid]
            ti = TaskInstance(task, self.run_id)
            self.instances[tid] = ti

            # Check upstream succeeded
            upstream_ok = all(
                self.instances.get(dep, None) and self.instances[dep].status == "success"
                for dep in self.dag._deps.get(tid, [])
            )
            if not upstream_ok and self.dag._deps.get(tid):
                ti.status = "skipped"
                print(f"  {tid:<15} SKIPPED (upstream failed)")
                all_success = False
                continue

            ti.status = "running"
            ti.start_time = time.time()
            success, output = run_with_retry(task, self.context)
            ti.end_time = time.time()
            duration = ti.end_time - ti.start_time

            if success:
                ti.status = "success"
                ti.output = output
                if isinstance(output, dict):
                    self.context.update(output)
                sla_ok = task.sla_s is None or duration <= task.sla_s
                sla_str = "" if sla_ok else f"  ⚠ SLA MISS ({duration:.2f}s > {task.sla_s}s)"
                print(f"  {tid:<15} ✓  {duration*1000:.0f}ms{sla_str}")
            else:
                ti.status = "failed"
                ti.error = output
                print(f"  {tid:<15} ✗  {output}")
                all_success = False

        return all_success

# Inject a flaky task that fails once then succeeds
_fail_count = {"transform": 0}
def flaky_transform(ctx):
    _fail_count["transform"] += 1
    if _fail_count["transform"] < 2:
        raise ValueError("Transient network error")
    return {"features": ctx.get("rows", 0) * 2}

dag._tasks["transform"] = Task("transform", flaky_transform, retries=2, retry_delay_s=1.0)
runner = DAGRunner(dag)
runner.run()
