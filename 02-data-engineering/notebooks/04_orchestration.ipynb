# ── Cell 1: DAG with Topological Sort ────────────────────────────────────────
from dataclasses import dataclass, field
from typing import Dict, List, Optional, Callable, Any
from collections import defaultdict, deque
import time, random, math

@dataclass
class Task:
    task_id: str
    func: Callable
    retries: int = 0
    retry_delay_s: float = 0.0  # simulated delay
    sla_s: Optional[float] = None  # max allowed seconds

class DAG:
    def __init__(self, dag_id: str):
        self.dag_id = dag_id
        self._tasks: Dict[str, Task] = {}
        self._deps: Dict[str, List[str]] = defaultdict(list)  # task → upstream deps

    def add_task(self, task: Task) -> "DAG":
        self._tasks[task.task_id] = task
        return self

    def set_downstream(self, upstream_id: str, downstream_id: str) -> "DAG":
        self._deps[downstream_id].append(upstream_id)
        return self

    def topological_order(self) -> List[str]:
        """Kahn's algorithm — returns tasks in execution order."""
        in_degree = {tid: 0 for tid in self._tasks}
        for tid, deps in self._deps.items():
            in_degree[tid] = len(deps)

        queue = deque(tid for tid, deg in in_degree.items() if deg == 0)
        order = []
        while queue:
            tid = queue.popleft()
            order.append(tid)
            for other_tid in self._tasks:
                if tid in self._deps.get(other_tid, []):
                    in_degree[other_tid] -= 1
                    if in_degree[other_tid] == 0:
                        queue.append(other_tid)

        if len(order) != len(self._tasks):
            raise ValueError("DAG has a cycle!")
        return order

# Demo DAG
def extract():    return {"rows": 1000}
def validate(ctx): return {"valid": ctx.get("rows", 0) > 0}
def transform(ctx): return {"features": ctx.get("rows", 0) * 2}
def load(ctx):    return {"loaded": True}
def notify(ctx):  return {"notified": True}

dag = DAG("user_feature_pipeline")
for tid, fn in [("extract", extract), ("validate", validate),
                ("transform", transform), ("load", load), ("notify", notify)]:
    dag.add_task(Task(tid, fn, retries=2))

dag.set_downstream("extract", "validate")
dag.set_downstream("validate", "transform")
dag.set_downstream("transform", "load")
dag.set_downstream("load", "notify")

order = dag.topological_order()
print(f"DAG '{dag.dag_id}' execution order:")
for i, tid in enumerate(order):
    deps = dag._deps.get(tid, [])
    dep_str = f"← {', '.join(deps)}" if deps else "(start)"
    print(f"  {i+1}. {tid:<15} {dep_str}")
