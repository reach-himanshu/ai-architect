# ── Cell 4: Pipeline Metadata Store ───────────────────────────────────────────
import json
from collections import defaultdict
from typing import List

@dataclass
class PipelineRun:
    dag_id: str
    run_id: str
    execution_date: str
    status: str
    start_time: float
    end_time: float
    rows_processed: int
    output_partition: str
    task_stats: Dict[str, str] = field(default_factory=dict)

class MetadataStore:
    def __init__(self):
        self._runs: List[PipelineRun] = []

    def record(self, run: PipelineRun) -> None:
        self._runs.append(run)

    def get_runs(self, dag_id: str) -> List[PipelineRun]:
        return [r for r in self._runs if r.dag_id == dag_id]

    def freshness_report(self, dag_id: str) -> None:
        runs = self.get_runs(dag_id)
        if not runs:
            print("No runs found.")
            return

        latest = max(runs, key=lambda r: r.end_time)
        lag_s = time.time() - latest.end_time
        success_rate = sum(1 for r in runs if r.status == "success") / len(runs)
        durations = [r.end_time - r.start_time for r in runs if r.status == "success"]
        avg_dur = sum(durations) / len(durations) if durations else 0
        total_rows = sum(r.rows_processed for r in runs if r.status == "success")

        print(f"\nPipeline Metadata Report: {dag_id}")
        print(f"  Total runs      : {len(runs)}")
        print(f"  Success rate    : {success_rate:.0%}")
        print(f"  Avg duration    : {avg_dur:.1f}s")
        print(f"  Freshness lag   : {lag_s:.0f}s since last successful run")
        print(f"  Total rows      : {total_rows:,}")
        print(f"  Latest partition: {latest.output_partition}")

# Simulate 10 historical runs
store = MetadataStore()
base_t = time.time() - 86400 * 10  # 10 days ago

for day in range(10):
    t_start = base_t + day * 86400
    success = day != 4  # one failure on day 4
    store.record(PipelineRun(
        dag_id="user_feature_pipeline",
        run_id=f"run-{day:03d}",
        execution_date=f"2025-01-{day+1:02d}",
        status="success" if success else "failed",
        start_time=t_start,
        end_time=t_start + (45 + random.randint(-10, 30)),
        rows_processed=1_000_000 + random.randint(-50000, 100000) if success else 0,
        output_partition=f"s3://data-lake/features/date=2025-01-{day+1:02d}/",
    ))

store.freshness_report("user_feature_pipeline")
