# ── Cell 2: Kappa Architecture — Replay Engine ────────────────────────────────

class KafkaLog:
    """Immutable append-only log — Kafka semantics."""
    def __init__(self, retention_s: float = float("inf")):
        self._log: List[Event] = []
        self.retention_s = retention_s

    def append(self, event: Event) -> int:
        self._log.append(event)
        return len(self._log) - 1

    def read(self, from_offset: int = 0, max_ts: Optional[float] = None) -> List[Event]:
        events = self._log[from_offset:]
        if max_ts is not None:
            events = [e for e in events if e.timestamp <= max_ts]
        return events

class StreamingJob:
    """Stateful streaming job — can be replayed from offset 0."""
    def __init__(self, name: str):
        self.name = name
        self._state: Dict[str, dict] = defaultdict(lambda: {"spend": 0.0, "count": 0})
        self.processed = 0

    def process(self, event: Event) -> None:
        if event.event_type == "purchase":
            self._state[event.user_id]["spend"] += event.value
            self._state[event.user_id]["count"] += 1
        self.processed += 1

    def get_results(self) -> Dict[str, dict]:
        return {k: dict(v) for k, v in self._state.items()}

    def reset(self) -> None:
        self._state.clear()
        self.processed = 0

def run_kappa(log: KafkaLog, job: StreamingJob,
              from_offset: int = 0, max_ts: Optional[float] = None) -> Dict[str, dict]:
    job.reset()
    events = log.read(from_offset, max_ts)
    for e in events:
        job.process(e)
    return job.get_results()

kafka_log = KafkaLog()
all_events = generate_events(300)
for e in all_events:
    kafka_log.append(e)

job_v1 = StreamingJob("spend-aggregator-v1")

# Full historical replay
results = run_kappa(kafka_log, job_v1)
print(f"Kappa: Full replay ({len(all_events)} events)")
for uid in sorted(results.keys())[:4]:
    print(f"  {uid}: {results[uid]}")

# Replay only up to a specific timestamp (time travel)
cutoff_ts = all_events[100].timestamp
results_historical = run_kappa(kafka_log, job_v1, max_ts=cutoff_ts)
print(f"\nKappa: Replay up to t={cutoff_ts:.0f} (first 100 events approx)")
print(f"  Users with purchases: {sum(1 for v in results_historical.values() if v['count'] > 0)}")
