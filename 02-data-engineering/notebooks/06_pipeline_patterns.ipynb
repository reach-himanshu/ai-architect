# ── Cell 3: Medallion Pipeline (Bronze → Silver → Gold) ───────────────────────

class MedallionPipeline:

    def __init__(self):
        self.bronze: List[dict] = []   # raw, immutable
        self.silver: List[dict] = []   # cleaned, validated
        self.gold: Dict[str, dict] = {}  # aggregated

    # ── Bronze: raw ingest ──────────────────────────────────
    def ingest_to_bronze(self, raw_records: List[dict]) -> int:
        for r in raw_records:
            self.bronze.append({**r, "_ingested_at": time.time(), "_source": "events_api"})
        return len(raw_records)

    # ── Silver: clean + validate ────────────────────────────
    def bronze_to_silver(self) -> tuple:
        cleaned, rejected = [], []
        seen_ids = set()
        for r in self.bronze:
            issues = []
            if not r.get("user_id"):          issues.append("missing user_id")
            if not isinstance(r.get("value"), (int, float)): issues.append("invalid value")
            if r.get("value", 0) < 0:         issues.append("negative value")
            if r.get("event_id") in seen_ids: issues.append("duplicate")

            if issues:
                rejected.append({**r, "_rejection_reason": issues})
            else:
                seen_ids.add(r.get("event_id"))
                cleaned.append({
                    "event_id": r["event_id"],
                    "user_id":  r["user_id"],
                    "event_type": r.get("event_type", "unknown"),
                    "value":    float(r["value"]),
                    "timestamp": r.get("timestamp", 0),
                })
        self.silver = cleaned
        return len(cleaned), len(rejected)

    # ── Gold: aggregate ─────────────────────────────────────
    def silver_to_gold(self) -> int:
        aggs: Dict[str, dict] = defaultdict(lambda: {
            "purchase_count": 0, "total_spend": 0.0,
            "avg_order_value": 0.0, "view_count": 0,
        })
        for r in self.silver:
            if r["event_type"] == "purchase":
                aggs[r["user_id"]]["purchase_count"] += 1
                aggs[r["user_id"]]["total_spend"] += r["value"]
            elif r["event_type"] == "view":
                aggs[r["user_id"]]["view_count"] += 1

        for uid, agg in aggs.items():
            if agg["purchase_count"] > 0:
                agg["avg_order_value"] = agg["total_spend"] / agg["purchase_count"]
        self.gold = {k: dict(v) for k, v in aggs.items()}
        return len(self.gold)

# Demo with some dirty data
raw = []
for e in all_events[:50]:
    raw.append({"event_id": e.event_id, "user_id": e.user_id,
                "event_type": e.event_type, "value": e.value, "timestamp": e.timestamp})
# Add bad records
raw += [
    {"event_id": "bad-1", "user_id": "",    "event_type": "purchase", "value": 99},
    {"event_id": "bad-2", "user_id": "u99", "event_type": "purchase", "value": -50},
    {"event_id": raw[0]["event_id"], "user_id": "u0", "event_type": "purchase", "value": 10},  # dup
]

pipeline = MedallionPipeline()
b = pipeline.ingest_to_bronze(raw)
s_ok, s_rej = pipeline.bronze_to_silver()
g = pipeline.silver_to_gold()

print(f"Medallion Pipeline:")
print(f"  Bronze: {b} raw records ingested")
print(f"  Silver: {s_ok} cleaned  |  {s_rej} rejected")
print(f"  Gold:   {g} user aggregates")
print(f"\n  Gold sample:")
for uid in sorted(pipeline.gold.keys())[:3]:
    print(f"    {uid}: {pipeline.gold[uid]}")
