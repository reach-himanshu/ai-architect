# Pipeline Patterns — Hands-On

Implementations of a Lambda architecture simulator, Kappa replay engine,
Medallion pipeline, and a point-in-time feature store. Standard-library Python only.
</cell id="cell-0">

<cell id="cell-1">
# ── Cell 1: Lambda Architecture Simulator ────────────────────────────────────
import random, time, math
from dataclasses import dataclass, field
from typing import List, Dict, Any, Optional
from collections import defaultdict

@dataclass
class Event:
    event_id: str
    user_id: str
    event_type: str
    value: float
    timestamp: float

def generate_events(n: int, base_ts: float = 1_700_000_000.0) -> List[Event]:
    random.seed(42)
    types = ["purchase", "view", "click"]
    return [Event(
        event_id=f"e{i:05d}",
        user_id=f"u{random.randint(0, 49)}",
        event_type=random.choice(types),
        value=round(random.uniform(1, 500), 2),
        timestamp=base_ts + i * 3,
    ) for i in range(n)]

class BatchLayer:
    """Periodically processes all historical events — accurate but high latency."""
    def __init__(self):
        self._all_events: List[Event] = []
        self.batch_views: Dict[str, dict] = {}  # user_id → aggregate

    def ingest(self, event: Event) -> None:
        self._all_events.append(event)

    def recompute(self) -> None:
        """Full batch recomputation over all history."""
        views: Dict[str, dict] = defaultdict(lambda: {"total_spend": 0.0, "purchase_count": 0})
        for e in self._all_events:
            if e.event_type == "purchase":
                views[e.user_id]["total_spend"] += e.value
                views[e.user_id]["purchase_count"] += 1
        self.batch_views = {k: dict(v) for k, v in views.items()}

class SpeedLayer:
    """Processes only recent events — low latency, approximate."""
    def __init__(self, window_s: float = 300):
        self.window_s = window_s
        self._buffer: List[Event] = []

    def ingest(self, event: Event) -> None:
        self._buffer.append(event)
        cutoff = event.timestamp - self.window_s
        self._buffer = [e for e in self._buffer if e.timestamp >= cutoff]

    def real_time_view(self) -> Dict[str, dict]:
        views: Dict[str, dict] = defaultdict(lambda: {"recent_spend": 0.0})
        for e in self._buffer:
            if e.event_type == "purchase":
                views[e.user_id]["recent_spend"] += e.value
        return {k: dict(v) for k, v in views.items()}

class ServingLayer:
    """Merges batch + real-time views."""
    def query(self, user_id: str, batch: Dict, rt: Dict) -> dict:
        b = batch.get(user_id, {"total_spend": 0.0, "purchase_count": 0})
        r = rt.get(user_id, {"recent_spend": 0.0})
        return {
            "user_id": user_id,
            "total_spend": b["total_spend"],
            "purchase_count": b["purchase_count"],
            "recent_spend_delta": r["recent_spend"],
        }

events = generate_events(200)
batch, speed, serving = BatchLayer(), SpeedLayer(window_s=300), ServingLayer()

for e in events:
    batch.ingest(e)
    speed.ingest(e)

batch.recompute()
rt_view = speed.real_time_view()

print("Lambda Architecture — Sample Queries:")
for uid in ["u0", "u1", "u2"]:
    result = serving.query(uid, batch.batch_views, rt_view)
    print(f"  {result}")
