# ── Cell 4: Point-in-Time Feature Store ───────────────────────────────────────
import bisect

class PointInTimeFeatureStore:
    """
    Stores time-series feature values and supports point-in-time (as-of) lookups.
    Prevents train/serve skew by ensuring the correct historical value is used.
    """

    def __init__(self):
        # entity_id → sorted list of (timestamp, value)
        self._store: Dict[str, List[tuple]] = defaultdict(list)

    def write(self, entity_id: str, timestamp: float, feature_name: str, value: Any) -> None:
        key = f"{entity_id}:{feature_name}"
        bisect.insort(self._store[key], (timestamp, value))

    def lookup(self, entity_id: str, feature_name: str, as_of: float) -> Optional[Any]:
        """Return the feature value as it existed at time `as_of`."""
        key = f"{entity_id}:{feature_name}"
        history = self._store.get(key, [])
        if not history:
            return None
        # Find the latest entry with timestamp <= as_of
        idx = bisect.bisect_right(history, (as_of, float("inf"))) - 1
        return history[idx][1] if idx >= 0 else None

    def point_in_time_join(self, label_events: List[dict], features: List[str]) -> List[dict]:
        """
        For each label event, join the feature value as it was at label_time.
        This is the core of avoiding train/serve skew.
        """
        results = []
        for event in label_events:
            entity = event["user_id"]
            row = dict(event)
            for feat in features:
                row[feat] = self.lookup(entity, feat, as_of=event["label_time"])
            results.append(row)
        return results

# Simulate: users accumulate purchase_count over time
store = PointInTimeFeatureStore()
base_ts = 1_700_000_000.0

random.seed(7)
for user_idx in range(5):
    uid = f"u{user_idx}"
    count = 0
    for day in range(30):
        if random.random() < 0.4:  # 40% chance of purchase each day
            count += 1
        ts = base_ts + day * 86400
        store.write(uid, ts, "purchase_count", count)
        store.write(uid, ts, "days_since_signup", day)

# Label events: churn prediction at specific times
label_events = [
    {"user_id": "u0", "label_time": base_ts + 10*86400, "churned": 0},
    {"user_id": "u1", "label_time": base_ts + 15*86400, "churned": 1},
    {"user_id": "u2", "label_time": base_ts + 20*86400, "churned": 0},
]

training_rows = store.point_in_time_join(label_events, ["purchase_count", "days_since_signup"])

print("Point-in-Time Feature Join (no train/serve skew):")
for row in training_rows:
    print(f"  {row}")

# Demonstrate skew: using current value instead of historical
print("\nWith skew (using current values — WRONG for training):")
for event in label_events:
    uid = event["user_id"]
    current_count = store.lookup(uid, "purchase_count", as_of=base_ts + 29*86400)
    pit_count = store.lookup(uid, "purchase_count", as_of=event["label_time"])
    print(f"  {uid}: current={current_count}  at_label_time={pit_count}  "
          f"{'(SKEW if different)' if current_count != pit_count else '(same)'}")
