<cell id="cell-0"><cell_type>markdown</cell_type># Distributed Systems Fundamentals

Simulating CAP theorem, consistency models, and vector clocks.</cell id="cell-0">
<cell id="cell-1"><cell_type>markdown</cell_type>## 1. CAP Theorem: CP vs AP System Behavior</cell id="cell-1">
<cell id="cell-2">from dataclasses import dataclass, field
from typing import Optional, Any

@dataclass
class Node:
    id: str
    data: dict = field(default_factory=dict)

class CPSystem:
    """CP: Consistent + Partition-Tolerant. Rejects writes during partition."""
    def __init__(self):
        self.primary = Node("primary")
        self.replica = Node("replica")
        self.partitioned = False

    def write(self, key: str, value: Any) -> dict:
        if self.partitioned:
            return {"success": False, "error": "Unavailable during partition (CP)"}
        self.primary.data[key] = value
        self.replica.data[key] = value   # Synchronous replication
        return {"success": True, "nodes": ["primary", "replica"]}

    def read(self, key: str, from_replica: bool = False) -> dict:
        if self.partitioned and from_replica:
            return {"success": False, "error": "Replica isolated"}
        node = self.replica if from_replica else self.primary
        return {"success": True, "value": node.data.get(key), "source": node.id}

class APSystem:
    """AP: Available + Partition-Tolerant. Returns stale data during partition."""
    def __init__(self):
        self.primary = Node("primary")
        self.replica = Node("replica")
        self.partitioned = False

    def write(self, key: str, value: Any) -> dict:
        self.primary.data[key] = value
        if not self.partitioned:
            self.replica.data[key] = value
        return {"success": True, "note": "async replication" if self.partitioned else "synced"}

    def read(self, key: str, from_replica: bool = False) -> dict:
        node = self.replica if from_replica else self.primary
        return {
            "success": True,
            "value": node.data.get(key),
            "source": node.id,
            "stale": from_replica and self.partitioned,
        }

# Demonstrate both systems during a partition
print("=== CP System (e.g. PostgreSQL with synchronous replication) ===")
cp = CPSystem()
cp.write("balance", 100)
cp.partitioned = True
print("Write during partition:", cp.write("balance", 200))
print("Read primary during partition:", cp.read("balance"))

print()
print("=== AP System (e.g. Cassandra with eventual consistency) ===")
ap = APSystem()
ap.write("balance", 100)
ap.partitioned = True
ap.write("balance", 200)   # Only updates primary
print("Read from primary:", ap.read("balance", from_replica=False))
print("Read from replica (stale!):", ap.read("balance", from_replica=True))</cell id="cell-2">
<cell id="cell-3"><cell_type>markdown</cell_type>## 2. Vector Clocks for Causality Tracking</cell id="cell-3">
<cell id="cell-4">class VectorClock:
    """Track causality in a distributed system."""

    def __init__(self, node_id: str, all_nodes: list[str]):
        self.node_id = node_id
        self.clock = {n: 0 for n in all_nodes}

    def tick(self) -> dict:
        """Increment own clock on local event."""
        self.clock[self.node_id] += 1
        return self.clock.copy()

    def merge(self, other: dict) -> None:
        """Merge received clock — take element-wise max."""
        for node, ts in other.items():
            self.clock[node] = max(self.clock.get(node, 0), ts)

    def happens_before(self, other_clock: dict) -> bool:
        """Does self happen-before other?"""
        return (
            all(self.clock.get(n, 0) <= v for n, v in other_clock.items())
            and any(self.clock.get(n, 0) < v for n, v in other_clock.items())
        )

    def concurrent_with(self, other_clock: dict) -> bool:
        return not self.happens_before(other_clock) and not all(
            other_clock.get(n, 0) <= v for n, v in self.clock.items()
        )

nodes = ["n1", "n2", "n3"]
clocks = {n: VectorClock(n, nodes) for n in nodes}

# n1 writes
ts_n1_write = clocks["n1"].tick()
print(f"n1 writes X=1:       {ts_n1_write}")

# n2 writes concurrently (hasn't seen n1)
ts_n2_write = clocks["n2"].tick()
print(f"n2 writes X=2:       {ts_n2_write}")

# n3 receives n1's message, then writes
clocks["n3"].merge(ts_n1_write)
ts_n3_write = clocks["n3"].tick()
print(f"n3 merges n1, writes:{ts_n3_write}")

print()
print(f"n1 happens-before n3? {clocks['n1'].happens_before(ts_n3_write)}")
print(f"n1 and n2 concurrent? {clocks['n1'].concurrent_with(ts_n2_write)}")
print("→ Concurrent writes need conflict resolution (LWW, CRDT, or application logic)")</cell id="cell-4">
<cell id="cell-5"><cell_type>markdown</cell_type>## 3. Saga Pattern for Distributed Transactions</cell id="cell-5">
<cell id="cell-6">from dataclasses import dataclass
from typing import Callable
import uuid

@dataclass
class SagaStep:
    name: str
    execute: Callable
    compensate: Callable

class SagaOrchestrator:
    """
    Saga pattern: chain of local transactions with compensating actions.
    On failure, compensates all completed steps in reverse order.
    """

    def __init__(self, steps: list[SagaStep]):
        self.steps = steps
        self.saga_id = str(uuid.uuid4())[:8]

    def run(self, context: dict) -> dict:
        completed = []
        print(f"Saga {self.saga_id} started")
        for step in self.steps:
            try:
                step.execute(context)
                completed.append(step)
                print(f"  [OK] {step.name}")
            except Exception as e:
                print(f"  [FAIL] {step.name}: {e}")
                print(f"  Compensating {len(completed)} completed steps...")
                for s in reversed(completed):
                    try:
                        s.compensate(context)
                        print(f"    [COMPENSATED] {s.name}")
                    except Exception as comp_err:
                        print(f"    [COMPENSATION FAILED] {s.name}: {comp_err}")
                return {"success": False, "failed_at": step.name}
        return {"success": True, "saga_id": self.saga_id}

# Simulate an order placement saga
import random

def reserve_inventory(ctx):
    ctx["inventory_reserved"] = True

def charge_payment(ctx):
    if random.random() < 0.5:   # Simulate payment failure
        raise ValueError("Payment declined")
    ctx["payment_charged"] = True

def send_confirmation(ctx):
    ctx["email_sent"] = True

def release_inventory(ctx):
    ctx.pop("inventory_reserved", None)

def refund_payment(ctx):
    ctx.pop("payment_charged", None)

saga = SagaOrchestrator([
    SagaStep("Reserve Inventory", reserve_inventory, release_inventory),
    SagaStep("Charge Payment",    charge_payment,    refund_payment),
    SagaStep("Send Confirmation", send_confirmation, lambda ctx: None),
])

random.seed(42)
result = saga.run({})
print(f"\nResult: {result}")</cell id="cell-6">
