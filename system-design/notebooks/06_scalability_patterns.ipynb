<cell id="cell-0"><cell_type>markdown</cell_type># Scalability Patterns

Consistent hashing ring, LRU cache, and load balancer simulator.</cell id="cell-0">
<cell id="cell-1"><cell_type>markdown</cell_type>## 1. Consistent Hashing Ring</cell id="cell-1">
<cell id="cell-2">import hashlib, bisect

class ConsistentHashRing:
    def __init__(self, vnodes: int = 150):
        self.vnodes = vnodes
        self._ring: dict[int, str] = {}
        self._sorted: list[int] = []
        self._nodes: set[str] = set()

    def _h(self, s: str) -> int:
        return int(hashlib.md5(s.encode()).hexdigest(), 16)

    def add(self, node: str) -> None:
        self._nodes.add(node)
        for i in range(self.vnodes):
            k = self._h(f"{node}#{i}")
            self._ring[k] = node
            bisect.insort(self._sorted, k)

    def remove(self, node: str) -> None:
        self._nodes.discard(node)
        for i in range(self.vnodes):
            k = self._h(f"{node}#{i}")
            self._ring.pop(k, None)
            if k in self._sorted:
                self._sorted.remove(k)

    def get(self, key: str) -> str:
        h = self._h(key)
        idx = bisect.bisect_right(self._sorted, h) % len(self._sorted)
        return self._ring[self._sorted[idx]]

    def distribution(self, keys: list[str]) -> dict[str, int]:
        d: dict = {n: 0 for n in self._nodes}
        for k in keys:
            d[self.get(k)] += 1
        return d

ring = ConsistentHashRing(vnodes=150)
for n in ["node-1", "node-2", "node-3"]:
    ring.add(n)

keys = [f"key:{i}" for i in range(1200)]
dist_3 = ring.distribution(keys)
assignment_3 = {k: ring.get(k) for k in keys}

print("Distribution — 3 nodes:")
for n, c in sorted(dist_3.items()):
    print(f"  {n}: {c} keys ({c/12:.1f}%)")

ring.add("node-4")
dist_4 = ring.distribution(keys)
remapped = sum(1 for k in keys if ring.get(k) != assignment_3[k])
print(f"\nDistribution — 4 nodes (added node-4):")
for n, c in sorted(dist_4.items()):
    print(f"  {n}: {c} keys ({c/12:.1f}%)")
print(f"\nRemapped: {remapped}/{len(keys)} ({remapped/len(keys):.0%}) — ideal is ~25%")</cell id="cell-2">
<cell id="cell-3"><cell_type>markdown</cell_type>## 2. LRU Cache with TTL</cell id="cell-3">
<cell id="cell-4">import time
from collections import OrderedDict
from typing import Any, Optional

class LRUCache:
    """LRU cache with TTL — for caching LLM responses or embeddings."""

    def __init__(self, capacity: int, ttl: float = float("inf")):
        self.capacity = capacity
        self.ttl = ttl
        self._cache: OrderedDict = OrderedDict()   # key → (value, timestamp)
        self.hits = 0
        self.misses = 0

    def get(self, key: str) -> Optional[Any]:
        if key not in self._cache:
            self.misses += 1
            return None
        value, ts = self._cache[key]
        if time.time() - ts > self.ttl:
            del self._cache[key]
            self.misses += 1
            return None
        self._cache.move_to_end(key)
        self.hits += 1
        return value

    def put(self, key: str, value: Any) -> None:
        if key in self._cache:
            self._cache.move_to_end(key)
        self._cache[key] = (value, time.time())
        if len(self._cache) > self.capacity:
            evicted_key = next(iter(self._cache))
            del self._cache[evicted_key]

    @property
    def hit_rate(self) -> float:
        total = self.hits + self.misses
        return self.hits / total if total else 0.0

import random
random.seed(42)
cache = LRUCache(capacity=50, ttl=3600)
query_pool = [f"q{i}" for i in range(30)]

for _ in range(300):
    q = random.choice(query_pool)
    if cache.get(q) is None:
        cache.put(q, f"LLM answer for {q}")

print(f"LRU Cache stats (capacity=50, 300 requests, 30 unique queries):")
print(f"  Hits:      {cache.hits}")
print(f"  Misses:    {cache.misses}")
print(f"  Hit rate:  {cache.hit_rate:.1%}")
print(f"  Cached:    {len(cache._cache)} entries")
print(f"  LLM calls saved: {cache.hits} / {cache.hits + cache.misses}")</cell id="cell-4">
<cell id="cell-5"><cell_type>markdown</cell_type>## 3. Load Balancer Algorithms Comparison</cell id="cell-5">
<cell id="cell-6">import random, time
from dataclasses import dataclass, field

@dataclass
class Server:
    id: str
    weight: float = 1.0
    connections: int = 0
    requests: int = 0
    total_ms: float = 0.0

    @property
    def avg_latency(self):
        return self.total_ms / self.requests if self.requests else 0

class LoadBalancer:
    def __init__(self, servers: list[Server]):
        self.servers = servers
        self._rr = 0

    def round_robin(self) -> Server:
        s = self.servers[self._rr % len(self.servers)]
        self._rr += 1
        return s

    def least_connections(self) -> Server:
        return min(self.servers, key=lambda s: s.connections)

    def weighted_rr(self) -> Server:
        total = sum(s.weight for s in self.servers)
        r = random.uniform(0, total)
        cum = 0
        for s in self.servers:
            cum += s.weight
            if r <= cum:
                return s
        return self.servers[-1]

    def dispatch(self, algo: str) -> Server:
        s = getattr(self, algo)()
        duration = random.uniform(20, 200) / s.weight   # heavier servers faster
        s.connections += 1
        s.requests += 1
        s.total_ms += duration
        s.connections -= 1
        return s

servers = [Server("s1", weight=2.0), Server("s2", weight=1.0), Server("s3", weight=1.0)]

for algo in ["round_robin", "least_connections", "weighted_rr"]:
    for s in servers:
        s.requests = 0; s.total_ms = 0.0
    lb = LoadBalancer(servers)
    random.seed(0)
    for _ in range(300):
        lb.dispatch(algo)
    print(f"Algorithm: {algo}")
    for s in servers:
        print(f"  {s.id} (w={s.weight}): {s.requests} req, avg={s.avg_latency:.1f}ms")
    print()</cell id="cell-6">
