<cell id="cell-0"><cell_type>markdown</cell_type># Message Queues

Implementing a queue with DLQ, Kafka-style consumer groups, and backpressure.</cell id="cell-0">
<cell id="cell-1"><cell_type>markdown</cell_type>## 1. Queue with Dead Letter Queue</cell id="cell-1">
<cell id="cell-2">import uuid, time, random
from dataclasses import dataclass, field
from collections import deque
from typing import Callable, Optional

@dataclass
class Message:
    id: str
    payload: dict
    attempt: int = 0
    error: Optional[str] = None

class Queue:
    """In-memory queue with retry logic and DLQ."""

    def __init__(self, name: str, max_retries: int = 3):
        self.name = name
        self.max_retries = max_retries
        self._q: deque = deque()
        self._dlq: list[Message] = []
        self.processed = 0
        self.failed = 0

    def publish(self, payload: dict) -> str:
        msg = Message(id=str(uuid.uuid4())[:8], payload=payload)
        self._q.append(msg)
        return msg.id

    def consume(self, handler: Callable[[Message], None]) -> Optional[Message]:
        if not self._q:
            return None
        msg = self._q.popleft()
        msg.attempt += 1
        try:
            handler(msg)
            self.processed += 1
            return msg
        except Exception as e:
            msg.error = str(e)
            if msg.attempt >= self.max_retries:
                self._dlq.append(msg)
                self.failed += 1
                print(f"  [DLQ] {msg.id} → DLQ after {msg.attempt} attempts ({e})")
            else:
                self._q.appendleft(msg)   # retry
                print(f"  [RETRY {msg.attempt}/{self.max_retries}] {msg.id}: {e}")
            return None

    @property
    def stats(self):
        return {"queued": len(self._q), "processed": self.processed,
                "failed": self.failed, "dlq": len(self._dlq)}

queue = Queue("ml-inference", max_retries=3)
for i in range(6):
    queue.publish({"image_id": i, "model": "classifier"})

def flaky_handler(msg: Message):
    if random.random() < 0.4:
        raise RuntimeError("GPU OOM")
    # success — no return needed

random.seed(42)
print("Processing messages:")
while queue._q:
    queue.consume(flaky_handler)
print(f"\nFinal stats: {queue.stats}")</cell id="cell-2">
<cell id="cell-3"><cell_type>markdown</cell_type>## 2. Kafka-style Consumer Groups</cell id="cell-3">
<cell id="cell-4">from dataclasses import dataclass, field

@dataclass
class Partition:
    id: int
    messages: list = field(default_factory=list)
    committed_offset: int = 0

class Topic:
    """Simplified Kafka topic."""

    def __init__(self, name: str, num_partitions: int = 3):
        self.name = name
        self.partitions = [Partition(id=i) for i in range(num_partitions)]

    def produce(self, key: str, value: dict) -> None:
        p = hash(key) % len(self.partitions)
        self.partitions[p].messages.append({"key": key, "value": value,
                                             "offset": len(self.partitions[p].messages)})

    def assign(self, consumers: list[str]) -> dict[str, list[int]]:
        """Round-robin partition assignment."""
        assignment: dict = {c: [] for c in consumers}
        for i, _ in enumerate(self.partitions):
            assignment[consumers[i % len(consumers)]].append(i)
        return assignment

    def poll(self, partition_id: int, batch: int = 3) -> list[dict]:
        p = self.partitions[partition_id]
        msgs = p.messages[p.committed_offset : p.committed_offset + batch]
        p.committed_offset += len(msgs)
        return msgs

topic = Topic("user-events", num_partitions=3)
for user, event in [("u1","login"),("u2","purchase"),("u1","view"),("u3","signup"),("u2","checkout")]:
    topic.produce(user, {"user": user, "event": event})

print("Partition sizes:", {f"p{p.id}": len(p.messages) for p in topic.partitions})

consumers = ["worker-A", "worker-B"]
assignment = topic.assign(consumers)
print(f"Assignment: {assignment}\n")

print("Consuming:")
for consumer, partitions in assignment.items():
    for pid in partitions:
        for msg in topic.poll(pid):
            print(f"  [{consumer}] p{pid}@{msg['offset']}: {msg['value']}")</cell id="cell-4">
<cell id="cell-5"><cell_type>markdown</cell_type>## 3. Backpressure Queue</cell id="cell-5">
<cell id="cell-6">from collections import deque

class BackpressureQueue:
    """Queue that signals producers to slow down when near capacity."""

    def __init__(self, capacity: int = 10, high_watermark: float = 0.7):
        self._q: deque = deque()
        self.capacity = capacity
        self.high_watermark = high_watermark
        self.accepted = 0
        self.dropped = 0

    @property
    def utilization(self) -> float:
        return len(self._q) / self.capacity

    def publish(self, item) -> dict:
        if len(self._q) >= self.capacity:
            self.dropped += 1
            return {"accepted": False, "reason": "full", "utilization": 1.0}
        self._q.append(item)
        self.accepted += 1
        delay = max(0.0, (self.utilization - self.high_watermark) * 0.2)
        return {"accepted": True, "utilization": round(self.utilization, 2),
                "suggested_delay_s": round(delay, 3)}

    def consume(self):
        return self._q.popleft() if self._q else None

bq = BackpressureQueue(capacity=8, high_watermark=0.6)
print(f"{'#':>3} {'Util':>6} {'Delay':>7} {'Status'}")
print("-" * 32)
for i in range(15):
    result = bq.publish({"id": i})
    status = "OK" if result["accepted"] else "DROPPED"
    util = result["utilization"]
    delay = result.get("suggested_delay_s", 0)
    print(f"{i:>3} {util:>6.0%} {delay:>7.3f}  {status}")

print(f"\nAccepted: {bq.accepted}, Dropped: {bq.dropped}")</cell id="cell-6">
