<cell id="cell-0"><cell_type>markdown</cell_type># ML System Design

Feature store, model registry, shadow deployment, and drift detection.</cell id="cell-0">
<cell id="cell-1"><cell_type>markdown</cell_type>## 1. Feature Store with Point-in-Time Retrieval</cell id="cell-1">
<cell id="cell-2">import time
from dataclasses import dataclass, field
from typing import Any, Optional

@dataclass
class FeatureStore:
    """Point-in-time correct feature store."""
    _store: dict = field(default_factory=dict)   # entity → feature → [(ts, val)]

    def write(self, entity_id: str, feature: str, value: Any, ts: float = None) -> None:
        ts = ts or time.time()
        self._store.setdefault(entity_id, {}).setdefault(feature, []).append((ts, value))
        self._store[entity_id][feature].sort()

    def read(self, entity_id: str, feature: str, as_of: float = None) -> Optional[Any]:
        history = self._store.get(entity_id, {}).get(feature, [])
        if not history:
            return None
        if as_of is None:
            return history[-1][1]
        result = None
        for ts, val in history:
            if ts <= as_of:
                result = val
        return result

    def get_vector(self, entity_id: str, features: list[str], as_of: float = None) -> dict:
        return {f: self.read(entity_id, f, as_of) for f in features}

fs = FeatureStore()
now = time.time()
# Simulate feature history for a user
fs.write("u1", "purchase_30d", 3,  ts=now - 600)
fs.write("u1", "purchase_30d", 7,  ts=now - 60)    # Most recent
fs.write("u1", "avg_spend",    45.0, ts=now - 600)
fs.write("u1", "avg_spend",    62.5, ts=now - 60)
fs.write("u1", "days_since_login", 2.0, ts=now)

print("Current features for u1:")
v = fs.get_vector("u1", ["purchase_30d", "avg_spend", "days_since_login"])
for k, val in v.items():
    print(f"  {k}: {val}")

print("\nHistorical features (as_of = 5 mins ago):")
v_hist = fs.get_vector("u1", ["purchase_30d", "avg_spend"], as_of=now - 300)
for k, val in v_hist.items():
    print(f"  {k}: {val}")</cell id="cell-2">
<cell id="cell-3"><cell_type>markdown</cell_type>## 2. Model Registry with Lifecycle Management</cell id="cell-3">
<cell id="cell-4">import uuid
from dataclasses import dataclass, field
from datetime import datetime
from typing import Optional

@dataclass
class ModelVersion:
    name: str
    version: str
    stage: str           # staging | production | archived
    metrics: dict
    run_id: str = field(default_factory=lambda: str(uuid.uuid4())[:8])
    created: str = field(default_factory=lambda: datetime.now().strftime("%Y-%m-%d %H:%M"))

class ModelRegistry:
    def __init__(self):
        self._versions: dict[str, list[ModelVersion]] = {}

    def register(self, name: str, version: str, metrics: dict) -> ModelVersion:
        mv = ModelVersion(name=name, version=version, stage="staging", metrics=metrics)
        self._versions.setdefault(name, []).append(mv)
        print(f"Registered {name}@{version} (run={mv.run_id})")
        return mv

    def transition(self, name: str, version: str, to_stage: str) -> None:
        for mv in self._versions.get(name, []):
            if mv.version == version:
                if to_stage == "production":
                    for other in self._versions.get(name, []):
                        if other.stage == "production":
                            other.stage = "archived"
                            print(f"  Archived {name}@{other.version}")
                mv.stage = to_stage
                print(f"  {name}@{version} → {to_stage}")
                return
        raise ValueError(f"Not found: {name}@{version}")

    def get_production(self, name: str) -> Optional[ModelVersion]:
        return next((mv for mv in reversed(self._versions.get(name, [])) if mv.stage == "production"), None)

    def show(self, name: str) -> None:
        print(f"\n{'Version':>9} {'Stage':>12} {'F1':>6} {'Latency':>9}  Created")
        print("  " + "-" * 55)
        for mv in self._versions.get(name, []):
            f1 = mv.metrics.get("f1", "—")
            lat = mv.metrics.get("latency_ms", "—")
            print(f"  {mv.version:>9} {mv.stage:>12} {str(f1):>6} {str(lat):>9}  {mv.created}")

registry = ModelRegistry()
registry.register("churn-predictor", "1.0.0", {"f1": 0.81, "latency_ms": 42})
registry.register("churn-predictor", "1.1.0", {"f1": 0.86, "latency_ms": 45})
registry.transition("churn-predictor", "1.0.0", "production")
registry.transition("churn-predictor", "1.1.0", "production")
registry.show("churn-predictor")
prod = registry.get_production("churn-predictor")
print(f"\nCurrent production: {prod.version} (F1={prod.metrics['f1']})")</cell id="cell-4">
<cell id="cell-5"><cell_type>markdown</cell_type>## 3. Data Drift Detector (PSI)</cell id="cell-5">
<cell id="cell-6">import math

def psi(baseline: list[float], current: list[float], bins: int = 10) -> float:
    """
    Population Stability Index.
    PSI < 0.1: No shift. 0.1-0.2: Minor. > 0.2: Major shift — investigate.
    """
    min_val = min(min(baseline), min(current))
    max_val = max(max(baseline), max(current))
    edges = [min_val + i * (max_val - min_val) / bins for i in range(bins + 1)]

    def freq(data, edges):
        counts = [0] * bins
        for v in data:
            for i in range(bins):
                if edges[i] <= v < edges[i + 1] or (i == bins - 1 and v == edges[-1]):
                    counts[i] += 1
                    break
        n = len(data)
        return [max(c / n, 1e-6) for c in counts]   # Avoid log(0)

    base_freq = freq(baseline, edges)
    curr_freq = freq(current, edges)

    return sum((c - b) * math.log(c / b) for b, c in zip(base_freq, curr_freq))

import random
random.seed(42)

# Baseline: normal distribution of user ages centered at 35
baseline_ages = [random.gauss(35, 8) for _ in range(1000)]

# Scenario 1: slight shift
slight_shift = [random.gauss(37, 8) for _ in range(1000)]

# Scenario 2: major shift (new customer segment)
major_shift = [random.gauss(52, 10) for _ in range(1000)]

print("Population Stability Index (PSI) for 'user_age' feature:")
for label, sample in [("No shift (same dist)", baseline_ages[:500] + [random.gauss(35,8) for _ in range(500)]),
                       ("Slight shift (μ=37)",  slight_shift),
                       ("Major shift (μ=52)",   major_shift)]:
    score = psi(baseline_ages, sample)
    flag = "OK" if score < 0.1 else ("WARN" if score < 0.2 else "ALERT — retrain!")
    print(f"  {label:<32} PSI={score:.4f}  [{flag}]")</cell id="cell-6">
