<cell id="cell-0"><cell_type>markdown</cell_type># API Design

Building versioned REST APIs, cursor pagination, and a token bucket rate limiter.</cell id="cell-0">
<cell id="cell-1"><cell_type>markdown</cell_type>## 1. Versioned API Router</cell id="cell-1">
<cell id="cell-2">from dataclasses import dataclass, field
from typing import Any, Callable
import json

@dataclass
class Request:
    method: str
    path: str
    body: dict = field(default_factory=dict)
    query: dict = field(default_factory=dict)

@dataclass
class Response:
    status: int
    body: Any

class APIRouter:
    """Versioned REST router."""

    def __init__(self):
        self._routes: dict = {}   # version → method → path → handler

    def route(self, method: str, path: str, version: str = "v1"):
        def decorator(func: Callable) -> Callable:
            self._routes.setdefault(version, {}).setdefault(method.upper(), {})[path] = func
            return func
        return decorator

    def handle(self, request: Request, version: str = "v1") -> Response:
        routes = self._routes.get(version, {}).get(request.method.upper(), {})
        handler = routes.get(request.path)
        if not handler:
            return Response(404, {"error": f"Not found: {request.method} {request.path} ({version})"})
        try:
            return handler(request)
        except Exception as e:
            return Response(500, {"error": str(e)})

api = APIRouter()
USERS = {
    1: {"id": 1, "name": "Alice"},
    2: {"id": 2, "name": "Bob"},
}

@api.route("GET", "/users", version="v1")
def list_users_v1(req):
    return Response(200, {"users": list(USERS.values()), "count": len(USERS)})

@api.route("GET", "/users", version="v2")
def list_users_v2(req):
    data = [{"id": u["id"], "name": u["name"], "email": f"{u['name'].lower()}@example.com"} for u in USERS.values()]
    return Response(200, {"data": data, "meta": {"total": len(data), "api_version": "v2"}})

@api.route("POST", "/users", version="v1")
def create_user_v1(req):
    new_id = max(USERS) + 1
    USERS[new_id] = {"id": new_id, **req.body}
    return Response(201, USERS[new_id])

for version in ["v1", "v2"]:
    req = Request("GET", "/users")
    resp = api.handle(req, version=version)
    print(f"GET /users ({version}) → {resp.status}")
    print(f"  {json.dumps(resp.body)[:100]}")
print()
# POST
req = Request("POST", "/users", body={"name": "Carol"})
resp = api.handle(req, "v1")
print(f"POST /users → {resp.status}: {resp.body}")</cell id="cell-2">
<cell id="cell-3"><cell_type>markdown</cell_type>## 2. Cursor Pagination</cell id="cell-3">
<cell id="cell-4">import base64, json
from typing import Optional

def encode_cursor(data: dict) -> str:
    return base64.b64encode(json.dumps(data).encode()).decode()

def decode_cursor(cursor: str) -> dict:
    return json.loads(base64.b64decode(cursor.encode()).decode())

class CursorPaginator:
    """Stable cursor-based pagination."""

    def __init__(self, items: list, sort_key: str = "id"):
        self.items = sorted(items, key=lambda x: x[sort_key])
        self.sort_key = sort_key

    def paginate(self, after: Optional[str] = None, limit: int = 5) -> dict:
        start = 0
        if after:
            after_val = decode_cursor(after)[self.sort_key]
            for i, item in enumerate(self.items):
                if item[self.sort_key] > after_val:
                    start = i
                    break
            else:
                start = len(self.items)

        page = self.items[start : start + limit]
        has_more = start + limit < len(self.items)
        next_cursor = encode_cursor({self.sort_key: page[-1][self.sort_key]}) if has_more and page else None
        return {"data": page, "next_cursor": next_cursor, "has_more": has_more, "count": len(page)}

all_items = [{"id": i, "title": f"Post {i}"} for i in range(1, 22)]
paginator = CursorPaginator(all_items)

cursor = None
for page_num in range(1, 6):
    result = paginator.paginate(after=cursor, limit=5)
    ids = [x["id"] for x in result["data"]]
    print(f"Page {page_num}: ids={ids}, has_more={result['has_more']}")
    cursor = result["next_cursor"]
    if not result["has_more"]:
        print(f"  Reached end.")
        break</cell id="cell-4">
<cell id="cell-5"><cell_type>markdown</cell_type>## 3. Token Bucket Rate Limiter</cell id="cell-5">
<cell id="cell-6">import time
from dataclasses import dataclass, field

@dataclass
class TokenBucket:
    capacity: float
    refill_rate: float      # tokens/second
    _tokens: float = field(init=False)
    _last: float = field(init=False)

    def __post_init__(self):
        self._tokens = self.capacity
        self._last = time.time()

    def consume(self, cost: float = 1.0) -> tuple[bool, dict]:
        now = time.time()
        self._tokens = min(self.capacity, self._tokens + (now - self._last) * self.refill_rate)
        self._last = now
        if self._tokens >= cost:
            self._tokens -= cost
            return True, {"allowed": True, "remaining": round(self._tokens, 2)}
        retry_after = round((cost - self._tokens) / self.refill_rate, 2)
        return False, {"allowed": False, "remaining": round(self._tokens, 2), "retry_after_s": retry_after}

class RateLimiter:
    def __init__(self, rpm: int = 60, burst: int = 10):
        self._buckets: dict[str, TokenBucket] = {}
        self.rps = rpm / 60
        self.burst = burst

    def check(self, user_id: str) -> tuple[bool, dict]:
        if user_id not in self._buckets:
            self._buckets[user_id] = TokenBucket(capacity=self.burst, refill_rate=self.rps)
        return self._buckets[user_id].consume()

limiter = RateLimiter(rpm=12, burst=5)   # 12 req/min, burst of 5
print("Rapid-fire 10 requests from user_001:")
for i in range(10):
    allowed, info = limiter.check("user_001")
    status = "OK    " if allowed else "LIMIT "
    print(f"  #{i+1} [{status}] remaining={info['remaining']:.1f}", end="")
    if not allowed:
        print(f"  retry_after={info['retry_after_s']}s", end="")
    print()</cell id="cell-6">
