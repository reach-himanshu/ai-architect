<cell id="cell-0"><cell_type>markdown</cell_type># Database Selection

Decision frameworks, connection pool simulator, and sharding analysis.</cell id="cell-0">
<cell id="cell-1"><cell_type>markdown</cell_type>## 1. Database Selection Decision Engine</cell id="cell-1">
<cell id="cell-2">from dataclasses import dataclass

@dataclass
class DBRequirements:
    access_pattern: str   # point_lookup, range, full_text, graph, vector, analytics, write_heavy
    need_transactions: bool
    schema_flexible: bool
    consistency: str      # strong, eventual
    scale: str            # small, medium, large, massive
    existing_stack: str = ""

def recommend_db(req: DBRequirements) -> dict:
    pattern = req.access_pattern

    if pattern == "vector":
        return {"primary": "Qdrant or Pinecone",
                "alternative": "pgvector (if already on PostgreSQL)",
                "reason": "Purpose-built ANN indexes (HNSW) required"}

    if pattern == "full_text":
        return {"primary": "Elasticsearch / OpenSearch",
                "alternative": "PostgreSQL GIN (small scale)",
                "reason": "Inverted index for full-text, facets, aggregations"}

    if pattern == "graph":
        return {"primary": "Neo4j or Amazon Neptune",
                "alternative": "PostgreSQL recursive CTEs (simple graphs)",
                "reason": "Native graph traversal; SQL is O(n) for deep traversals"}

    if pattern == "analytics":
        return {"primary": "BigQuery / Snowflake / Redshift",
                "alternative": "ClickHouse (self-hosted), DuckDB (embedded)",
                "reason": "Columnar storage — 10-100x faster than row-oriented for scans"}

    if pattern == "write_heavy" and req.scale in ("large", "massive") and req.consistency == "eventual":
        return {"primary": "Cassandra",
                "alternative": "DynamoDB (managed)",
                "reason": "LSM-tree storage optimized for high write throughput"}

    if pattern == "point_lookup" and not req.need_transactions:
        return {"primary": "Redis (cache) + DynamoDB (durable store)",
                "alternative": "DynamoDB alone",
                "reason": "Sub-millisecond key-value lookup"}

    if req.need_transactions and req.consistency == "strong":
        alt = "CockroachDB" if req.scale == "massive" else "MySQL"
        return {"primary": "PostgreSQL",
                "alternative": alt,
                "reason": "Best-in-class ACID, rich indexing, JSONB for flexibility"}

    if req.schema_flexible:
        return {"primary": "MongoDB",
                "alternative": "PostgreSQL + JSONB",
                "reason": "Document model for flexible, nested, evolving schemas"}

    return {"primary": "PostgreSQL",
            "alternative": "MySQL",
            "reason": "Excellent default; covers most use cases"}

scenarios = [
    ("RAG knowledge base",       DBRequirements("vector",    False, True,  "eventual",  "medium")),
    ("E-commerce orders",        DBRequirements("range",     True,  False, "strong",    "medium")),
    ("Log search",               DBRequirements("full_text", False, True,  "eventual",  "large")),
    ("Social graph",             DBRequirements("graph",     False, True,  "eventual",  "large")),
    ("IoT sensor data",          DBRequirements("write_heavy",False, False,"eventual",  "massive")),
    ("User session store",       DBRequirements("point_lookup",False,False,"eventual",  "large")),
    ("Analytics dashboard",      DBRequirements("analytics", False, False, "eventual",  "large")),
]

print(f"{'Scenario':<28} {'Recommendation':<30} {'Reason'}")
print("-" * 90)
for name, req in scenarios:
    rec = recommend_db(req)
    print(f"{name:<28} {rec['primary']:<30} {rec['reason'][:40]}")</cell id="cell-2">
<cell id="cell-3"><cell_type>markdown</cell_type>## 2. Connection Pool Simulator</cell id="cell-3">
<cell id="cell-4">import time, random
from dataclasses import dataclass, field
from collections import deque

@dataclass
class ConnPool:
    min_size: int = 5
    max_size: int = 20
    _available: deque = field(default_factory=deque)
    _in_use: int = 0
    _wait_count: int = 0
    _rejected: int = 0

    def __post_init__(self):
        self._available = deque(range(self.min_size))

    @property
    def total(self):
        return len(self._available) + self._in_use

    def acquire(self) -> dict:
        if self._available:
            cid = self._available.popleft()
            self._in_use += 1
            return {"conn_id": cid, "status": "reused"}
        if self.total < self.max_size:
            cid = self.total
            self._in_use += 1
            return {"conn_id": cid, "status": "new"}
        self._rejected += 1
        return {"conn_id": None, "status": "rejected", "utilization": self._in_use / self.max_size}

    def release(self, conn_id: int):
        self._in_use = max(0, self._in_use - 1)
        if len(self._available) < self.min_size:
            self._available.append(conn_id)

pool = ConnPool(min_size=3, max_size=6)
active = []
random.seed(42)

print(f"{'Op':<9} {'ConnID':>7} {'Total':>6} {'InUse':>6} {'Status'}")
print("-" * 40)
for _ in range(16):
    if random.random() < 0.65 or not active:
        res = pool.acquire()
        if res["conn_id"] is not None:
            active.append(res["conn_id"])
        print(f"{'ACQUIRE':<9} {str(res['conn_id']):>7} {pool.total:>6} {pool._in_use:>6}  {res['status']}")
    elif active:
        cid = active.pop(0)
        pool.release(cid)
        print(f"{'RELEASE':<9} {cid:>7} {pool.total:>6} {pool._in_use:>6}")

print(f"\nRejected: {pool._rejected}")</cell id="cell-4">
<cell id="cell-5"><cell_type>markdown</cell_type>## 3. Consistent Hashing for Sharding</cell id="cell-5">
<cell id="cell-6">import hashlib, bisect

class HashRing:
    """Consistent hash ring — minimal key remapping when nodes change."""

    def __init__(self, vnodes: int = 100):
        self.vnodes = vnodes
        self._ring: dict[int, str] = {}
        self._keys: list[int] = []
        self._nodes: set[str] = set()

    def _h(self, s: str) -> int:
        return int(hashlib.md5(s.encode()).hexdigest(), 16)

    def add(self, node: str):
        self._nodes.add(node)
        for i in range(self.vnodes):
            k = self._h(f"{node}#{i}")
            self._ring[k] = node
            bisect.insort(self._keys, k)

    def remove(self, node: str):
        self._nodes.discard(node)
        for i in range(self.vnodes):
            k = self._h(f"{node}#{i}")
            self._ring.pop(k, None)
            if k in self._keys:
                self._keys.remove(k)

    def get(self, key: str) -> str:
        if not self._ring:
            raise ValueError("Empty ring")
        h = self._h(key)
        idx = bisect.bisect_right(self._keys, h) % len(self._keys)
        return self._ring[self._keys[idx]]

    def distribution(self, keys: list[str]) -> dict[str, int]:
        counts: dict = {n: 0 for n in self._nodes}
        for k in keys:
            counts[self.get(k)] += 1
        return counts

ring = HashRing(vnodes=150)
for n in ["shard-1", "shard-2", "shard-3"]:
    ring.add(n)

test_keys = [f"user:{i}" for i in range(900)]
dist3 = ring.distribution(test_keys)
print("Distribution — 3 shards:")
for s, c in sorted(dist3.items()):
    print(f"  {s}: {c} keys ({c/9:.1f}%)")

ring.add("shard-4")
dist4 = ring.distribution(test_keys)
remapped = sum(1 for k in test_keys if ring.get(k) != [n for n, c in dist3.items() if c > 0][0])
print(f"\nDistribution — 4 shards (added shard-4):")
for s, c in sorted(dist4.items()):
    print(f"  {s}: {c} keys ({c/9:.1f}%)")
print(f"\nOnly ~25% of keys remapped (consistent hashing minimizes movement)")</cell id="cell-6">
