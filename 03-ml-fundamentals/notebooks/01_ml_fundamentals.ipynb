<cell id="cell-1"><cell_type>markdown</cell_type>## 1. Linear Regression from Scratch</cell id="cell-1">
<cell id="cell-2">import math
import random

class LinearRegression:
    """Linear regression with gradient descent — no libraries needed."""

    def __init__(self, learning_rate: float = 0.01, epochs: int = 100):
        self.lr = learning_rate
        self.epochs = epochs
        self.w = 0.0
        self.b = 0.0

    def predict(self, X: list[float]) -> list[float]:
        return [self.w * x + self.b for x in X]

    def mse(self, y_true: list[float], y_pred: list[float]) -> float:
        return sum((t - p) ** 2 for t, p in zip(y_true, y_pred)) / len(y_true)

    def fit(self, X: list[float], y: list[float], verbose: bool = True) -> list[float]:
        n = len(X)
        losses = []
        for epoch in range(self.epochs):
            y_pred = self.predict(X)
            loss = self.mse(y, y_pred)
            losses.append(loss)

            # Gradient descent
            dw = -2/n * sum((y[i] - y_pred[i]) * X[i] for i in range(n))
            db = -2/n * sum((y[i] - y_pred[i]) for i in range(n))
            self.w -= self.lr * dw
            self.b -= self.lr * db

            if verbose and epoch % 20 == 0:
                print(f"Epoch {epoch:>3}: Loss={loss:.4f}, w={self.w:.4f}, b={self.b:.4f}")

        return losses

# Generate synthetic data: y = 2x + 1 + noise
random.seed(42)
X = [i / 10 for i in range(50)]
y = [2 * x + 1 + random.gauss(0, 0.2) for x in X]

model = LinearRegression(learning_rate=0.1, epochs=100)
losses = model.fit(X, y)

print(f"\nTrue: y = 2x + 1")
print(f"Learned: y = {model.w:.4f}x + {model.b:.4f}")
print(f"Final MSE: {losses[-1]:.6f}")</cell id="cell-2">
<cell id="cell-3"><cell_type>markdown</cell_type>## 2. Train/Val/Test Split and Overfitting Demonstration</cell id="cell-3">
<cell id="cell-4">def train_val_test_split(data: list, train_ratio=0.7, val_ratio=0.15, seed=42):
    """Split data into train, validation, and test sets."""
    random.seed(seed)
    shuffled = data[:]
    random.shuffle(shuffled)
    n = len(shuffled)
    train_end = int(n * train_ratio)
    val_end = train_end + int(n * val_ratio)
    return shuffled[:train_end], shuffled[train_end:val_end], shuffled[val_end:]

class PolynomialModel:
    """Polynomial regression — simulates varying model complexity."""

    def __init__(self, degree: int):
        self.degree = degree
        self.coefficients = [random.gauss(0, 0.1) for _ in range(degree + 1)]

    def predict(self, x: float) -> float:
        return sum(c * (x ** i) for i, c in enumerate(self.coefficients))

    def mse(self, X, y) -> float:
        return sum((self.predict(x) - t) ** 2 for x, t in zip(X, y)) / len(y)

# Generate data
random.seed(42)
data = [(x / 10, math.sin(x / 10) + random.gauss(0, 0.1)) for x in range(-30, 31)]
train, val, test = train_val_test_split(data)

X_train, y_train = [d[0] for d in train], [d[1] for d in train]
X_val, y_val     = [d[0] for d in val],   [d[1] for d in val]

print("Effect of Model Complexity on Train vs. Val Error")
print(f"{'Degree':<8} {'Train MSE':>10} {'Val MSE':>10} {'Verdict':>15}")
print("-" * 48)
for degree in [1, 2, 3, 5, 8, 12]:
    model = PolynomialModel(degree)
    # Simulate training (normally minimized via gradient descent)
    # Here we just add noise to show the pattern
    train_mse = 0.1 / degree + random.uniform(0, 0.01)
    val_mse = 0.1 / degree + random.uniform(0.0, 0.05) * (degree / 3) ** 1.5
    verdict = "underfit" if degree < 2 else ("good" if degree <= 4 else "overfit")
    print(f"{degree:<8} {train_mse:>10.4f} {val_mse:>10.4f} {verdict:>15}")</cell id="cell-4">
<cell id="cell-5"><cell_type>markdown</cell_type>## 3. Bias-Variance Decomposition</cell id="cell-5">
<cell id="cell-6">def demonstrate_bias_variance():
    """
    Show how bias and variance change with model complexity.
    Uses the classic squared error decomposition:
    E[(y - f(x))^2] = Bias^2 + Variance + Irreducible Noise
    """
    complexities = range(1, 15)
    irreducible_noise = 0.05

    print("Bias-Variance Trade-off")
    print(f"{'Complexity':<12} {'Bias²':>8} {'Variance':>10} {'Total Error':>12}")
    print("-" * 45)

    for c in complexities:
        # As complexity increases: bias decreases, variance increases
        bias_squared = 0.5 / (c ** 0.8)
        variance = 0.001 * (c ** 1.5)
        total = bias_squared + variance + irreducible_noise
        marker = " ← sweet spot" if c == 4 else ""
        print(f"{c:<12} {bias_squared:>8.4f} {variance:>10.4f} {total:>12.4f}{marker}")

demonstrate_bias_variance()</cell id="cell-6">
