<cell id="cell-5"><cell_type>markdown</cell_type>## 3. K-Fold Cross Validation</cell id="cell-5">
<cell id="cell-6">def k_fold_split(data: list, k: int = 5) -> list[tuple]:
    """Split data into k folds, return (train, val) index pairs."""
    n = len(data)
    fold_size = n // k
    folds = []
    for i in range(k):
        val_start = i * fold_size
        val_end = val_start + fold_size if i < k - 1 else n
        val_indices = list(range(val_start, val_end))
        train_indices = [j for j in range(n) if j not in set(val_indices)]
        folds.append((train_indices, val_indices))
    return folds

def simulate_model_score(train_size: int) -> float:
    """Simulate a model's accuracy given training set size (more data = better)."""
    base_accuracy = 0.75
    size_bonus = min(0.15, train_size / 10000)
    return base_accuracy + size_bonus + random.gauss(0, 0.02)

data = list(range(1000))
folds = k_fold_split(data, k=5)

scores = []
print("5-Fold Cross Validation:")
print(f"{'Fold':<6} {'Train Size':>11} {'Val Size':>9} {'Score':>8}")
print("-" * 38)
for i, (train_idx, val_idx) in enumerate(folds, 1):
    score = simulate_model_score(len(train_idx))
    scores.append(score)
    print(f"{i:<6} {len(train_idx):>11} {len(val_idx):>9} {score:>8.4f}")

mean = sum(scores) / len(scores)
std = math.sqrt(sum((s - mean)**2 for s in scores) / len(scores))
print(f"\nMean: {mean:.4f} ± {std:.4f}")
print(f"Single split might give any of: {min(scores):.4f} to {max(scores):.4f}")
print("Cross-validation gives a more reliable estimate.")</cell id="cell-6">
