<cell id="cell-0"><cell_type>markdown</cell_type># Fine-Tuning & Transfer Learning

Simulating LoRA, comparing fine-tuning approaches, and building a training data quality checker.</cell id="cell-0">
<cell id="cell-1"><cell_type>markdown</cell_type>## 1. LoRA Mathematics Simulation</cell id="cell-1">
<cell id="cell-2">import random
import math

def matrix_multiply(A: list[list[float]], B: list[list[float]]) -> list[list[float]]:
    rows_A, cols_A = len(A), len(A[0])
    rows_B, cols_B = len(B), len(B[0])
    assert cols_A == rows_B
    C = [[0.0] * cols_B for _ in range(rows_A)]
    for i in range(rows_A):
        for k in range(cols_A):
            for j in range(cols_B):
                C[i][j] += A[i][k] * B[k][j]
    return C

def matrix_add(A, B):
    return [[A[i][j] + B[i][j] for j in range(len(A[0]))] for i in range(len(A))]

def frobenius_norm(M: list[list[float]]) -> float:
    return math.sqrt(sum(v**2 for row in M for v in row))

def simulate_lora(d: int = 16, rank: int = 2) -> dict:
    """
    Simulate LoRA: W_new = W_original + A @ B
    Shows how few parameters LoRA uses.
    """
    random.seed(42)
    # Original frozen weight matrix (d x d)
    W_original = [[random.gauss(0, 0.1) for _ in range(d)] for _ in range(d)]

    # LoRA matrices (trainable)
    A = [[random.gauss(0, 0.01) for _ in range(rank)] for _ in range(d)]   # d x r
    B = [[random.gauss(0, 0.01) for _ in range(d)] for _ in range(rank)]   # r x d

    # LoRA update: delta_W = A @ B
    delta_W = matrix_multiply(A, B)  # d x d
    W_updated = matrix_add(W_original, delta_W)

    original_params = d * d
    lora_params = d * rank + rank * d  # A + B

    return {
        "d": d,
        "rank": rank,
        "original_params": original_params,
        "lora_params": lora_params,
        "param_reduction": original_params / lora_params,
        "delta_W_norm": frobenius_norm(delta_W),
    }

print("LoRA Parameter Efficiency")
print(f"{'d':>4} {'rank':>5} {'Full Params':>12} {'LoRA Params':>12} {'Reduction':>10} {'ΔW Norm':>10}")
print("-" * 60)
for d in [16, 64, 256, 1024]:
    for rank in [2, 8]:
        result = simulate_lora(d, rank)
        print(f"{d:>4} {rank:>5} {result['original_params']:>12,} {result['lora_params']:>12,} {result['param_reduction']:>10.1f}x {result['delta_W_norm']:>10.4f}")</cell id="cell-2">
<cell id="cell-3"><cell_type>markdown</cell_type>## 2. Fine-Tuning Decision Framework</cell id="cell-3">
<cell id="cell-4">from dataclasses import dataclass
from typing import Optional

@dataclass
class FinetuneDecision:
    approach: str
    reason: str
    estimated_cost: str
    data_needed: str
    time_to_implement: str

def decide_adaptation_strategy(
    dataset_size: int,
    update_frequency: str,  # "daily", "weekly", "static"
    need_citations: bool,
    latency_budget_ms: int,
    budget_usd: float,
    domain_specific: bool,
) -> FinetuneDecision:
    """Recommend an LLM adaptation strategy based on requirements."""

    # RAG is better for frequently updated data
    if update_frequency in ("daily", "weekly"):
        return FinetuneDecision(
            approach="RAG",
            reason="Frequent data updates make fine-tuning impractical (retraining cost)",
            estimated_cost="$50–500/month (vector DB + inference)",
            data_needed="Documents only, no labeling needed",
            time_to_implement="1–2 weeks",
        )

    if need_citations:
        return FinetuneDecision(
            approach="RAG",
            reason="Source citations require retrieval — fine-tuned models can't cite sources",
            estimated_cost="$50–500/month",
            data_needed="Documents only",
            time_to_implement="1–2 weeks",
        )

    if dataset_size < 500:
        return FinetuneDecision(
            approach="Prompt Engineering + Few-shot",
            reason=f"Only {dataset_size} examples — insufficient for fine-tuning",
            estimated_cost="Minimal (just inference)",
            data_needed="Examples already have",
            time_to_implement="1–3 days",
        )

    if latency_budget_ms < 200:
        return FinetuneDecision(
            approach="LoRA Fine-Tuning (small model)",
            reason="Tight latency budget — RAG adds retrieval overhead; fine-tuned small model is fastest",
            estimated_cost="$200–1000 training + $0.01/1M tokens inference",
            data_needed=f"{dataset_size} labeled examples (have) + quality review",
            time_to_implement="2–4 weeks",
        )

    if dataset_size >= 1000 and budget_usd > 500:
        if domain_specific:
            return FinetuneDecision(
                approach="QLoRA Fine-Tuning",
                reason="Large dataset + domain-specific needs + sufficient budget",
                estimated_cost="$100–500 training (GPU rental)",
                data_needed=f"{dataset_size} examples (have sufficient)",
                time_to_implement="2–6 weeks",
            )

    return FinetuneDecision(
        approach="RAG + Prompt Engineering",
        reason="Good default: low cost, fast iteration, handles most use cases",
        estimated_cost="$50–200/month",
        data_needed="Documents for knowledge base",
        time_to_implement="1–2 weeks",
    )

# Test different scenarios
scenarios = [
    {"dataset_size": 200, "update_frequency": "static", "need_citations": False, "latency_budget_ms": 2000, "budget_usd": 1000, "domain_specific": True},
    {"dataset_size": 5000, "update_frequency": "static", "need_citations": False, "latency_budget_ms": 100, "budget_usd": 500, "domain_specific": True},
    {"dataset_size": 10000, "update_frequency": "weekly", "need_citations": True, "latency_budget_ms": 1000, "budget_usd": 2000, "domain_specific": True},
    {"dataset_size": 2000, "update_frequency": "static", "need_citations": False, "latency_budget_ms": 500, "budget_usd": 200, "domain_specific": False},
]

for i, s in enumerate(scenarios, 1):
    decision = decide_adaptation_strategy(**s)
    print(f"Scenario {i}: {s['dataset_size']} examples, {s['update_frequency']} updates, latency={s['latency_budget_ms']}ms")
    print(f"  → Recommendation: {decision.approach}")
    print(f"  → Reason: {decision.reason}")
    print(f"  → Timeline: {decision.time_to_implement}")
    print()</cell id="cell-4">
<cell id="cell-5"><cell_type>markdown</cell_type>## 3. Training Data Quality Checker</cell id="cell-5">
<cell id="cell-6">from collections import Counter

@dataclass
class DataQualityReport:
    total_samples: int
    duplicate_rate: float
    avg_input_length: float
    avg_output_length: float
    label_distribution: dict
    issues: list[str]

    def print_report(self) -> None:
        print(f"Data Quality Report")
        print("=" * 45)
        print(f"  Total samples:      {self.total_samples}")
        print(f"  Duplicate rate:     {self.duplicate_rate:.1%}")
        print(f"  Avg input length:   {self.avg_input_length:.0f} chars")
        print(f"  Avg output length:  {self.avg_output_length:.0f} chars")
        print(f"  Label distribution: {self.label_distribution}")
        if self.issues:
            print(f"  Issues ({len(self.issues)}):")
            for issue in self.issues:
                print(f"    ⚠ {issue}")
        else:
            print("  No issues found!")

def check_finetune_data(samples: list[dict]) -> DataQualityReport:
    """
    Validate a fine-tuning dataset.
    Each sample: {"input": str, "output": str, "label": str}
    """
    issues = []

    # Check duplicates
    inputs = [s["input"] for s in samples]
    unique_inputs = len(set(inputs))
    dup_rate = 1 - unique_inputs / len(samples)
    if dup_rate > 0.05:
        issues.append(f"High duplicate rate: {dup_rate:.1%}")

    # Check lengths
    input_lengths = [len(s["input"]) for s in samples]
    output_lengths = [len(s["output"]) for s in samples]
    avg_in = sum(input_lengths) / len(input_lengths)
    avg_out = sum(output_lengths) / len(output_lengths)

    short_inputs = sum(1 for l in input_lengths if l < 10)
    if short_inputs > len(samples) * 0.05:
        issues.append(f"{short_inputs} samples with very short inputs (<10 chars)")

    empty_outputs = sum(1 for s in samples if not s["output"].strip())
    if empty_outputs:
        issues.append(f"{empty_outputs} samples with empty outputs")

    # Check label balance
    labels = [s.get("label", "none") for s in samples]
    label_counts = Counter(labels)
    if len(label_counts) > 1:
        max_count = max(label_counts.values())
        min_count = min(label_counts.values())
        if max_count / min_count > 5:
            issues.append(f"Label imbalance: {dict(label_counts)}")

    return DataQualityReport(
        total_samples=len(samples),
        duplicate_rate=dup_rate,
        avg_input_length=avg_in,
        avg_output_length=avg_out,
        label_distribution=dict(label_counts),
        issues=issues,
    )

# Test with a sample dataset
random.seed(42)
dataset = (
    [{"input": f"Classify this text: {i} sample review", "output": "positive", "label": "positive"} for i in range(60)]
    + [{"input": f"Classify: negative review {i}", "output": "negative", "label": "negative"} for i in range(10)]
    + [{"input": "short", "output": "positive", "label": "positive"}]  # Short input
    + [{"input": "Duplicate review text", "output": "positive", "label": "positive"} for _ in range(5)]  # Duplicates
)

report = check_finetune_data(dataset)
report.print_report()</cell id="cell-6">
