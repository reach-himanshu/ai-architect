<cell id="cell-0"><cell_type>markdown</cell_type># Feature Engineering

Preprocessing pipelines, encoding strategies, and missing data handling from scratch.</cell id="cell-0">
<cell id="cell-1"><cell_type>markdown</cell_type>## 1. Normalization and Standardization</cell id="cell-1">
<cell id="cell-2">import math
import random

class StandardScaler:
    """Z-score standardization: (x - mean) / std"""
    def __init__(self):
        self.mean = None
        self.std = None

    def fit(self, data: list[float]) -> "StandardScaler":
        self.mean = sum(data) / len(data)
        variance = sum((x - self.mean) ** 2 for x in data) / len(data)
        self.std = math.sqrt(variance) or 1.0  # Avoid division by zero
        return self

    def transform(self, data: list[float]) -> list[float]:
        return [(x - self.mean) / self.std for x in data]

    def fit_transform(self, data):
        return self.fit(data).transform(data)

class MinMaxScaler:
    """Min-Max normalization: (x - min) / (max - min)"""
    def __init__(self):
        self.min = None
        self.max = None

    def fit(self, data: list[float]) -> "MinMaxScaler":
        self.min = min(data)
        self.max = max(data)
        return self

    def transform(self, data: list[float]) -> list[float]:
        range_ = self.max - self.min or 1.0
        return [(x - self.min) / range_ for x in data]

    def fit_transform(self, data):
        return self.fit(data).transform(data)

# Example: ages with outlier
ages = [25, 30, 22, 45, 28, 35, 150, 31, 27, 33]  # 150 is an outlier

standard = StandardScaler().fit_transform(ages)
minmax = MinMaxScaler().fit_transform(ages)

print(f"{'Age':>6} {'Z-score':>10} {'MinMax':>8}")
print("-" * 28)
for age, z, mm in zip(ages, standard, minmax):
    flag = " ← outlier" if age == 150 else ""
    print(f"{age:>6} {z:>10.4f} {mm:>8.4f}{flag}")</cell id="cell-2">
<cell id="cell-3"><cell_type>markdown</cell_type>## 2. Categorical Encoding Strategies</cell id="cell-3">
<cell id="cell-4">from collections import defaultdict

def one_hot_encode(values: list[str]) -> dict[str, list[int]]:
    """One-hot encode a list of categorical values."""
    categories = sorted(set(values))
    category_to_idx = {c: i for i, c in enumerate(categories)}
    encoded = {}
    for val in values:
        vec = [0] * len(categories)
        vec[category_to_idx[val]] = 1
        encoded[val] = vec
    return {"categories": categories, "encoded": encoded}

def target_encode(feature: list[str], target: list[float], smoothing: float = 10.0) -> dict[str, float]:
    """
    Smoothed target encoding: blend category mean with global mean.
    Smoothing reduces overfitting on low-frequency categories.
    """
    global_mean = sum(target) / len(target)
    category_stats: dict[str, list] = defaultdict(list)

    for cat, t in zip(feature, target):
        category_stats[cat].append(t)

    encoding = {}
    for cat, values in category_stats.items():
        n = len(values)
        cat_mean = sum(values) / n
        # Smoothed estimate: weight toward global mean when n is small
        encoded = (n * cat_mean + smoothing * global_mean) / (n + smoothing)
        encoding[cat] = round(encoded, 4)

    return encoding

# Test one-hot
colors = ["red", "blue", "green", "red", "blue"]
result = one_hot_encode(colors)
print("One-Hot Encoding:")
print(f"Categories: {result['categories']}")
for color in set(colors):
    print(f"  {color}: {result['encoded'][color]}")

print()

# Test target encoding (country → mean revenue)
countries = ["US", "UK", "US", "DE", "US", "UK", "DE", "US", "FR", "UK"]
revenues  = [500, 320, 450, 280, 520, 310, 290, 480, 350, 330]

encodings = target_encode(countries, revenues, smoothing=5.0)
print("Target Encoding (Country → Smoothed Mean Revenue):")
global_mean = sum(revenues) / len(revenues)
print(f"  Global mean: {global_mean:.1f}")
for country, enc in sorted(encodings.items()):
    count = countries.count(country)
    raw_mean = sum(r for c, r in zip(countries, revenues) if c == country) / count
    print(f"  {country}: raw_mean={raw_mean:.1f}, encoded={enc:.4f} (n={count})")</cell id="cell-4">
<cell id="cell-5"><cell_type>markdown</cell_type>## 3. Missing Data Imputation</cell id="cell-5">
<cell id="cell-6">class SimpleImputer:
    """Handle missing values in feature columns."""

    def __init__(self, strategy: str = "mean"):
        assert strategy in {"mean", "median", "mode", "constant"}
        self.strategy = strategy
        self._fill_value = None

    def fit(self, data: list) -> "SimpleImputer":
        non_null = [x for x in data if x is not None]
        if not non_null:
            self._fill_value = 0
            return self

        if self.strategy == "mean":
            self._fill_value = sum(non_null) / len(non_null)
        elif self.strategy == "median":
            sorted_data = sorted(non_null)
            n = len(sorted_data)
            self._fill_value = (sorted_data[n//2 - 1] + sorted_data[n//2]) / 2 if n % 2 == 0 else sorted_data[n//2]
        elif self.strategy == "mode":
            from collections import Counter
            self._fill_value = Counter(non_null).most_common(1)[0][0]
        return self

    def transform(self, data: list) -> list:
        return [x if x is not None else self._fill_value for x in data]

# Simulate a dataset with missing values
random.seed(42)
ages_with_missing = [25, None, 30, 45, None, 28, None, 35, 31, 27]
cities = ["NYC", None, "LA", "NYC", "Chicago", None, "LA", "NYC", None, "Chicago"]

# Numerical: mean imputation
num_imputer = SimpleImputer("mean")
num_imputer.fit(ages_with_missing)
filled_ages = num_imputer.transform(ages_with_missing)

# Categorical: mode imputation
cat_imputer = SimpleImputer("mode")
cat_imputer.fit(cities)
filled_cities = cat_imputer.transform(cities)

print(f"{'Index':>6} {'Original Age':>13} {'Filled Age':>11} {'Original City':>14} {'Filled City':>12}")
print("-" * 62)
for i, (oa, fa, oc, fc) in enumerate(zip(ages_with_missing, filled_ages, cities, filled_cities)):
    imputed_flag = " *" if oa is None or oc is None else "  "
    print(f"{i:>6} {str(oa):>13} {fa:>11.1f} {str(oc):>14} {fc:>12}{imputed_flag}")
print(f"\n* Imputed: ages with mean={num_imputer._fill_value:.1f}, cities with mode='{cat_imputer._fill_value}'")</cell id="cell-6">
