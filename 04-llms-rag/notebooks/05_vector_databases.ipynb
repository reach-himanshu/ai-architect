<cell id="cell-0"><cell_type>markdown</cell_type># Vector Databases

Implementing core vector database concepts: HNSW intuition, metadata filtering, and hybrid search.</cell id="cell-0">
<cell id="cell-1"><cell_type>markdown</cell_type>## 1. In-Memory Vector Store with Metadata Filtering</cell id="cell-1">
<cell id="cell-2">import math
import random
from dataclasses import dataclass, field
from typing import Any

@dataclass
class Document:
    id: str
    text: str
    embedding: list[float]
    metadata: dict[str, Any] = field(default_factory=dict)

def cosine_similarity(a: list[float], b: list[float]) -> float:
    dot = sum(x * y for x, y in zip(a, b))
    norm_a = math.sqrt(sum(x**2 for x in a))
    norm_b = math.sqrt(sum(x**2 for x in b))
    return dot / (norm_a * norm_b) if norm_a and norm_b else 0.0

def mock_embed(text: str, dim: int = 16) -> list[float]:
    random.seed(hash(text) % (2**32))
    vec = [random.gauss(0, 1) for _ in range(dim)]
    norm = math.sqrt(sum(x**2 for x in vec))
    return [x / norm for x in vec]

class VectorStore:
    """Production-style vector store with metadata filtering."""

    def __init__(self):
        self._docs: dict[str, Document] = {}

    def upsert(self, id: str, text: str, metadata: dict = None) -> None:
        self._docs[id] = Document(
            id=id,
            text=text,
            embedding=mock_embed(text),
            metadata=metadata or {},
        )

    def _matches_filter(self, doc: Document, where: dict) -> bool:
        for key, condition in where.items():
            if isinstance(condition, dict):
                val = doc.metadata.get(key)
                if "$eq" in condition and val != condition["$eq"]:
                    return False
                if "$in" in condition and val not in condition["$in"]:
                    return False
                if "$gte" in condition and (val is None or val < condition["$gte"]):
                    return False
                if "$lte" in condition and (val is None or val > condition["$lte"]):
                    return False
            else:
                if doc.metadata.get(key) != condition:
                    return False
        return True

    def query(self, query_text: str, top_k: int = 5, where: dict = None) -> list[dict]:
        query_vec = mock_embed(query_text)
        results = []

        for doc in self._docs.values():
            if where and not self._matches_filter(doc, where):
                continue
            score = cosine_similarity(query_vec, doc.embedding)
            results.append({"id": doc.id, "text": doc.text, "score": score, "metadata": doc.metadata})

        return sorted(results, key=lambda x: x["score"], reverse=True)[:top_k]

# Build a knowledge base
store = VectorStore()
kb = [
    ("doc1", "Introduction to RAG systems", {"topic": "rag", "level": "beginner", "year": 2024}),
    ("doc2", "Advanced RAG with reranking", {"topic": "rag", "level": "advanced", "year": 2024}),
    ("doc3", "HNSW algorithm for ANN search", {"topic": "vector-db", "level": "advanced", "year": 2023}),
    ("doc4", "Pinecone vs Weaviate comparison", {"topic": "vector-db", "level": "intermediate", "year": 2024}),
    ("doc5", "Python async programming basics", {"topic": "python", "level": "beginner", "year": 2023}),
    ("doc6", "LLM fine-tuning with LoRA", {"topic": "llm", "level": "advanced", "year": 2024}),
    ("doc7", "Prompt engineering techniques", {"topic": "llm", "level": "beginner", "year": 2024}),
]

for doc_id, text, meta in kb:
    store.upsert(doc_id, text, meta)

# Query with metadata filtering
print("Query: 'RAG architecture' (all levels)")
for r in store.query("RAG architecture", top_k=3):
    print(f"  [{r['score']:.3f}] {r['text']} | topic={r['metadata']['topic']}")

print()
print("Query: 'vector search' (advanced only)")
for r in store.query("vector search", top_k=3, where={"level": "advanced"}):
    print(f"  [{r['score']:.3f}] {r['text']} | level={r['metadata']['level']}")

print()
print("Query: 'AI techniques' (year >= 2024)")
for r in store.query("AI techniques", top_k=3, where={"year": {"$gte": 2024}}):
    print(f"  [{r['score']:.3f}] {r['text']} | year={r['metadata']['year']}")</cell id="cell-2">
<cell id="cell-3"><cell_type>markdown</cell_type>## 2. Hybrid Search: Dense + Sparse (BM25 simulation)</cell id="cell-3">
<cell id="cell-4">import math
from collections import Counter

class BM25:
    """Simple BM25 sparse retrieval implementation."""
    def __init__(self, k1: float = 1.5, b: float = 0.75):
        self.k1 = k1
        self.b = b
        self._docs: list[dict] = []
        self._idf: dict[str, float] = {}
        self._avg_doc_len: float = 0

    def fit(self, documents: list[dict]) -> None:
        self._docs = documents
        doc_len = [len(d["text"].split()) for d in documents]
        self._avg_doc_len = sum(doc_len) / len(doc_len)

        # Compute IDF
        df: Counter = Counter()
        for doc in documents:
            terms = set(doc["text"].lower().split())
            df.update(terms)

        n = len(documents)
        self._idf = {
            term: math.log((n - freq + 0.5) / (freq + 0.5) + 1)
            for term, freq in df.items()
        }

    def score(self, query: str, doc_text: str) -> float:
        terms = query.lower().split()
        words = doc_text.lower().split()
        tf = Counter(words)
        doc_len = len(words)
        score = 0.0
        for term in terms:
            if term not in self._idf:
                continue
            f = tf[term]
            idf = self._idf[term]
            tf_score = f * (self.k1 + 1) / (f + self.k1 * (1 - self.b + self.b * doc_len / self._avg_doc_len))
            score += idf * tf_score
        return score

def hybrid_search(query: str, store: VectorStore, bm25: BM25, alpha: float = 0.5, top_k: int = 5) -> list[dict]:
    """Combine dense and sparse retrieval scores."""
    dense_results = store.query(query, top_k=len(store._docs))
    dense_map = {r["id"]: r["score"] for r in dense_results}
    # Normalize dense scores to [0, 1]
    max_dense = max(dense_map.values()) if dense_map else 1
    dense_norm = {k: v / max_dense for k, v in dense_map.items()}

    # Get sparse scores
    sparse_scores = {}
    for doc in bm25._docs:
        sparse_scores[doc["id"]] = bm25.score(query, doc["text"])
    max_sparse = max(sparse_scores.values()) if sparse_scores else 1
    sparse_norm = {k: v / max_sparse for k, v in sparse_scores.items()}

    # Combine
    all_ids = set(dense_norm) | set(sparse_norm)
    combined = []
    for doc_id in all_ids:
        d = dense_norm.get(doc_id, 0)
        s = sparse_norm.get(doc_id, 0)
        combined_score = alpha * d + (1 - alpha) * s
        combined.append({"id": doc_id, "dense": d, "sparse": s, "combined": combined_score})

    return sorted(combined, key=lambda x: x["combined"], reverse=True)[:top_k]

# Test hybrid search
bm25_docs = [{"id": d.id, "text": d.text} for d in store._docs.values()]
bm25 = BM25()
bm25.fit(bm25_docs)

print("Hybrid Search: 'RAG retrieval' (alpha=0.5)")
print(f"{'ID':<6} {'Dense':>7} {'Sparse':>7} {'Combined':>9}")
print("-" * 35)
for r in hybrid_search("RAG retrieval", store, bm25, alpha=0.5, top_k=4):
    print(f"{r['id']:<6} {r['dense']:>7.3f} {r['sparse']:>7.3f} {r['combined']:>9.3f}")</cell id="cell-4">
