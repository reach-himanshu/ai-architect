<cell id="cell-0"><cell_type>markdown</cell_type># Embeddings

Building intuition for vector similarity and implementing an embedding pipeline from scratch.</cell id="cell-0">
<cell id="cell-1"><cell_type>markdown</cell_type>## 1. Cosine Similarity from Scratch</cell id="cell-1">
<cell id="cell-2">import math
from typing import Sequence

def cosine_similarity(a: Sequence[float], b: Sequence[float]) -> float:
    """Compute cosine similarity between two vectors."""
    dot = sum(x * y for x, y in zip(a, b))
    norm_a = math.sqrt(sum(x ** 2 for x in a))
    norm_b = math.sqrt(sum(x ** 2 for x in b))
    if norm_a == 0 or norm_b == 0:
        return 0.0
    return dot / (norm_a * norm_b)

def euclidean_distance(a: Sequence[float], b: Sequence[float]) -> float:
    """Compute Euclidean distance between two vectors."""
    return math.sqrt(sum((x - y) ** 2 for x, y in zip(a, b)))

# Simulate embeddings (normally from an embedding model)
# These 4D vectors represent semantic relationships
vectors = {
    "dog":      [0.8,  0.6,  0.1,  0.2],
    "puppy":    [0.75, 0.65, 0.15, 0.25],
    "cat":      [0.7,  0.5,  0.2,  0.1],
    "car":      [0.1,  0.1,  0.9,  0.8],
    "truck":    [0.15, 0.05, 0.85, 0.75],
    "airplane": [0.05, 0.2,  0.7,  0.95],
}

print("Cosine Similarity Matrix (higher = more similar)")
print("=" * 65)
words = list(vectors.keys())
print(f"{'':12}", end="")
for w in words:
    print(f"{w:10}", end="")
print()

for w1 in words:
    print(f"{w1:12}", end="")
    for w2 in words:
        sim = cosine_similarity(vectors[w1], vectors[w2])
        print(f"{sim:.3f}     ", end="")
    print()</cell id="cell-2">
<cell id="cell-3"><cell_type>markdown</cell_type>## 2. Semantic Search Engine (Without an API)</cell id="cell-3">
<cell id="cell-4">import random

def mock_embed(text: str, dim: int = 8) -> list[float]:
    """
    Mock embedding function for demonstration.
    In production, use: openai.embeddings.create() or sentence_transformers
    """
    random.seed(hash(text) % (2**32))
    vec = [random.gauss(0, 1) for _ in range(dim)]
    # Normalize
    norm = math.sqrt(sum(x**2 for x in vec))
    return [x / norm for x in vec]

class SimpleVectorStore:
    """A minimal in-memory vector store."""

    def __init__(self):
        self._documents: list[dict] = []

    def add(self, text: str, metadata: dict = None) -> None:
        embedding = mock_embed(text)
        self._documents.append({
            "text": text,
            "embedding": embedding,
            "metadata": metadata or {},
        })

    def search(self, query: str, top_k: int = 3) -> list[dict]:
        query_embedding = mock_embed(query)
        scored = []

        for doc in self._documents:
            sim = cosine_similarity(query_embedding, doc["embedding"])
            scored.append({**doc, "score": sim})

        return sorted(scored, key=lambda x: x["score"], reverse=True)[:top_k]

# Build a small knowledge base
store = SimpleVectorStore()
documents = [
    ("RAG stands for Retrieval-Augmented Generation.", {"topic": "rag", "section": "intro"}),
    ("Vector databases store high-dimensional embeddings.", {"topic": "vector-db", "section": "storage"}),
    ("Chunking splits documents into smaller pieces for indexing.", {"topic": "rag", "section": "ingestion"}),
    ("Temperature controls the randomness of LLM outputs.", {"topic": "llm", "section": "params"}),
    ("FAISS is a library for efficient similarity search.", {"topic": "vector-db", "section": "tools"}),
    ("Python is a high-level programming language.", {"topic": "python", "section": "intro"}),
]

for text, metadata in documents:
    store.add(text, metadata)

# Search
queries = ["How does RAG work?", "How to store vectors?", "What is Python?"]
for query in queries:
    results = store.search(query, top_k=2)
    print(f"Query: {query!r}")
    for r in results:
        print(f"  [{r['score']:.3f}] {r['text']}")
    print()</cell id="cell-4">
<cell id="cell-5"><cell_type>markdown</cell_type>## 3. Embedding Dimensionality Trade-off Analysis</cell id="cell-5">
<cell id="cell-6">import time

def benchmark_similarity(dim: int, n_docs: int = 1000) -> dict:
    """Benchmark similarity search at different vector dimensions."""
    # Generate random normalized vectors
    docs = []
    for _ in range(n_docs):
        vec = [random.gauss(0, 1) for _ in range(dim)]
        norm = math.sqrt(sum(x**2 for x in vec))
        docs.append([x / norm for x in vec])

    query = docs[0]  # Use first doc as query

    start = time.time()
    similarities = [cosine_similarity(query, doc) for doc in docs]
    elapsed_ms = (time.time() - start) * 1000

    storage_bytes = n_docs * dim * 4  # 4 bytes per float32

    return {
        "dimensions": dim,
        "n_docs": n_docs,
        "search_ms": round(elapsed_ms, 2),
        "storage_kb": round(storage_bytes / 1024, 1),
        "max_similarity": round(max(similarities[1:]), 4),  # Exclude self
    }

print(f"{'Dims':>6} | {'Docs':>6} | {'Search (ms)':>12} | {'Storage (KB)':>13} | {'Max Sim':>8}")
print("-" * 60)
for dim in [128, 384, 768, 1536, 3072]:
    result = benchmark_similarity(dim, n_docs=500)
    print(f"{result['dimensions']:>6} | {result['n_docs']:>6} | {result['search_ms']:>12.2f} | {result['storage_kb']:>13.1f} | {result['max_similarity']:>8.4f}")</cell id="cell-6">
