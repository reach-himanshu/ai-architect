<cell id="cell-0"><cell_type>markdown</cell_type># LLM APIs

Building a production-grade LLM client with retry logic, cost tracking, and structured output.</cell id="cell-0">
<cell id="cell-1"><cell_type>markdown</cell_type>## 1. LLM Client with Retry, Cost Tracking, and Logging

A reusable wrapper that handles production concerns.</cell id="cell-1">
<cell id="cell-2">import time
import random
import json
from dataclasses import dataclass, field
from typing import Any

# Cost table (per 1M tokens, approximate 2025 pricing)
COST_TABLE = {
    "gpt-4o":              {"input": 2.50,  "output": 10.00},
    "gpt-4o-mini":         {"input": 0.15,  "output": 0.60},
    "claude-opus-4-6":     {"input": 15.00, "output": 75.00},
    "claude-sonnet-4-5-20250929": {"input": 3.00,  "output": 15.00},
    "claude-haiku-4-5-20251001":  {"input": 0.25,  "output": 1.25},
}

@dataclass
class LLMUsage:
    model: str
    input_tokens: int
    output_tokens: int
    latency_ms: float

    @property
    def cost_usd(self) -> float:
        prices = COST_TABLE.get(self.model, {"input": 3.0, "output": 15.0})
        return (
            (self.input_tokens / 1_000_000) * prices["input"] +
            (self.output_tokens / 1_000_000) * prices["output"]
        )

    def __str__(self) -> str:
        return (
            f"Model: {self.model} | "
            f"In: {self.input_tokens} | Out: {self.output_tokens} | "
            f"Cost: ${self.cost_usd:.6f} | Latency: {self.latency_ms:.0f}ms"
        )

# Simulate an LLM call (replace with real client in production)
def simulate_llm_call(model: str, messages: list[dict], temperature: float = 0.7) -> dict:
    """Simulates an LLM API response for demonstration purposes."""
    time.sleep(0.05)  # Simulate network latency

    # Simulate occasional errors
    if random.random() < 0.1:
        raise ConnectionError("Simulated rate limit error")

    user_msg = messages[-1]["content"] if messages else ""
    return {
        "content": f"[Simulated response to: '{user_msg[:30]}...']",
        "input_tokens": sum(len(m["content"].split()) * 1.3 for m in messages),
        "output_tokens": 50,
    }

def call_llm_with_retry(
    model: str,
    messages: list[dict],
    temperature: float = 0.7,
    max_retries: int = 3,
    base_delay: float = 0.5,
) -> tuple[str, LLMUsage]:
    """Call LLM with exponential backoff retry."""
    for attempt in range(max_retries):
        try:
            start = time.time()
            result = simulate_llm_call(model, messages, temperature)
            latency_ms = (time.time() - start) * 1000

            usage = LLMUsage(
                model=model,
                input_tokens=int(result["input_tokens"]),
                output_tokens=result["output_tokens"],
                latency_ms=latency_ms,
            )
            return result["content"], usage

        except ConnectionError as e:
            if attempt == max_retries - 1:
                raise
            delay = base_delay * (2 ** attempt) + random.uniform(0, 0.3)
            print(f"  Attempt {attempt + 1} failed: {e}. Retrying in {delay:.2f}s...")
            time.sleep(delay)

# Run a few calls
total_cost = 0.0
for i in range(3):
    messages = [
        {"role": "system", "content": "You are an AI architecture expert."},
        {"role": "user", "content": f"Explain concept {i+1} of RAG in one sentence."},
    ]
    try:
        content, usage = call_llm_with_retry("claude-sonnet-4-5-20250929", messages)
        total_cost += usage.cost_usd
        print(f"Call {i+1}: {usage}")
    except Exception as e:
        print(f"Call {i+1} failed after retries: {e}")

print(f"\nTotal session cost: ${total_cost:.6f}")</cell id="cell-2">
<cell id="cell-3"><cell_type>markdown</cell_type>## 2. Messages Array Builder

Building conversation history correctly is essential for multi-turn applications.</cell id="cell-3">
<cell id="cell-4">class ConversationManager:
    """Manages conversation history with a sliding window to stay within context limits."""

    def __init__(self, system_prompt: str, max_turns: int = 10):
        self.system_prompt = system_prompt
        self.max_turns = max_turns
        self._history: list[dict] = []

    def add_user(self, content: str) -> None:
        self._history.append({"role": "user", "content": content})

    def add_assistant(self, content: str) -> None:
        self._history.append({"role": "assistant", "content": content})

    def get_messages(self) -> list[dict]:
        """Return messages array with system prompt and windowed history."""
        windowed = self._history[-(self.max_turns * 2):]
        return [{"role": "system", "content": self.system_prompt}] + windowed

    def token_estimate(self) -> int:
        """Rough token count estimate (1 token ≈ 4 chars)."""
        total_chars = len(self.system_prompt)
        for msg in self._history:
            total_chars += len(msg["content"])
        return total_chars // 4

# Demonstrate conversation management
conv = ConversationManager(
    system_prompt="You are an AI architecture tutor.",
    max_turns=3,
)

turns = [
    ("What is RAG?", "RAG stands for Retrieval-Augmented Generation..."),
    ("What are chunking strategies?", "Common strategies include fixed-size, recursive, and semantic chunking..."),
    ("Which is best?", "Semantic chunking is often best for precision..."),
    ("How do I implement it?", "You can use LangChain's SemanticChunker..."),
]

for user_msg, assistant_msg in turns:
    conv.add_user(user_msg)
    conv.add_assistant(assistant_msg)

messages = conv.get_messages()
print(f"Total history: {len(turns)} turns")
print(f"Messages in window: {len(messages) - 1} turns (system + {len(messages)-1} messages)")
print(f"Estimated tokens: {conv.token_estimate()}")
print()
for msg in messages:
    print(f"[{msg['role'].upper()}]: {msg['content'][:60]}...")</cell id="cell-4">
<cell id="cell-5"><cell_type>markdown</cell_type>## 3. Structured Output with Pydantic Validation</cell id="cell-5">
<cell id="cell-6">import json
from pydantic import BaseModel, ValidationError
from typing import Optional

class ExtractedEntity(BaseModel):
    name: str
    entity_type: str  # person, organization, location, product
    confidence: float  # 0.0 to 1.0
    context: Optional[str] = None

class ExtractionResult(BaseModel):
    entities: list[ExtractedEntity]
    total_found: int
    processing_notes: Optional[str] = None

def parse_structured_output(raw_json: str) -> ExtractionResult | None:
    """Parse and validate structured LLM output using Pydantic."""
    try:
        data = json.loads(raw_json)
        return ExtractionResult(**data)
    except json.JSONDecodeError as e:
        print(f"JSON parse error: {e}")
        return None
    except ValidationError as e:
        print(f"Validation error: {e}")
        return None

# Simulate a well-formed LLM response
good_response = json.dumps({
    "entities": [
        {"name": "Alice Johnson", "entity_type": "person", "confidence": 0.98, "context": "CEO"},
        {"name": "Anthropic", "entity_type": "organization", "confidence": 0.95, "context": "AI company"},
        {"name": "San Francisco", "entity_type": "location", "confidence": 0.90},
    ],
    "total_found": 3,
    "processing_notes": "High confidence extraction"
})

# Simulate a malformed response
bad_response = '{"entities": [{"name": "Bob"}], "total_found": "one"}'

print("Good response:")
result = parse_structured_output(good_response)
if result:
    for entity in result.entities:
        print(f"  {entity.entity_type}: {entity.name} ({entity.confidence:.0%} confident)")

print()
print("Bad response:")
parse_structured_output(bad_response)</cell id="cell-6">
