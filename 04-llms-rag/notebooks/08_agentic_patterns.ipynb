<cell id="cell-0"><cell_type>markdown</cell_type># Agentic Patterns

Building a ReAct agent loop with tool use, memory, and multi-agent coordination.</cell id="cell-0">
<cell id="cell-1"><cell_type>markdown</cell_type>## 1. Tool Registry and Executor</cell id="cell-1">
<cell id="cell-2">import json
import inspect
from typing import Callable, Any
from dataclasses import dataclass

@dataclass
class ToolDefinition:
    name: str
    description: str
    parameters: dict
    func: Callable

    def to_api_schema(self) -> dict:
        """Convert to OpenAI-compatible tool schema."""
        return {
            "type": "function",
            "function": {
                "name": self.name,
                "description": self.description,
                "parameters": self.parameters,
            }
        }

class ToolRegistry:
    """Registry that holds and executes tools."""

    def __init__(self):
        self._tools: dict[str, ToolDefinition] = {}

    def register(self, name: str, description: str, parameters: dict):
        """Decorator to register a function as a tool."""
        def decorator(func: Callable) -> Callable:
            self._tools[name] = ToolDefinition(
                name=name,
                description=description,
                parameters=parameters,
                func=func,
            )
            return func
        return decorator

    def execute(self, name: str, arguments: dict) -> Any:
        if name not in self._tools:
            return {"error": f"Tool '{name}' not found. Available: {list(self._tools.keys())}"}
        try:
            return self._tools[name].func(**arguments)
        except Exception as e:
            return {"error": str(e)}

    def get_schemas(self) -> list[dict]:
        return [t.to_api_schema() for t in self._tools.values()]

# Create the registry and register tools
registry = ToolRegistry()

@registry.register(
    name="search_web",
    description="Search the web for current information. Use for facts, news, definitions.",
    parameters={
        "type": "object",
        "properties": {
            "query": {"type": "string", "description": "The search query"},
            "max_results": {"type": "integer", "default": 3},
        },
        "required": ["query"],
    }
)
def search_web(query: str, max_results: int = 3) -> dict:
    """Simulated web search."""
    results = {
        "Tokyo population": [{"title": "Tokyo Facts", "snippet": "Tokyo has 13.96M people (2024)"}],
        "Python programming": [{"title": "Python", "snippet": "Python is a high-level interpreted language."}],
        "RAG architecture": [{"title": "RAG Guide", "snippet": "RAG combines retrieval and generation for grounded LLM answers."}],
    }
    for key, val in results.items():
        if key.lower() in query.lower():
            return {"results": val[:max_results]}
    return {"results": [{"title": "Generic Result", "snippet": f"Information about: {query}"}]}

@registry.register(
    name="calculate",
    description="Perform mathematical calculations. Input a valid Python math expression.",
    parameters={
        "type": "object",
        "properties": {
            "expression": {"type": "string", "description": "Math expression e.g. '13.96 + 8.26'"},
        },
        "required": ["expression"],
    }
)
def calculate(expression: str) -> dict:
    """Safe math evaluator."""
    try:
        allowed = set("0123456789.+-*/() ")
        if not all(c in allowed for c in expression):
            return {"error": "Only basic math operators allowed"}
        result = eval(expression)  # Safe here: only math chars allowed
        return {"result": result, "expression": expression}
    except Exception as e:
        return {"error": str(e)}

# Test the registry
print("Registered tools:")
for schema in registry.get_schemas():
    print(f"  - {schema['function']['name']}: {schema['function']['description'][:60]}")

print()
print("Tool executions:")
print(registry.execute("search_web", {"query": "RAG architecture"}))
print(registry.execute("calculate", {"expression": "13.96 + 8.26"}))
print(registry.execute("unknown_tool", {}))</cell id="cell-2">
<cell id="cell-3"><cell_type>markdown</cell_type>## 2. ReAct Agent Loop</cell id="cell-3">
<cell id="cell-4">import json
from dataclasses import dataclass, field

@dataclass
class AgentStep:
    step: int
    thought: str
    action: str = ""
    action_input: dict = field(default_factory=dict)
    observation: str = ""

class ReActAgent:
    """
    ReAct agent that reasons and acts in a loop.
    In production, the LLM generates thoughts and tool calls.
    Here, we simulate the decision logic.
    """

    def __init__(self, registry: ToolRegistry, max_steps: int = 5):
        self.registry = registry
        self.max_steps = max_steps
        self._steps: list[AgentStep] = []

    def _simulate_llm_decision(self, query: str, steps_so_far: list[AgentStep]) -> dict:
        """
        Simulates LLM decision-making.
        In production: call LLM with tool schemas + conversation history.
        """
        n = len(steps_so_far)

        if n == 0:
            return {
                "thought": f"I need to find information about '{query}'. Let me search for it.",
                "action": "search_web",
                "action_input": {"query": query},
            }
        elif n == 1 and "Tokyo" in query:
            return {
                "thought": "Now let me compare with NYC.",
                "action": "search_web",
                "action_input": {"query": "New York City population 2024"},
            }
        else:
            last_obs = steps_so_far[-1].observation if steps_so_far else ""
            return {
                "thought": f"I have enough information: {last_obs[:100]}. I can now answer.",
                "action": "FINISH",
                "action_input": {},
                "final_answer": f"Based on my research about '{query}': {last_obs}",
            }

    def run(self, query: str) -> str:
        print(f"Agent running: '{query}'")
        print("=" * 55)

        for step_num in range(1, self.max_steps + 1):
            decision = self._simulate_llm_decision(query, self._steps)

            if decision.get("action") == "FINISH":
                print(f"Step {step_num} [THOUGHT]: {decision['thought']}")
                print(f"Final Answer: {decision['final_answer']}")
                return decision["final_answer"]

            step = AgentStep(
                step=step_num,
                thought=decision["thought"],
                action=decision["action"],
                action_input=decision["action_input"],
            )

            result = self.registry.execute(step.action, step.action_input)
            step.observation = json.dumps(result)
            self._steps.append(step)

            print(f"Step {step_num} [THOUGHT]: {step.thought}")
            print(f"  [ACTION]: {step.action}({json.dumps(step.action_input)})")
            print(f"  [OBSERVATION]: {step.observation[:100]}")
            print()

        return "Max steps reached without a final answer."

agent = ReActAgent(registry, max_steps=5)
agent.run("Tokyo population comparison")</cell id="cell-4">
<cell id="cell-5"><cell_type>markdown</cell_type>## 3. Simple Agent Memory</cell id="cell-5">
<cell id="cell-6">from datetime import datetime
import math, random

def mock_embed(text: str, dim: int = 8) -> list[float]:
    random.seed(hash(text) % (2**32))
    vec = [random.gauss(0, 1) for _ in range(dim)]
    norm = math.sqrt(sum(x**2 for x in vec))
    return [x / norm for x in vec]

def cosine_sim(a, b):
    dot = sum(x*y for x,y in zip(a,b))
    na = math.sqrt(sum(x**2 for x in a))
    nb = math.sqrt(sum(x**2 for x in b))
    return dot/(na*nb) if na and nb else 0.0

class AgentMemory:
    """
    Persistent agent memory combining:
    - Working memory: Current session context (in-context)
    - Episodic memory: Past interactions (vector store)
    - Semantic memory: Key facts (key-value store)
    """

    def __init__(self, max_working: int = 5):
        self.max_working = max_working
        self._working: list[dict] = []
        self._episodic: list[dict] = []
        self._semantic: dict[str, str] = {}

    def remember_working(self, role: str, content: str) -> None:
        self._working.append({"role": role, "content": content, "ts": datetime.now().isoformat()})
        if len(self._working) > self.max_working:
            self._working.pop(0)

    def remember_fact(self, key: str, value: str) -> None:
        self._semantic[key] = value

    def remember_episode(self, summary: str) -> None:
        self._episodic.append({"summary": summary, "embedding": mock_embed(summary), "ts": datetime.now().isoformat()})

    def recall_facts(self, key: str) -> str | None:
        return self._semantic.get(key)

    def recall_similar(self, query: str, top_k: int = 2) -> list[str]:
        qe = mock_embed(query)
        scored = [(cosine_sim(qe, e["embedding"]), e["summary"]) for e in self._episodic]
        scored.sort(reverse=True)
        return [s for _, s in scored[:top_k]]

    def get_working_context(self) -> list[dict]:
        return self._working.copy()

# Simulate an agent using memory across interactions
memory = AgentMemory(max_working=4)

memory.remember_working("user", "What is RAG?")
memory.remember_working("assistant", "RAG is Retrieval-Augmented Generation...")
memory.remember_fact("user_name", "Alice")
memory.remember_fact("user_expertise", "intermediate")
memory.remember_episode("User asked about RAG fundamentals and seemed satisfied with the explanation")
memory.remember_episode("User asked about vector databases, specifically Pinecone vs Qdrant")
memory.remember_working("user", "Now tell me about vector databases")
memory.remember_working("assistant", "Vector databases like Pinecone and Qdrant...")

print("Working Memory (last 4 turns):")
for msg in memory.get_working_context():
    print(f"  [{msg['role']}]: {msg['content'][:60]}...")

print()
print("Semantic Facts:")
print(f"  User: {memory.recall_facts('user_name')}, Level: {memory.recall_facts('user_expertise')}")

print()
print("Relevant Episodes for 'similarity search performance':")
for ep in memory.recall_similar("similarity search performance", top_k=2):
    print(f"  - {ep}")</cell id="cell-6">
