<cell id="cell-0"><cell_type>markdown</cell_type># Advanced RAG

Implementing query transformation, parent-child chunking, and reranking from scratch.</cell id="cell-0">
<cell id="cell-1"><cell_type>markdown</cell_type>## 1. Multi-Query Retrieval</cell id="cell-1">
<cell id="cell-2">import math
import random
from dataclasses import dataclass

def mock_embed(text: str, dim: int = 16) -> list[float]:
    random.seed(hash(text) % (2**32))
    vec = [random.gauss(0, 1) for _ in range(dim)]
    norm = math.sqrt(sum(x**2 for x in vec))
    return [x / norm for x in vec]

def cosine_similarity(a, b):
    dot = sum(x * y for x, y in zip(a, b))
    na = math.sqrt(sum(x**2 for x in a))
    nb = math.sqrt(sum(x**2 for x in b))
    return dot / (na * nb) if na and nb else 0.0

# Simulate query expansion (in production, this would call an LLM)
def expand_query(query: str) -> list[str]:
    """Generate query variants (simulated — would use LLM in production)."""
    expansions = {
        "How does RAG work?": [
            "How does Retrieval-Augmented Generation work?",
            "RAG architecture and pipeline explanation",
            "Steps in retrieval augmented generation system",
        ],
        "vector database performance": [
            "vector DB query latency benchmark",
            "ANN search speed comparison",
            "HNSW vs IVF index performance",
        ],
    }
    return expansions.get(query, [query, f"explain {query}", f"overview of {query}"])

class MultiQueryRAG:
    """RAG with query expansion for better coverage."""

    def __init__(self, docs: list[dict]):
        self._index = [{"text": d["text"], "embedding": mock_embed(d["text"]), **d} for d in docs]

    def _search(self, query: str, top_k: int = 5) -> list[dict]:
        qe = mock_embed(query)
        return sorted(self._index, key=lambda d: cosine_similarity(qe, d["embedding"]), reverse=True)[:top_k]

    def retrieve(self, query: str, top_k: int = 5) -> list[dict]:
        variants = [query] + expand_query(query)
        seen_texts = set()
        merged = []

        for variant in variants:
            for doc in self._search(variant, top_k=3):
                if doc["text"] not in seen_texts:
                    seen_texts.add(doc["text"])
                    merged.append(doc)

        # Score by frequency across variants (reciprocal rank fusion)
        scores = {}
        for variant in variants:
            for rank, doc in enumerate(self._search(variant, top_k=10)):
                key = doc["text"]
                scores[key] = scores.get(key, 0) + 1 / (rank + 1)

        merged_scored = [{"score": scores.get(d["text"], 0), **d} for d in merged]
        return sorted(merged_scored, key=lambda x: x["score"], reverse=True)[:top_k]

docs = [
    {"id": "1", "text": "RAG retrieves relevant context from a knowledge base to ground LLM answers."},
    {"id": "2", "text": "Vector databases store embeddings and enable fast similarity search."},
    {"id": "3", "text": "HNSW is a graph-based ANN algorithm used in Pinecone and Qdrant."},
    {"id": "4", "text": "Query expansion generates multiple search variants to improve recall."},
    {"id": "5", "text": "Reranking uses cross-encoders to re-score retrieved documents for precision."},
    {"id": "6", "text": "Chunking strategies affect retrieval quality significantly in RAG systems."},
]

mqrag = MultiQueryRAG(docs)
print("Multi-Query Results for 'How does RAG work?'")
for r in mqrag.retrieve("How does RAG work?", top_k=3):
    print(f"  [RRF: {r['score']:.3f}] {r['text']}")</cell id="cell-2">
<cell id="cell-3"><cell_type>markdown</cell_type>## 2. Parent-Child Chunking</cell id="cell-3">
<cell id="cell-4">import uuid
import re
from dataclasses import dataclass, field

@dataclass
class ParentChunk:
    id: str
    text: str
    children: list["ChildChunk"] = field(default_factory=list)

@dataclass
class ChildChunk:
    id: str
    text: str
    parent_id: str
    embedding: list[float] = field(default_factory=list)

def split_sentences(text: str) -> list[str]:
    return [s.strip() for s in re.split(r'(?<=[.!?])\s+', text) if s.strip()]

class ParentChildIndex:
    """Index with small child chunks for retrieval and large parent chunks for context."""

    def __init__(self, parent_sentences: int = 4, child_sentences: int = 1):
        self.parent_size = parent_sentences
        self.child_size = child_sentences
        self._parents: dict[str, ParentChunk] = {}
        self._children: list[ChildChunk] = []

    def ingest(self, text: str) -> None:
        sentences = split_sentences(text)
        # Create parent chunks
        for i in range(0, len(sentences), self.parent_size):
            parent_sents = sentences[i:i + self.parent_size]
            parent = ParentChunk(id=str(uuid.uuid4())[:8], text=" ".join(parent_sents))

            # Create child chunks within each parent
            for j in range(0, len(parent_sents), self.child_size):
                child_sents = parent_sents[j:j + self.child_size]
                child = ChildChunk(
                    id=str(uuid.uuid4())[:8],
                    text=" ".join(child_sents),
                    parent_id=parent.id,
                    embedding=mock_embed(" ".join(child_sents)),
                )
                parent.children.append(child)
                self._children.append(child)

            self._parents[parent.id] = parent

    def search(self, query: str, top_k: int = 3) -> list[dict]:
        """Search child chunks, return parent context."""
        qe = mock_embed(query)
        scored_children = sorted(
            self._children,
            key=lambda c: cosine_similarity(qe, c.embedding),
            reverse=True
        )[:top_k]

        seen_parents = set()
        results = []
        for child in scored_children:
            parent = self._parents[child.parent_id]
            if parent.id not in seen_parents:
                seen_parents.add(parent.id)
                results.append({
                    "matched_child": child.text,
                    "parent_context": parent.text,
                    "parent_id": parent.id,
                })
        return results

long_doc = (
    "RAG stands for Retrieval-Augmented Generation. It is an AI framework combining retrieval and generation. "
    "The retrieval step finds relevant documents from a knowledge base. A vector database stores document embeddings. "
    "Similarity search finds the most relevant chunks. Retrieved documents become context for the LLM. "
    "The LLM generates an answer grounded in the retrieved context. This reduces hallucinations significantly. "
    "Chunking is a critical step in RAG pipelines. Small chunks improve retrieval precision. "
    "Large chunks provide more context for the LLM. Parent-child chunking combines both benefits."
)

pc_index = ParentChildIndex(parent_sentences=3, child_sentences=1)
pc_index.ingest(long_doc)

print(f"Indexed {len(pc_index._parents)} parents, {len(pc_index._children)} children\n")
results = pc_index.search("What is RAG?", top_k=2)
for r in results:
    print(f"Matched Child: '{r['matched_child']}'")
    print(f"Parent Context (sent to LLM): '{r['parent_context']}'")
    print()</cell id="cell-4">
<cell id="cell-5"><cell_type>markdown</cell_type>## 3. Reciprocal Rank Fusion (RRF)</cell id="cell-5">
<cell id="cell-6">def reciprocal_rank_fusion(ranked_lists: list[list[str]], k: int = 60) -> list[tuple[str, float]]:
    """
    Merge multiple ranked lists using RRF.
    k=60 is the standard constant that prevents very high scores for top ranks.
    """
    scores: dict[str, float] = {}

    for ranked in ranked_lists:
        for rank, doc_id in enumerate(ranked):
            scores[doc_id] = scores.get(doc_id, 0) + 1 / (k + rank + 1)

    return sorted(scores.items(), key=lambda x: x[1], reverse=True)

# Simulate different retrieval systems returning ranked doc IDs
dense_results  = ["doc3", "doc1", "doc5", "doc7", "doc2"]  # Vector search
sparse_results = ["doc1", "doc4", "doc3", "doc6", "doc2"]  # BM25
llm_results    = ["doc5", "doc3", "doc1", "doc2", "doc8"]  # HyDE search

fused = reciprocal_rank_fusion([dense_results, sparse_results, llm_results])

print("Reciprocal Rank Fusion Results")
print(f"{'Rank':<6} {'Doc ID':<8} {'RRF Score':>10}")
print("-" * 28)
for rank, (doc_id, score) in enumerate(fused[:6], 1):
    print(f"{rank:<6} {doc_id:<8} {score:>10.4f}")

print()
print("doc3 appears in all 3 lists → highest score")
print("doc8 appears in only 1 list → lower score")</cell id="cell-6">
