<cell id="cell-0"><cell_type>markdown</cell_type># RAG Fundamentals

Build a complete RAG pipeline from scratch — chunking, indexing, retrieval, and generation.</cell id="cell-0">
<cell id="cell-1"><cell_type>markdown</cell_type>## 1. Document Chunking Strategies</cell id="cell-1">
<cell id="cell-2">import re
from dataclasses import dataclass

@dataclass
class Chunk:
    text: str
    start_char: int
    chunk_id: int
    metadata: dict

def fixed_size_chunk(text: str, size: int = 200, overlap: int = 50) -> list[Chunk]:
    """Split text into fixed-size character chunks with overlap."""
    chunks = []
    start = 0
    chunk_id = 0
    while start < len(text):
        end = min(start + size, len(text))
        chunks.append(Chunk(text=text[start:end], start_char=start, chunk_id=chunk_id, metadata={"strategy": "fixed"}))
        start += size - overlap
        chunk_id += 1
    return chunks

def sentence_chunk(text: str, max_chunk_size: int = 300) -> list[Chunk]:
    """Split text at sentence boundaries."""
    sentences = re.split(r'(?<=[.!?])\s+', text)
    chunks = []
    current = ""
    start_char = 0
    chunk_id = 0

    for sent in sentences:
        if len(current) + len(sent) > max_chunk_size and current:
            chunks.append(Chunk(text=current.strip(), start_char=start_char, chunk_id=chunk_id, metadata={"strategy": "sentence"}))
            start_char += len(current)
            current = sent + " "
            chunk_id += 1
        else:
            current += sent + " "

    if current.strip():
        chunks.append(Chunk(text=current.strip(), start_char=start_char, chunk_id=chunk_id, metadata={"strategy": "sentence"}))

    return chunks

def recursive_chunk(text: str, max_size: int = 300, separators: list[str] = None) -> list[Chunk]:
    """Recursively split using different separators (like LangChain's RecursiveCharacterTextSplitter)."""
    if separators is None:
        separators = ["\n\n", "\n", ". ", " ", ""]

    if len(text) <= max_size:
        return [Chunk(text=text, start_char=0, chunk_id=0, metadata={"strategy": "recursive"})]

    for sep in separators:
        if sep and sep in text:
            parts = text.split(sep)
            chunks = []
            current = ""
            chunk_id = 0
            for part in parts:
                candidate = current + sep + part if current else part
                if len(candidate) > max_size and current:
                    chunks.append(Chunk(text=current.strip(), start_char=0, chunk_id=chunk_id, metadata={"strategy": "recursive"}))
                    current = part
                    chunk_id += 1
                else:
                    current = candidate
            if current:
                chunks.append(Chunk(text=current.strip(), start_char=0, chunk_id=chunk_id, metadata={"strategy": "recursive"}))
            return chunks

    return [Chunk(text=text[:max_size], start_char=0, chunk_id=0, metadata={"strategy": "recursive"})]

# Test with a sample document
document = """
Retrieval-Augmented Generation (RAG) is an AI framework that combines the strengths of retrieval-based and generative AI models.

RAG systems work by first retrieving relevant documents from a knowledge base, then using those documents as context for a language model to generate an answer. This approach grounds the LLM's responses in real data.

The retrieval step uses vector similarity search. Documents are chunked, embedded, and stored in a vector database. At query time, the query is embedded and compared against all document embeddings to find the most relevant chunks.

The generation step combines the retrieved context with the user query in a prompt. The LLM then generates a response grounded in the retrieved information, reducing hallucinations significantly.
""".strip()

strategies = [
    ("Fixed-size (200 chars, 50 overlap)", fixed_size_chunk(document, 200, 50)),
    ("Sentence-based (max 300)", sentence_chunk(document, 300)),
    ("Recursive (max 300)", recursive_chunk(document, 300)),
]

for name, chunks in strategies:
    print(f"Strategy: {name}")
    print(f"  Chunks: {len(chunks)}")
    for i, c in enumerate(chunks):
        print(f"  [{i}] ({len(c.text)} chars): {c.text[:80]}...")
    print()</cell id="cell-2">
<cell id="cell-3"><cell_type>markdown</cell_type>## 2. Complete RAG Pipeline</cell id="cell-3">
<cell id="cell-4">import math
import random

def mock_embed(text: str, dim: int = 16) -> list[float]:
    random.seed(hash(text) % (2**32))
    vec = [random.gauss(0, 1) for _ in range(dim)]
    norm = math.sqrt(sum(x**2 for x in vec))
    return [x / norm for x in vec]

def cosine_similarity(a, b):
    dot = sum(x * y for x, y in zip(a, b))
    na = math.sqrt(sum(x**2 for x in a))
    nb = math.sqrt(sum(x**2 for x in b))
    return dot / (na * nb) if na and nb else 0.0

class RAGPipeline:
    """A minimal but complete RAG pipeline."""

    def __init__(self, chunk_size: int = 300):
        self.chunk_size = chunk_size
        self._index: list[dict] = []

    def ingest(self, documents: list[dict]) -> None:
        """Chunk, embed, and index documents."""
        print(f"Ingesting {len(documents)} documents...")
        for doc in documents:
            chunks = sentence_chunk(doc["text"], self.chunk_size)
            for chunk in chunks:
                self._index.append({
                    "text": chunk.text,
                    "embedding": mock_embed(chunk.text),
                    "source": doc.get("source", "unknown"),
                    "chunk_id": chunk.chunk_id,
                })
        print(f"  Indexed {len(self._index)} chunks.")

    def retrieve(self, query: str, top_k: int = 3) -> list[dict]:
        """Embed query and retrieve top-k chunks."""
        query_emb = mock_embed(query)
        scored = [(cosine_similarity(query_emb, c["embedding"]), c) for c in self._index]
        scored.sort(key=lambda x: x[0], reverse=True)
        return [{"score": s, **c} for s, c in scored[:top_k]]

    def build_prompt(self, query: str, retrieved: list[dict]) -> list[dict]:
        """Assemble the RAG prompt."""
        context = "\n\n".join(
            f"[Source {i+1} - {r['source']}]\n{r['text']}"
            for i, r in enumerate(retrieved)
        )
        return [
            {
                "role": "system",
                "content": (
                    "You are a precise assistant. Answer ONLY using the provided sources. "
                    "If the answer is not in the sources, say 'I don't have that information.' "
                    "Cite sources using [Source N]."
                ),
            },
            {"role": "user", "content": f"Sources:\n{context}\n\nQuestion: {query}"},
        ]

    def query(self, question: str, top_k: int = 3) -> dict:
        """End-to-end RAG query."""
        retrieved = self.retrieve(question, top_k=top_k)
        prompt = self.build_prompt(question, retrieved)
        return {
            "question": question,
            "retrieved_chunks": retrieved,
            "prompt": prompt,
            "simulated_answer": f"[LLM would answer based on {len(retrieved)} retrieved chunks]",
        }

# Build the pipeline
rag = RAGPipeline(chunk_size=200)
docs = [
    {"source": "rag_guide.md", "text": "RAG combines retrieval and generation. It retrieves relevant documents from a vector database. The retrieved context is then passed to an LLM to generate grounded answers."},
    {"source": "embeddings.md", "text": "Embeddings are dense vectors representing semantic meaning. Cosine similarity measures the angle between vectors. Higher similarity means more semantically similar text."},
    {"source": "chunking.md", "text": "Chunking splits documents into smaller pieces for indexing. Fixed-size chunking is simple. Sentence chunking preserves meaning better. Recursive chunking handles mixed content."},
]
rag.ingest(docs)

result = rag.query("How does RAG retrieve information?")
print(f"\nQuestion: {result['question']}")
print(f"Retrieved {len(result['retrieved_chunks'])} chunks:")
for r in result["retrieved_chunks"]:
    print(f"  [{r['score']:.3f}] ({r['source']}) {r['text'][:80]}...")
print(f"\nAnswer: {result['simulated_answer']}")</cell id="cell-4">
