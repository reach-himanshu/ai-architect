<cell id="cell-0"><cell_type>markdown</cell_type># LLM Evaluation

Implementing an evaluation framework for RAG systems: faithfulness scoring, hallucination detection, and regression testing.</cell id="cell-0">
<cell id="cell-1"><cell_type>markdown</cell_type>## 1. RAG Evaluation Metrics from Scratch</cell id="cell-1">
<cell id="cell-2">from dataclasses import dataclass
from typing import Optional

@dataclass
class EvalSample:
    question: str
    answer: str
    context: list[str]  # Retrieved chunks
    ground_truth: Optional[str] = None

@dataclass
class EvalResult:
    sample: EvalSample
    faithfulness: float
    answer_relevancy: float
    context_precision: float
    context_recall: Optional[float] = None

    @property
    def overall(self) -> float:
        scores = [self.faithfulness, self.answer_relevancy, self.context_precision]
        if self.context_recall is not None:
            scores.append(self.context_recall)
        return sum(scores) / len(scores)

# Simulated evaluation (in production, these would call an LLM judge)
def score_faithfulness(answer: str, context: list[str]) -> float:
    """Check if answer claims are supported by context."""
    combined_context = " ".join(context).lower()
    answer_words = set(answer.lower().split())
    # Simulated: check what fraction of key answer words appear in context
    key_words = [w for w in answer_words if len(w) > 5]
    if not key_words:
        return 1.0
    supported = sum(1 for w in key_words if w in combined_context)
    return round(supported / len(key_words), 3)

def score_answer_relevancy(question: str, answer: str) -> float:
    """Check if the answer addresses the question."""
    q_words = set(question.lower().split())
    a_words = set(answer.lower().split())
    overlap = len(q_words & a_words)
    return round(min(1.0, overlap / max(len(q_words), 1) * 2), 3)

def score_context_precision(question: str, context: list[str]) -> float:
    """What fraction of retrieved chunks are actually relevant?"""
    q_words = set(question.lower().split())
    relevant = 0
    for chunk in context:
        chunk_words = set(chunk.lower().split())
        if len(q_words & chunk_words) >= 2:
            relevant += 1
    return round(relevant / len(context) if context else 0, 3)

def evaluate_sample(sample: EvalSample) -> EvalResult:
    return EvalResult(
        sample=sample,
        faithfulness=score_faithfulness(sample.answer, sample.context),
        answer_relevancy=score_answer_relevancy(sample.question, sample.answer),
        context_precision=score_context_precision(sample.question, sample.context),
    )

# Evaluate a batch of samples
samples = [
    EvalSample(
        question="What is RAG and how does retrieval work?",
        answer="RAG is Retrieval-Augmented Generation. It retrieves relevant documents from a vector database using embedding similarity.",
        context=[
            "RAG stands for Retrieval-Augmented Generation, a framework combining retrieval and generation.",
            "Vector databases store embeddings and enable fast similarity search for retrieval.",
            "Python is a popular programming language.",  # Irrelevant chunk
        ],
        ground_truth="RAG retrieves relevant documents from a knowledge base to ground LLM responses.",
    ),
    EvalSample(
        question="How do you choose chunk size for RAG?",
        answer="Paris is the capital of France and has a population of 2.1 million.",
        context=[
            "Chunk size in RAG affects retrieval quality. Smaller chunks are more precise.",
            "Larger chunks provide more context but may introduce noise.",
        ],
        ground_truth="Chunk size depends on embedding model context length and query specificity.",
    ),
    EvalSample(
        question="What is HNSW indexing?",
        answer="HNSW is a graph-based algorithm for approximate nearest neighbor search used in vector databases.",
        context=[
            "HNSW stands for Hierarchical Navigable Small World graph.",
            "HNSW provides fast approximate nearest neighbor search with high recall.",
            "It is used in Pinecone, Qdrant, and Weaviate for indexing vectors.",
        ],
        ground_truth="HNSW is a fast ANN index algorithm used in vector databases.",
    ),
]

results = [evaluate_sample(s) for s in samples]

print(f"{'Question':<40} {'Faith':>6} {'RelEv':>6} {'CtxP':>6} {'Overall':>8}")
print("-" * 70)
for r in results:
    q = r.sample.question[:38] + "..."
    print(f"{q:<40} {r.faithfulness:>6.3f} {r.answer_relevancy:>6.3f} {r.context_precision:>6.3f} {r.overall:>8.3f}")

print()
avg_faithful = sum(r.faithfulness for r in results) / len(results)
avg_relevancy = sum(r.answer_relevancy for r in results) / len(results)
avg_precision = sum(r.context_precision for r in results) / len(results)
print(f"{'AVERAGES':<40} {avg_faithful:>6.3f} {avg_relevancy:>6.3f} {avg_precision:>6.3f} {(avg_faithful+avg_relevancy+avg_precision)/3:>8.3f}")</cell id="cell-2">
<cell id="cell-3"><cell_type>markdown</cell_type>## 2. Hallucination Detection</cell id="cell-3">
<cell id="cell-4">def detect_hallucination(answer: str, context: list[str]) -> dict:
    """
    Simple hallucination detector using atomic fact checking.
    In production: use an NLI model or LLM-as-judge.
    """
    # Split answer into atomic claims (simplified)
    claims = [s.strip() for s in answer.split(".") if len(s.strip()) > 20]
    combined_context = " ".join(context).lower()

    analysis = []
    for claim in claims:
        key_nouns = [w for w in claim.lower().split() if len(w) > 5 and w.isalpha()]
        supported_count = sum(1 for w in key_nouns if w in combined_context)
        support_ratio = supported_count / len(key_nouns) if key_nouns else 1.0

        analysis.append({
            "claim": claim,
            "support_ratio": round(support_ratio, 2),
            "is_hallucination": support_ratio < 0.3,
        })

    hallucinated = [a for a in analysis if a["is_hallucination"]]
    return {
        "total_claims": len(claims),
        "hallucinated_claims": len(hallucinated),
        "hallucination_rate": round(len(hallucinated) / len(claims) if claims else 0, 2),
        "details": analysis,
    }

# Test hallucination detection
test_cases = [
    {
        "answer": "RAG retrieves documents using embedding similarity. Vector databases store these embeddings efficiently.",
        "context": [
            "RAG uses embedding similarity to retrieve relevant documents.",
            "Vector databases like Pinecone and Qdrant store embeddings.",
        ],
    },
    {
        "answer": "The Eiffel Tower was built in 1889. It is located in Paris and is 330 meters tall. The tower hosts over 7 million visitors annually.",
        "context": [
            "RAG is a framework for grounding LLM responses in retrieved documents.",
            "Chunking splits documents into pieces for vector indexing.",
        ],
    },
]

for i, case in enumerate(test_cases, 1):
    result = detect_hallucination(case["answer"], case["context"])
    print(f"Test {i}:")
    print(f"  Hallucination rate: {result['hallucination_rate']:.0%}")
    print(f"  Claims: {result['total_claims']}, Hallucinated: {result['hallucinated_claims']}")
    for detail in result["details"]:
        flag = "HALLUCINATED" if detail["is_hallucination"] else "OK"
        print(f"  [{flag}] ({detail['support_ratio']:.0%} support) {detail['claim'][:70]}")
    print()</cell id="cell-4">
<cell id="cell-5"><cell_type>markdown</cell_type>## 3. Regression Testing Framework</cell id="cell-5">
<cell id="cell-6">class RAGRegressionSuite:
    """Run evals and detect regressions against a baseline."""

    def __init__(self, baseline: dict, tolerance: float = 0.03):
        self.baseline = baseline
        self.tolerance = tolerance

    def run(self, samples: list[EvalSample]) -> dict:
        results = [evaluate_sample(s) for s in samples]

        current = {
            "faithfulness": sum(r.faithfulness for r in results) / len(results),
            "answer_relevancy": sum(r.answer_relevancy for r in results) / len(results),
            "context_precision": sum(r.context_precision for r in results) / len(results),
            "overall": sum(r.overall for r in results) / len(results),
        }

        regressions = []
        improvements = []
        for metric, baseline_score in self.baseline.items():
            if metric not in current:
                continue
            delta = current[metric] - baseline_score
            if delta < -self.tolerance:
                regressions.append({
                    "metric": metric,
                    "baseline": baseline_score,
                    "current": current[metric],
                    "delta": delta,
                })
            elif delta > self.tolerance:
                improvements.append({
                    "metric": metric,
                    "baseline": baseline_score,
                    "current": current[metric],
                    "delta": delta,
                })

        return {
            "passed": len(regressions) == 0,
            "current_scores": current,
            "baseline_scores": self.baseline,
            "regressions": regressions,
            "improvements": improvements,
        }

    def report(self, result: dict) -> None:
        status = "PASSED" if result["passed"] else "FAILED"
        print(f"Regression Test: {status}")
        print()
        print(f"{'Metric':<22} {'Baseline':>9} {'Current':>9} {'Delta':>8} {'Status'}")
        print("-" * 60)
        for metric in result["baseline_scores"]:
            if metric not in result["current_scores"]:
                continue
            b = result["baseline_scores"][metric]
            c = result["current_scores"].get(metric, 0)
            delta = c - b
            status_icon = "OK" if abs(delta) <= self.tolerance else ("IMPROVED" if delta > 0 else "REGRESSED")
            print(f"{metric:<22} {b:>9.3f} {c:>9.3f} {delta:>+8.3f}  {status_icon}")

        if result["regressions"]:
            print()
            print("REGRESSIONS DETECTED:")
            for r in result["regressions"]:
                print(f"  - {r['metric']}: {r['baseline']:.3f} → {r['current']:.3f} ({r['delta']:+.3f})")

# Set a baseline and run regression check
baseline = {
    "faithfulness": 0.70,
    "answer_relevancy": 0.60,
    "context_precision": 0.67,
    "overall": 0.65,
}

suite = RAGRegressionSuite(baseline=baseline, tolerance=0.05)
result = suite.run(samples)
suite.report(result)</cell id="cell-6">
