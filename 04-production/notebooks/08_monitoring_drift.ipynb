# ── Cell 3: Model Performance Tracker (with Delayed Labels) ───────────────────

@dataclass
class Prediction:
    pred_id: str
    model_version: str
    timestamp: float
    features: dict
    score: float
    predicted_class: int

@dataclass
class GroundTruth:
    pred_id: str
    label: int
    label_timestamp: float

class PerformanceTracker:
    """Buffers predictions and joins with delayed ground truth labels."""

    def __init__(self, label_lag_days: float = 30.0):
        self.label_lag_s = label_lag_days * 86400
        self._predictions: Dict[str, Prediction] = {}
        self._labels: Dict[str, GroundTruth] = {}
        self._evaluated: List[dict] = []

    def log_prediction(self, pred: Prediction) -> None:
        self._predictions[pred.pred_id] = pred

    def log_label(self, gt: GroundTruth) -> None:
        self._labels[gt.pred_id] = gt
        # Check if we can now evaluate
        if gt.pred_id in self._predictions:
            self._evaluate_pair(gt.pred_id)

    def _evaluate_pair(self, pred_id: str) -> None:
        pred = self._predictions[pred_id]
        gt   = self._labels[pred_id]
        self._evaluated.append({
            "pred_id": pred_id,
            "model_version": pred.model_version,
            "correct": pred.predicted_class == gt.label,
            "lag_days": (gt.label_timestamp - pred.timestamp) / 86400,
        })

    def metrics_by_version(self) -> Dict[str, dict]:
        by_ver: Dict[str, list] = defaultdict(list)
        for e in self._evaluated:
            by_ver[e["model_version"]].append(e["correct"])
        return {ver: {"accuracy": sum(c)/len(c), "n": len(c)}
                for ver, c in by_ver.items()}

    def confidence_distribution(self) -> dict:
        """Proxy metric when labels unavailable."""
        scores = [p.score for p in self._predictions.values()]
        if not scores: return {}
        mean_conf = sum(scores) / len(scores)
        entropy = -sum(
            p * math.log(max(p, 1e-9)) + (1-p) * math.log(max(1-p, 1e-9))
            for p in scores
        ) / len(scores)
        return {"mean_confidence": mean_conf, "mean_entropy": entropy, "n_predictions": len(scores)}

tracker = PerformanceTracker(label_lag_days=7)
random.seed(5)
base_ts = time.time() - 86400 * 14  # 14 days ago

# Simulate predictions from two model versions
for i in range(100):
    ver = "v1.0" if i < 50 else "v2.0"
    score = random.gauss(0.7 if ver == "v1.0" else 0.8, 0.15)
    score = max(0.01, min(0.99, score))
    pred = Prediction(f"p{i:04d}", ver, base_ts + i*3600, {"f1": i},
                      score, 1 if score > 0.5 else 0)
    tracker.log_prediction(pred)

# Labels arrive ~7 days later with some randomness
for i in range(100):
    true_label = 1 if random.random() < (0.65 if i < 50 else 0.78) else 0
    gt = GroundTruth(f"p{i:04d}", true_label, base_ts + i*3600 + 7*86400)
    tracker.log_label(gt)

metrics = tracker.metrics_by_version()
conf = tracker.confidence_distribution()
print("Delayed Label Performance Tracking:")
for ver, m in metrics.items():
    print(f"  {ver}: accuracy={m['accuracy']:.2%}  n={m['n']}")
print(f"\nConfidence Proxy Metrics (all versions):")
for k, v in conf.items():
    print(f"  {k}: {v:.4f}" if isinstance(v, float) else f"  {k}: {v}")
