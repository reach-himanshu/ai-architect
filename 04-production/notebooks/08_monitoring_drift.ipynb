# ── Cell 2: KS-Style Distribution Comparison ──────────────────────────────────

def ks_statistic(sample1: List[float], sample2: List[float]) -> float:
    """
    Two-sample Kolmogorov-Smirnov D-statistic.
    Measures max distance between empirical CDFs.
    D < 0.1 → no significant difference.
    D > 0.2 → significant drift.
    """
    combined = sorted(set(sample1 + sample2))
    n1, n2 = len(sample1), len(sample2)
    s1_sorted = sorted(sample1)
    s2_sorted = sorted(sample2)

    import bisect
    max_diff = 0.0
    for x in combined:
        cdf1 = bisect.bisect_right(s1_sorted, x) / n1
        cdf2 = bisect.bisect_right(s2_sorted, x) / n2
        max_diff = max(max_diff, abs(cdf1 - cdf2))
    return max_diff

def js_divergence(p: List[float], q: List[float], n_bins: int = 20) -> float:
    """Jensen-Shannon divergence (0=identical, 1=completely different)."""
    all_v = p + q
    mn, mx = min(all_v), max(all_v)
    bw = (mx - mn) / n_bins

    def hist(vals):
        c = [0]*n_bins
        for v in vals:
            idx = min(int((v-mn)/bw), n_bins-1)
            c[idx] += 1
        n = max(sum(c), 1)
        return [x/n for x in c]

    ph, qh = hist(p), hist(q)
    mh = [(pi+qi)/2 for pi, qi in zip(ph, qh)]

    def kl(a, b):
        return sum(ai * math.log(ai/bi) for ai, bi in zip(a, b) if ai > 0 and bi > 0)

    return (kl(ph, mh) + kl(qh, mh)) / 2

random.seed(7)
ref_dist = [random.gauss(100, 15) for _ in range(1000)]

print("Distribution Comparison Tests:")
print(f"{'Scenario':<30} {'KS Stat':>8} {'JS Div':>8}  {'Assessment'}")
print("-"*65)
for name, mu, sigma in [
    ("Identical distribution",  100, 15),
    ("Slight mean shift (+10)", 110, 15),
    ("Large mean shift (+30)",  130, 15),
    ("Variance change (×2)",    100, 30),
    ("Completely different",    160, 5),
]:
    curr = [random.gauss(mu, sigma) for _ in range(500)]
    ks = ks_statistic(ref_dist, curr)
    js = js_divergence(ref_dist, curr)
    assess = "✓ Stable" if ks < 0.1 else ("⚠ Monitor" if ks < 0.2 else "✗ Significant")
    print(f"  {name:<28} {ks:>8.4f} {js:>8.4f}  {assess}")
