# ── Cell 4: Layered Alerting System ───────────────────────────────────────────
from enum import Enum

class AlertSeverity(Enum):
    INFO = "INFO"
    WARNING = "WARNING"
    CRITICAL = "CRITICAL"

@dataclass
class AlertRule:
    name: str
    check: callable
    severity: AlertSeverity
    cooldown_s: float = 300  # don't re-alert within this window
    consecutive_required: int = 1  # require N consecutive violations

@dataclass
class Alert:
    rule_name: str
    severity: AlertSeverity
    message: str
    timestamp: float

class AlertManager:
    def __init__(self, rules: List[AlertRule]):
        self.rules = rules
        self._last_alert: Dict[str, float] = {}
        self._consecutive: Dict[str, int] = defaultdict(int)
        self.fired: List[Alert] = []

    def evaluate(self, metrics: dict, current_time: float = None) -> List[Alert]:
        now = current_time or time.time()
        new_alerts = []
        for rule in self.rules:
            violated, msg = rule.check(metrics)
            if violated:
                self._consecutive[rule.name] += 1
            else:
                self._consecutive[rule.name] = 0

            if (violated and
                self._consecutive[rule.name] >= rule.consecutive_required and
                now - self._last_alert.get(rule.name, 0) > rule.cooldown_s):
                alert = Alert(rule.name, rule.severity, msg, now)
                self.fired.append(alert)
                new_alerts.append(alert)
                self._last_alert[rule.name] = now

        return new_alerts

def make_alert_manager() -> AlertManager:
    return AlertManager([
        AlertRule("Error Rate",
                  lambda m: (m.get("error_rate",0) > 0.05,
                             f"Error rate {m.get('error_rate',0):.1%} > 5%"),
                  AlertSeverity.CRITICAL, cooldown_s=60, consecutive_required=1),
        AlertRule("Latency P99",
                  lambda m: (m.get("latency_p99",0) > 500,
                             f"p99 latency {m.get('latency_p99',0)}ms > 500ms"),
                  AlertSeverity.WARNING, cooldown_s=300, consecutive_required=2),
        AlertRule("PSI Drift",
                  lambda m: (m.get("psi_max",0) > 0.2,
                             f"PSI {m.get('psi_max',0):.3f} > 0.2 — data drift detected"),
                  AlertSeverity.WARNING, cooldown_s=3600, consecutive_required=2),
        AlertRule("Accuracy Drop",
                  lambda m: (m.get("accuracy_delta",0) < -0.05,
                             f"Accuracy dropped {m.get('accuracy_delta',0):.1%} from baseline"),
                  AlertSeverity.CRITICAL, cooldown_s=3600, consecutive_required=1),
    ])

am = make_alert_manager()
now = time.time()

hourly_metrics = [
    {"hour": 0, "error_rate": 0.01, "latency_p99": 180, "psi_max": 0.05, "accuracy_delta": -0.01},
    {"hour": 1, "error_rate": 0.02, "latency_p99": 520, "psi_max": 0.08, "accuracy_delta": -0.02},
    {"hour": 2, "error_rate": 0.01, "latency_p99": 550, "psi_max": 0.09, "accuracy_delta": -0.02},
    {"hour": 3, "error_rate": 0.08, "latency_p99": 300, "psi_max": 0.25, "accuracy_delta": -0.07},
    {"hour": 4, "error_rate": 0.03, "latency_p99": 200, "psi_max": 0.28, "accuracy_delta": -0.03},
]

print("Layered Alerting System:")
for m in hourly_metrics:
    hour = m.pop("hour")
    alerts = am.evaluate(m, current_time=now + hour*3600)
    if alerts:
        for a in alerts:
            print(f"  Hour {hour}: [{a.severity.value}] {a.rule_name} — {a.message}")
    else:
        print(f"  Hour {hour}: ✓ No alerts")
