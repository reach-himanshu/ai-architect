# ── Cell 1: PSI Drift Detector ────────────────────────────────────────────────
import random, math, time
from dataclasses import dataclass, field
from typing import List, Dict, Optional, Tuple
from collections import defaultdict

def compute_psi(baseline: List[float], current: List[float], n_bins: int = 10) -> float:
    """Population Stability Index between two continuous distributions."""
    all_vals = baseline + current
    min_v, max_v = min(all_vals), max(all_vals)
    bin_w = (max_v - min_v) / n_bins

    def bin_dist(vals: List[float]) -> List[float]:
        counts = [0] * n_bins
        for v in vals:
            idx = min(int((v - min_v) / bin_w), n_bins - 1)
            counts[idx] += 1
        n = max(len(vals), 1)
        return [max(c / n, 1e-6) for c in counts]

    base_dist = bin_dist(baseline)
    curr_dist = bin_dist(current)
    return sum((c - e) * math.log(c / e) for e, c in zip(base_dist, curr_dist))

def compute_psi_categorical(baseline: List[str], current: List[str]) -> float:
    """PSI for categorical features."""
    all_cats = set(baseline) | set(current)
    n_b, n_c = max(len(baseline), 1), max(len(current), 1)
    psi = 0.0
    for cat in all_cats:
        e = max(baseline.count(cat) / n_b, 1e-6)
        a = max(current.count(cat) / n_c, 1e-6)
        psi += (a - e) * math.log(a / e)
    return psi

def psi_label(psi: float) -> str:
    if psi < 0.1: return "✓ Stable"
    if psi < 0.2: return "⚠ Monitor"
    return "✗ Retrain"

random.seed(42)
baseline_age = [random.gauss(35, 10) for _ in range(2000)]
baseline_status = random.choices(["active","inactive","trial"], weights=[6,3,1], k=2000)

# Simulated production distributions at different drift levels
scenarios = {
    "No drift":      ([random.gauss(35, 10) for _ in range(500)],
                      random.choices(["active","inactive","trial"], weights=[6,3,1], k=500)),
    "Mild drift":    ([random.gauss(40, 10) for _ in range(500)],
                      random.choices(["active","inactive","trial"], weights=[5,3,2], k=500)),
    "Severe drift":  ([random.gauss(55, 12) for _ in range(500)],
                      random.choices(["active","inactive","trial"], weights=[3,5,2], k=500)),
}

print(f"{'Scenario':<20} {'PSI(age)':>10} {'PSI(status)':>12}  {'Label'}")
print("-" * 60)
for name, (curr_age, curr_status) in scenarios.items():
    psi_age = compute_psi(baseline_age, curr_age)
    psi_cat = compute_psi_categorical(baseline_status, curr_status)
    label = psi_label(max(psi_age, psi_cat))
    print(f"  {name:<18} {psi_age:>10.4f} {psi_cat:>12.4f}  {label}")
