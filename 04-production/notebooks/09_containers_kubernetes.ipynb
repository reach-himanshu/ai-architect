# ── Cell 4: KEDA-Style Queue-Based Autoscaler ─────────────────────────────────

class InferenceQueue:
    """Simulates a message queue for batch inference requests."""
    def __init__(self):
        self._queue: list = []

    def enqueue_batch(self, n: int) -> None:
        for i in range(n):
            self._queue.append({"request_id": f"r{time.time_ns()}"})

    def dequeue(self, n: int) -> list:
        batch = self._queue[:n]
        self._queue = self._queue[n:]
        return batch

    @property
    def depth(self) -> int:
        return len(self._queue)

class KEDAScaler:
    """
    Queue-depth based autoscaler (inspired by KEDA).
    Target: each pod should process ~target_queue_per_pod items.
    """
    def __init__(self, min_replicas: int = 1, max_replicas: int = 20,
                 target_queue_per_pod: int = 50):
        self.min_replicas = min_replicas
        self.max_replicas = max_replicas
        self.target_per_pod = target_queue_per_pod
        self.current_replicas = min_replicas

    def scale(self, queue_depth: int) -> int:
        if queue_depth == 0:
            self.current_replicas = self.min_replicas
        else:
            desired = math.ceil(queue_depth / self.target_per_pod)
            self.current_replicas = max(self.min_replicas, min(self.max_replicas, desired))
        return self.current_replicas

random.seed(42)
queue = InferenceQueue()
scaler = KEDAScaler(min_replicas=1, max_replicas=10, target_queue_per_pod=50)
THROUGHPUT_PER_POD = 30  # requests processed per pod per tick

print("KEDA Queue-Based Autoscaler Simulation:")
print(f"  {'Tick':>4}  {'Enqueued':>9}  {'Queue Depth':>12}  {'Pods':>5}  {'Processed':>10}")

for tick in range(15):
    # Variable incoming load
    new_requests = random.choice([0, 0, 20, 50, 100, 150, 200, 30, 10])
    queue.enqueue_batch(new_requests)

    # Scale based on current depth
    pods = scaler.scale(queue.depth)

    # Process with current pod count
    processed = queue.dequeue(pods * THROUGHPUT_PER_POD)

    print(f"  {tick:>4}  {new_requests:>9}  {queue.depth:>12}  {pods:>5}  {len(processed):>10}")

print(f"\nFinal queue depth: {queue.depth}")
print(f"Final pod count:   {scaler.current_replicas}")
