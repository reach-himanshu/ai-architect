# ── Cell 2: Kubernetes Rolling Update Simulator ───────────────────────────────

@dataclass
class Pod:
    pod_id: str
    version: str
    status: str = "Running"     # Running, Terminating, Pending, Ready
    health_check_passes: bool = True

class KubernetesDeployment:
    """Simulates a K8s rolling update with maxSurge/maxUnavailable."""

    def __init__(self, name: str, desired_replicas: int,
                 max_surge: int = 1, max_unavailable: int = 0):
        self.name = name
        self.desired = desired_replicas
        self.max_surge = max_surge
        self.max_unavailable = max_unavailable
        self.pods: List[Pod] = []
        self._pod_counter = 0

    def _new_pod(self, version: str) -> Pod:
        self._pod_counter += 1
        return Pod(f"{self.name}-{self._pod_counter:04d}", version)

    def initialize(self, version: str) -> None:
        self.pods = [self._new_pod(version) for _ in range(self.desired)]
        print(f"Deployment '{self.name}' initialized: {self.desired}×{version}")

    def rolling_update(self, new_version: str, readiness_delay_steps: int = 1) -> None:
        old_version = self.pods[0].version if self.pods else "unknown"
        print(f"\nRolling update: {old_version} → {new_version}")
        print(f"  Strategy: maxSurge={self.max_surge}, maxUnavailable={self.max_unavailable}")

        old_pods = list(self.pods)
        idx = 0
        step = 0

        while idx < len(old_pods):
            step += 1
            # How many we can add (surge capacity)
            current_total = len(self.pods)
            max_total = self.desired + self.max_surge
            can_add = max_total - current_total

            # Add new pods (surge)
            added = 0
            for _ in range(min(can_add, 1)):
                new_pod = self._new_pod(new_version)
                new_pod.status = "Pending"
                self.pods.append(new_pod)
                added += 1

            # Simulate readiness probe passing
            for p in self.pods:
                if p.status == "Pending":
                    p.status = "Ready"

            # Terminate old pod
            old_pod = old_pods[idx]
            old_pod.status = "Terminating"
            self.pods = [p for p in self.pods if p.pod_id != old_pod.pod_id]
            idx += 1

            running_new = sum(1 for p in self.pods if p.version == new_version)
            running_old = sum(1 for p in self.pods if p.version == old_version)
            print(f"  Step {step}: total={len(self.pods)}  "
                  f"new={running_new}  old={running_old}  ✓")

        print(f"  Rolling update complete. All pods at {new_version}.")

deploy = KubernetesDeployment("churn-model", desired_replicas=4, max_surge=1, max_unavailable=0)
deploy.initialize("v1.0")
deploy.rolling_update("v2.0")
