# ── Cell 1: Docker Layer Cache Analyser ──────────────────────────────────────
import random, time, math, hashlib
from dataclasses import dataclass, field
from typing import List, Dict, Optional, Tuple
from collections import defaultdict

@dataclass
class DockerLayer:
    instruction: str
    content_hash: str
    size_mb: float
    cached: bool = False

class DockerImageBuilder:
    """Simulates Docker layer-by-layer build with caching."""

    def __init__(self):
        self._layer_cache: Dict[str, DockerLayer] = {}

    def _hash(self, instruction: str, content: str) -> str:
        return hashlib.sha256(f"{instruction}:{content}".encode()).hexdigest()[:16]

    def build(self, dockerfile_steps: List[Tuple[str, str, float]]) -> List[DockerLayer]:
        """
        dockerfile_steps: [(instruction, content_hash, size_mb), ...]
        Returns list of layers with cache hit/miss info.
        """
        layers = []
        cache_valid = True  # once a layer misses, all subsequent are misses

        for instruction, content, size_mb in dockerfile_steps:
            key = self._hash(instruction, content)

            if cache_valid and key in self._layer_cache:
                layer = DockerLayer(instruction, key, size_mb, cached=True)
            else:
                cache_valid = False  # invalidate cache from here on
                layer = DockerLayer(instruction, key, size_mb, cached=False)
                self._layer_cache[key] = layer

            layers.append(layer)

        return layers

    def report(self, layers: List[DockerLayer]) -> None:
        total_mb = sum(l.size_mb for l in layers)
        rebuilt_mb = sum(l.size_mb for l in layers if not l.cached)
        cached_mb  = sum(l.size_mb for l in layers if l.cached)
        print(f"  {'Instruction':<30} {'Size':>6}  {'Cache'}")
        print(f"  {'-'*50}")
        for l in layers:
            status = "HIT ✓" if l.cached else "MISS ✗"
            print(f"  {l.instruction:<30} {l.size_mb:>5.0f}MB  {status}")
        print(f"  {'-'*50}")
        print(f"  Total: {total_mb:.0f}MB  |  Cached: {cached_mb:.0f}MB  |  Rebuilt: {rebuilt_mb:.0f}MB")
        print(f"  Cache efficiency: {cached_mb/total_mb:.0%}")

builder = DockerImageBuilder()

# Bad order: COPY src first, then pip install → code change busts deps cache
bad_order = [
    ("FROM",    "python:3.11-slim", 150),
    ("WORKDIR", "/app",              0),
    ("COPY",    "src_v1",           5),    # code (changes often)
    ("RUN",     "pip install",      400),  # expensive — busted by code change
    ("EXPOSE",  "8080",             0),
    ("CMD",     "python serve.py",  0),
]
# Good order: pip install first, then COPY src
good_order = [
    ("FROM",        "python:3.11-slim",    150),
    ("WORKDIR",     "/app",                 0),
    ("COPY",        "requirements.txt",     0),
    ("RUN",         "pip install",         400),  # cached if requirements unchanged
    ("COPY",        "src_v1",               5),   # code change only busts this layer
    ("EXPOSE",      "8080",                 0),
    ("CMD",         "python serve.py",      0),
]

# First build (cold cache)
print("=== First Build (cold cache) ===")
layers_first = builder.build(good_order)
builder.report(layers_first)

# Second build with code change
good_order_v2 = good_order.copy()
good_order_v2[4] = ("COPY", "src_v2", 5)  # code changed

print("\n=== Second Build (code change only) ===")
layers_second = builder.build(good_order_v2)
builder.report(layers_second)
