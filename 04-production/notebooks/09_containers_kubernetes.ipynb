# ── Cell 3: Horizontal Pod Autoscaler Simulation ──────────────────────────────

class HorizontalPodAutoscaler:
    """
    Simulates K8s HPA logic: scale up when metric > target, scale down when < target.
    """

    def __init__(self, deployment_name: str,
                 min_replicas: int = 2, max_replicas: int = 20,
                 target_cpu_pct: float = 70.0,
                 scale_down_cooldown_s: float = 300,
                 scale_up_cooldown_s: float = 60):
        self.deployment_name = deployment_name
        self.min_replicas = min_replicas
        self.max_replicas = max_replicas
        self.target_cpu = target_cpu_pct
        self.scale_down_cooldown = scale_down_cooldown_s
        self.scale_up_cooldown = scale_up_cooldown_s
        self.current_replicas = min_replicas
        self._last_scale_up = 0.0
        self._last_scale_down = 0.0

    def compute_desired(self, current_cpu: float) -> int:
        """K8s HPA formula: ceil(current * actual/target)"""
        ratio = current_cpu / self.target_cpu
        return max(self.min_replicas, min(self.max_replicas,
               math.ceil(self.current_replicas * ratio)))

    def reconcile(self, current_cpu: float, now: float = None) -> dict:
        now = now or time.time()
        desired = self.compute_desired(current_cpu)
        action = "none"

        if desired > self.current_replicas:
            if now - self._last_scale_up >= self.scale_up_cooldown:
                self.current_replicas = desired
                self._last_scale_up = now
                action = "scale_up"
        elif desired < self.current_replicas:
            if now - self._last_scale_down >= self.scale_down_cooldown:
                self.current_replicas = desired
                self._last_scale_down = now
                action = "scale_down"

        return {"replicas": self.current_replicas, "cpu": current_cpu,
                "desired": desired, "action": action}

hpa = HorizontalPodAutoscaler("inference-server", min_replicas=2, max_replicas=16,
                               target_cpu_pct=70, scale_down_cooldown_s=300)

# Simulate traffic pattern: ramp up, peak, ramp down
cpu_profile = (
    [30, 35, 40, 55, 70, 85, 95, 100, 105, 110] +  # ramp up
    [95, 90, 85, 80, 75, 70, 60, 50, 40, 30]         # ramp down
)

print(f"HPA Simulation ({hpa.deployment_name}):")
print(f"  target={hpa.target_cpu}%  min={hpa.min_replicas}  max={hpa.max_replicas}")
print(f"  {'Step':>4}  {'CPU%':>5}  {'Replicas':>9}  {'Action'}")
now_sim = time.time()

for step, cpu in enumerate(cpu_profile):
    result = hpa.reconcile(cpu, now=now_sim + step * 90)  # 90s between steps
    action_str = f"→ {result['action']}" if result["action"] != "none" else ""
    print(f"  {step:>4}  {cpu:>5}%  {result['replicas']:>9}  {action_str}")
