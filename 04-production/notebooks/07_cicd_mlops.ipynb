# ── Cell 1: ML Pipeline with Evaluation Gates ────────────────────────────────
import random, time, math
from dataclasses import dataclass, field
from typing import Dict, List, Optional, Callable, Any
from enum import Enum

class ModelStatus(Enum):
    STAGING = "staging"
    PRODUCTION = "production"
    ARCHIVED = "archived"
    REJECTED = "rejected"

@dataclass
class ModelVersion:
    model_id: str
    version: str
    git_sha: str
    dataset_version: str
    hyperparams: dict
    metrics: Dict[str, float] = field(default_factory=dict)
    status: ModelStatus = ModelStatus.STAGING
    created_at: float = field(default_factory=time.time)

@dataclass
class EvaluationGate:
    name: str
    metric: str
    threshold: float
    op: str = "gte"  # gte, lte, gt, lt

    def check(self, metrics: Dict[str, float]) -> tuple:
        val = metrics.get(self.metric)
        if val is None:
            return False, f"metric '{self.metric}' not found"
        ops = {"gte": val >= self.threshold, "lte": val <= self.threshold,
               "gt": val > self.threshold, "lt": val < self.threshold}
        passed = ops[self.op]
        return passed, f"{self.metric}={val:.4f} {'≥' if self.op=='gte' else '≤'} {self.threshold} → {'✓' if passed else '✗'}"

class MLPipeline:
    def __init__(self, gates: List[EvaluationGate]):
        self.gates = gates
        self.registry: List[ModelVersion] = []

    def register(self, model: ModelVersion) -> None:
        self.registry.append(model)

    def evaluate(self, model: ModelVersion) -> bool:
        print(f"\n  Evaluating {model.model_id} v{model.version}:")
        all_passed = True
        for gate in self.gates:
            passed, msg = gate.check(model.metrics)
            print(f"    [{gate.name}] {msg}")
            if not passed:
                all_passed = False
        return all_passed

    def promote(self, model: ModelVersion) -> bool:
        passed = self.evaluate(model)
        if passed:
            # Archive current production model
            for m in self.registry:
                if m.status == ModelStatus.PRODUCTION:
                    m.status = ModelStatus.ARCHIVED
            model.status = ModelStatus.PRODUCTION
            print(f"  → PROMOTED to production ✓")
        else:
            model.status = ModelStatus.REJECTED
            print(f"  → REJECTED ✗")
        return passed

# Demo
gates = [
    EvaluationGate("Precision Gate",    "precision",    0.85),
    EvaluationGate("Recall Gate",       "recall",       0.80),
    EvaluationGate("Latency Gate",      "latency_p99",  200, op="lte"),
    EvaluationGate("AUC Gate",          "auc",          0.88),
]
pipeline = MLPipeline(gates)

random.seed(42)
for i, (prec, rec, auc, lat) in enumerate([
    (0.87, 0.82, 0.91, 180),  # passes all
    (0.83, 0.85, 0.90, 150),  # fails precision
    (0.90, 0.88, 0.93, 210),  # fails latency
]):
    model = ModelVersion(
        model_id="churn-predictor", version=f"1.{i}",
        git_sha=f"abc{i}def", dataset_version="v3.2",
        hyperparams={"lr": 0.001, "epochs": 10},
        metrics={"precision": prec, "recall": rec, "auc": auc, "latency_p99": lat},
    )
    pipeline.register(model)
    pipeline.promote(model)
    print()

prod = next((m for m in pipeline.registry if m.status == ModelStatus.PRODUCTION), None)
print(f"Production model: {prod.version if prod else 'None'}")
