# ── Cell 3: Canary Rollout Controller ─────────────────────────────────────────

@dataclass
class TrafficSplit:
    champion_pct: float
    canary_pct: float

class CanaryController:
    """
    Gradually shifts traffic from champion to canary.
    Rolls back automatically if error rate exceeds threshold.
    """

    STAGES = [5.0, 20.0, 50.0, 100.0]

    def __init__(self, error_rate_threshold: float = 0.05):
        self.error_rate_threshold = error_rate_threshold
        self.current_stage_idx = 0
        self.traffic = TrafficSplit(100.0, 0.0)
        self.stage_metrics: List[dict] = []
        self.rolled_back = False

    def _route(self, rng: float) -> str:
        return "canary" if rng < self.traffic.canary_pct / 100 else "champion"

    def simulate_stage(self, n_requests: int = 1000,
                       canary_error_rate: float = 0.02,
                       champion_error_rate: float = 0.01) -> dict:
        """Simulate requests at current traffic split and return metrics."""
        errors = {"canary": 0, "champion": 0, "total_canary": 0, "total_champion": 0}
        rng = random.Random(self.current_stage_idx)
        for _ in range(n_requests):
            r = rng.random()
            model = self._route(rng.random() * 100 / 100)
            err_rate = canary_error_rate if model == "canary" else champion_error_rate
            errors[f"total_{model}"] += 1
            if rng.random() < err_rate:
                errors[model] += 1

        canary_err = (errors["canary"] / max(errors["total_canary"], 1))
        champ_err  = (errors["champion"] / max(errors["total_champion"], 1))
        return {"canary_error_rate": canary_err, "champion_error_rate": champ_err,
                "stage_pct": self.traffic.canary_pct}

    def advance(self, metrics: dict) -> str:
        canary_err = metrics["canary_error_rate"]
        if canary_err > self.error_rate_threshold:
            self.traffic = TrafficSplit(100.0, 0.0)
            self.rolled_back = True
            return f"ROLLBACK — canary error {canary_err:.1%} > threshold {self.error_rate_threshold:.1%}"

        self.current_stage_idx += 1
        if self.current_stage_idx >= len(self.STAGES):
            self.traffic = TrafficSplit(0.0, 100.0)
            return "COMPLETE — 100% canary"

        pct = self.STAGES[self.current_stage_idx]
        self.traffic = TrafficSplit(100-pct, pct)
        return f"ADVANCED to {pct}% canary"

random.seed(10)
controller = CanaryController(error_rate_threshold=0.05)

print("Canary Rollout:")
controller.traffic = TrafficSplit(95.0, 5.0)

for stage_pct in [5.0, 20.0, 50.0, 100.0]:
    controller.traffic = TrafficSplit(100-stage_pct, stage_pct)
    metrics = controller.simulate_stage(1000, canary_error_rate=0.02)
    status = controller.advance(metrics)
    print(f"  Stage {stage_pct:>5.0f}% canary: err={metrics['canary_error_rate']:.1%}  → {status}")
    if controller.rolled_back:
        break
