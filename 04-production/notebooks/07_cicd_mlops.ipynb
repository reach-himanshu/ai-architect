# ── Cell 2: Champion/Challenger Framework ─────────────────────────────────────

class ChampionChallenger:
    """
    Runs new (challenger) model against production (champion).
    Challenger promoted only if it beats champion by ≥ min_improvement.
    """

    def __init__(self, primary_metric: str, min_improvement: float = 0.01):
        self.primary_metric = primary_metric
        self.min_improvement = min_improvement
        self.champion: Optional[ModelVersion] = None
        self.history: List[dict] = []

    def set_champion(self, model: ModelVersion) -> None:
        self.champion = model
        print(f"  Champion: {model.model_id} v{model.version}  "
              f"{self.primary_metric}={model.metrics.get(self.primary_metric, 0):.4f}")

    def evaluate_challenger(self, challenger: ModelVersion) -> bool:
        if not self.champion:
            self.set_champion(challenger)
            return True

        champ_metric = self.champion.metrics.get(self.primary_metric, 0)
        chal_metric  = challenger.metrics.get(self.primary_metric, 0)
        improvement  = (chal_metric - champ_metric) / max(abs(champ_metric), 1e-9)

        result = {
            "challenger": challenger.version,
            "champion_metric": champ_metric,
            "challenger_metric": chal_metric,
            "improvement": improvement,
            "promoted": improvement >= self.min_improvement,
        }
        self.history.append(result)

        print(f"\n  Challenger v{challenger.version}: "
              f"{self.primary_metric}={chal_metric:.4f}  "
              f"improvement={improvement:+.2%}  "
              f"threshold={self.min_improvement:.0%}")

        if improvement >= self.min_improvement:
            old_champ = self.champion.version
            self.champion = challenger
            print(f"  → PROMOTED: v{old_champ} → v{challenger.version} ✓")
            return True
        else:
            print(f"  → REJECTED: improvement below threshold ✗")
            return False

cc = ChampionChallenger(primary_metric="auc", min_improvement=0.01)

models_seq = [
    ModelVersion("fraud-detector", "2.0", "sha_v2", "v5", {},
                 metrics={"auc": 0.920, "precision": 0.88}),
    ModelVersion("fraud-detector", "2.1", "sha_v21", "v5", {},
                 metrics={"auc": 0.928, "precision": 0.89}),   # +0.87% < 1%
    ModelVersion("fraud-detector", "2.2", "sha_v22", "v6", {},
                 metrics={"auc": 0.935, "precision": 0.90}),   # +0.75% < 1% from new champ
    ModelVersion("fraud-detector", "3.0", "sha_v30", "v7", {},
                 metrics={"auc": 0.950, "precision": 0.91}),   # +1.6% ✓
]

print("Champion/Challenger Evaluation:")
cc.set_champion(models_seq[0])
for challenger in models_seq[1:]:
    cc.evaluate_challenger(challenger)

print(f"\nFinal champion: {cc.champion.version}")
