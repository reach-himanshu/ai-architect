# ── Cell 4: Automated Retraining Trigger System ───────────────────────────────

@dataclass
class RetrainingTrigger:
    name: str
    check: Callable[[dict], bool]
    priority: int = 1   # higher = more urgent

class RetrainingScheduler:
    def __init__(self, triggers: List[RetrainingTrigger]):
        self.triggers = sorted(triggers, key=lambda t: -t.priority)
        self.history: List[dict] = []

    def evaluate(self, signals: dict) -> Optional[RetrainingTrigger]:
        """Return the highest-priority trigger that fired, or None."""
        for trigger in self.triggers:
            if trigger.check(signals):
                self.history.append({
                    "trigger": trigger.name,
                    "signals": signals,
                    "timestamp": time.time(),
                })
                return trigger
        return None

def make_scheduler() -> RetrainingScheduler:
    return RetrainingScheduler([
        RetrainingTrigger(
            "Data Drift (PSI)",
            lambda s: s.get("psi_max_feature", 0) > 0.2,
            priority=3,
        ),
        RetrainingTrigger(
            "Performance Drop",
            lambda s: s.get("accuracy_delta", 0) < -0.05,
            priority=3,
        ),
        RetrainingTrigger(
            "Data Volume Spike",
            lambda s: s.get("new_data_fraction", 0) > 0.1,
            priority=2,
        ),
        RetrainingTrigger(
            "Scheduled Weekly",
            lambda s: s.get("days_since_training", 0) >= 7,
            priority=1,
        ),
    ])

scheduler = make_scheduler()

# Simulate daily signal evaluation
print("Retraining Trigger Evaluation (7 days):")
signal_scenarios = [
    {"day": 1, "psi_max_feature": 0.05, "accuracy_delta": -0.01, "new_data_fraction": 0.03, "days_since_training": 1},
    {"day": 2, "psi_max_feature": 0.08, "accuracy_delta": -0.02, "new_data_fraction": 0.05, "days_since_training": 2},
    {"day": 3, "psi_max_feature": 0.15, "accuracy_delta": -0.03, "new_data_fraction": 0.06, "days_since_training": 3},
    {"day": 4, "psi_max_feature": 0.25, "accuracy_delta": -0.06, "new_data_fraction": 0.08, "days_since_training": 4},
    {"day": 5, "psi_max_feature": 0.10, "accuracy_delta": -0.02, "new_data_fraction": 0.04, "days_since_training": 1},
    {"day": 6, "psi_max_feature": 0.06, "accuracy_delta": -0.01, "new_data_fraction": 0.02, "days_since_training": 2},
    {"day": 7, "psi_max_feature": 0.07, "accuracy_delta": -0.01, "new_data_fraction": 0.03, "days_since_training": 7},
]

for sig in signal_scenarios:
    day = sig.pop("day")
    trigger = scheduler.evaluate(sig)
    if trigger:
        print(f"  Day {day}: 🔄 RETRAIN — triggered by '{trigger.name}' (priority={trigger.priority})")
    else:
        print(f"  Day {day}: ✓  No retraining needed")
