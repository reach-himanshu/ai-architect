<cell id="cell-0"><cell_type>markdown</cell_type># GPU & Compute for AI

GPU selection, VRAM estimation, spot instance economics, and batch size optimization.</cell id="cell-0">
<cell id="cell-1"><cell_type>markdown</cell_type>## 1. GPU Instance Cost Calculator</cell id="cell-1">
<cell id="cell-2">from dataclasses import dataclass

@dataclass
class GPUInstance:
    name: str
    gpu: str
    vram_gb: int
    on_demand_hourly: float
    spot_discount: float       # fraction of on-demand (e.g. 0.35 = 65% cheaper)
    tokens_per_second: int     # approximate inference throughput

GPU_CATALOG = [
    GPUInstance("g4dn.xlarge",  "T4",   16, 0.526,  0.35, 400),
    GPUInstance("g5.xlarge",    "A10G", 24, 1.006,  0.40, 800),
    GPUInstance("p3.2xlarge",   "V100", 16, 3.06,   0.40, 700),
    GPUInstance("p4d.24xlarge", "A100", 320, 32.77, 0.45, 8000),
    GPUInstance("p5.48xlarge",  "H100", 640, 98.32, 0.50, 20000),
]

def analyze(instance: GPUInstance, monthly_tokens: int) -> dict:
    hours = 730
    od_cost = instance.on_demand_hourly * hours
    spot_cost = od_cost * instance.spot_discount
    capacity = instance.tokens_per_second * 3600 * hours
    cost_per_1m_od   = od_cost / (capacity / 1e6) if capacity else float("inf")
    cost_per_1m_spot = spot_cost / (capacity / 1e6) if capacity else float("inf")
    sufficient = capacity >= monthly_tokens
    return {
        "instance": instance.name, "gpu": instance.gpu,
        "monthly_od": od_cost, "monthly_spot": spot_cost,
        "capacity_tokens": capacity, "sufficient": sufficient,
        "cost_per_1m_od": cost_per_1m_od,
        "cost_per_1m_spot": cost_per_1m_spot,
    }

TARGET_TOKENS = 500_000_000   # 500M tokens/month

print(f"GPU Analysis — Target: {TARGET_TOKENS/1e6:.0f}M tokens/month")
print(f"{'Instance':<18} {'GPU':<6} {'OnDemand/mo':>12} {'Spot/mo':>10} {'$/1M OD':>9} {'Sufficient'}")
print("-" * 72)
for inst in GPU_CATALOG:
    r = analyze(inst, TARGET_TOKENS)
    suf = "Yes" if r["sufficient"] else "No"
    print(f"{r['instance']:<18} {r['gpu']:<6} ${r['monthly_od']:>11,.0f} ${r['monthly_spot']:>9,.0f} ${r['cost_per_1m_od']:>8.2f}  {suf}")</cell id="cell-2">
<cell id="cell-3"><cell_type>markdown</cell_type>## 2. VRAM Requirements by Model Size</cell id="cell-3">
<cell id="cell-4">def vram_needed(params_b: float, dtype: str = "fp16", batch_size: int = 1, seq_len: int = 2048) -> dict:
    """
    Estimate GPU VRAM needed for LLM inference.
    params_b: model parameters in billions
    """
    bytes_per_param = {"fp32": 4, "fp16": 2, "int8": 1, "int4": 0.5}
    b = bytes_per_param.get(dtype, 2)

    # Model weights
    model_gb = params_b * 1e9 * b / 1e9

    # KV cache estimate (rough: 2 * layers * seq_len * hidden_dim * batch)
    # Approximation: ~0.5GB per 1K context per batch per 7B model
    kv_cache_gb = (params_b / 7) * (seq_len / 1000) * batch_size * 0.5

    # Activations + overhead
    overhead_gb = model_gb * 0.1

    total = model_gb + kv_cache_gb + overhead_gb
    return {
        "model_size_b": params_b,
        "dtype": dtype,
        "model_gb": round(model_gb, 1),
        "kv_cache_gb": round(kv_cache_gb, 1),
        "overhead_gb": round(overhead_gb, 1),
        "total_gb": round(total, 1),
        "fits_on": next((g for g in [16, 24, 40, 80, 160, 320] if g >= total), "multi-GPU"),
    }

print(f"{'Model':>10} {'Dtype':>6} {'Weights':>8} {'KV':>6} {'Total':>7} {'Min GPU'}")
print("-" * 52)
for params in [7, 13, 30, 70, 405]:
    for dtype in ["fp16", "int4"]:
        r = vram_needed(params, dtype, batch_size=4, seq_len=4096)
        print(f"{str(params)+'B':>10} {dtype:>6} {r['model_gb']:>7.1f}G {r['kv_cache_gb']:>5.1f}G {r['total_gb']:>6.1f}G  {r['fits_on']}GB VRAM")</cell id="cell-4">
<cell id="cell-5"><cell_type>markdown</cell_type>## 3. Spot Instance Economics for Training</cell id="cell-5">
<cell id="cell-6">import random, math

def simulate_spot_training(
    total_hours: float,          # Total GPU-hours needed
    interruption_rate: float,    # Prob of interruption per hour
    checkpoint_interval_h: float,# Hours between checkpoints
    spot_hourly: float,          # $/hr spot price
    od_hourly: float,            # $/hr on-demand price
    seed: int = 42,
) -> dict:
    """Simulate spot training with checkpointing."""
    random.seed(seed)
    hours_done = 0.0
    total_spent = 0.0
    interruptions = 0
    last_checkpoint = 0.0

    while hours_done < total_hours:
        # Simulate hour-by-hour
        time_to_interrupt = -math.log(random.random()) / interruption_rate if interruption_rate > 0 else float("inf")

        if time_to_interrupt < 1.0:
            # Interrupted mid-hour
            hours_done += time_to_interrupt
            total_spent += time_to_interrupt * spot_hourly
            interruptions += 1
            # Roll back to last checkpoint
            hours_done = last_checkpoint
        else:
            hours_done = min(hours_done + 1.0, total_hours)
            total_spent += min(1.0, total_hours - (hours_done - 1.0)) * spot_hourly
            if hours_done - last_checkpoint >= checkpoint_interval_h:
                last_checkpoint = hours_done

    od_cost = total_hours * od_hourly
    return {
        "interruptions": interruptions,
        "spot_cost": round(total_spent, 2),
        "od_cost": round(od_cost, 2),
        "savings_pct": round((1 - total_spent / od_cost) * 100, 1),
        "overhead_pct": round((total_spent - total_hours * spot_hourly) / (total_hours * spot_hourly) * 100, 1),
    }

print("Spot vs. On-Demand for Training (100 GPU-hours, A100):")
print(f"{'Interrupt Rate':>16} {'Ckpt Interval':>15} {'Spot $':>8} {'OD $':>8} {'Savings':>9} {'Overhead'}")
print("-" * 65)
for rate in [0.05, 0.10, 0.20]:
    for ckpt in [0.5, 2.0]:
        r = simulate_spot_training(100, rate, ckpt, spot_hourly=13.0, od_hourly=32.77)
        print(f"{rate:>14.0%}/hr {ckpt:>13.1f}h  ${r['spot_cost']:>7,} ${r['od_cost']:>7,}  {r['savings_pct']:>7.1f}%  {r['interruptions']} interrupts")</cell id="cell-6">
