<cell id="cell-0"><cell_type>markdown</cell_type># Cloud AI Services

Decision frameworks for cloud AI service selection.</cell id="cell-0">
<cell id="cell-1"><cell_type>markdown</cell_type>## 1. Cloud Provider Selection Framework</cell id="cell-1">
<cell id="cell-2">from dataclasses import dataclass

@dataclass
class AIProjectRequirements:
    primary_use_case: str       # llm_api, training, vision, speech, search
    compliance: list[str]       # ["HIPAA", "FedRAMP", "SOC2", "GDPR"]
    existing_cloud: str         # "aws", "gcp", "azure", "none"
    data_residency: str         # "us", "eu", "apac", "any"
    budget_monthly_usd: float
    team_cloud_expertise: str   # "aws", "gcp", "azure", "mixed"

def recommend_cloud(req: AIProjectRequirements) -> dict:
    scores = {"aws": 0, "gcp": 0, "azure": 0}

    # Existing infra affinity
    if req.existing_cloud in scores:
        scores[req.existing_cloud] += 3
    if req.team_cloud_expertise in scores:
        scores[req.team_cloud_expertise] += 2

    # Compliance requirements
    if "FedRAMP" in req.compliance:
        scores["azure"] += 3   # Azure Government has best FedRAMP
    if "HIPAA" in req.compliance:
        scores["azure"] += 2
        scores["aws"] += 2
    if "GDPR" in req.compliance:
        scores["azure"] += 1   # Strong EU presence
        scores["gcp"] += 1

    # Use-case specific
    if req.primary_use_case == "llm_api":
        scores["azure"] += 2   # Azure OpenAI
        scores["aws"] += 1     # Bedrock
        scores["gcp"] += 1     # Vertex
    elif req.primary_use_case == "training":
        scores["gcp"] += 2     # TPUs, best ML tooling
        scores["aws"] += 1
    elif req.primary_use_case == "analytics":
        scores["gcp"] += 3     # BigQuery

    # Budget (GCP often cheapest for AI)
    if req.budget_monthly_usd < 500:
        scores["gcp"] += 1

    winner = max(scores, key=scores.get)
    return {"recommendation": winner, "scores": scores,
            "reason": f"Highest fit score ({scores[winner]}) based on requirements"}

scenarios = [
    ("HIPAA healthcare LLM",
     AIProjectRequirements("llm_api", ["HIPAA", "SOC2"], "azure", "us", 2000, "azure")),
    ("ML training startup",
     AIProjectRequirements("training", ["SOC2"], "none", "any", 300, "mixed")),
    ("Enterprise analytics + AI",
     AIProjectRequirements("analytics", ["GDPR"], "gcp", "eu", 5000, "gcp")),
    ("Government AI assistant",
     AIProjectRequirements("llm_api", ["FedRAMP", "HIPAA"], "aws", "us", 10000, "aws")),
]

for name, req in scenarios:
    result = recommend_cloud(req)
    print(f"{name}:")
    print(f"  → {result['recommendation'].upper()} (scores: {result['scores']})")
    print()</cell id="cell-2">
<cell id="cell-3"><cell_type>markdown</cell_type>## 2. Managed vs Self-Hosted Cost Crossover Analysis</cell id="cell-3">
<cell id="cell-4">def managed_api_cost(monthly_tokens: int, price_per_1m: float = 3.0) -> float:
    """Cost of managed LLM API (e.g., Bedrock Claude)."""
    return (monthly_tokens / 1_000_000) * price_per_1m

def self_hosted_cost(
    gpu_hourly: float = 3.50,         # e.g., A10G spot price
    utilization: float = 0.7,          # GPU utilization
    tokens_per_second: float = 800,    # throughput on that GPU
) -> tuple[float, float]:
    """
    Monthly cost of self-hosting an LLM on a GPU.
    Returns (monthly_cost_usd, monthly_tokens).
    """
    hours_per_month = 730
    monthly_cost = gpu_hourly * hours_per_month
    monthly_tokens = tokens_per_second * 3600 * hours_per_month * utilization
    return monthly_cost, monthly_tokens

gpu_cost, gpu_tokens = self_hosted_cost(gpu_hourly=3.50, utilization=0.7, tokens_per_second=800)
print(f"Self-hosted GPU:")
print(f"  Monthly cost:   ${gpu_cost:,.0f}")
print(f"  Monthly tokens: {gpu_tokens/1e9:.2f}B")
print(f"  Effective rate: ${gpu_cost / (gpu_tokens/1e6):.4f}/1M tokens")

print(f"\nManaged API (Claude Sonnet @ $3/1M input tokens):")
print(f"{'Tokens/month':>15} {'Managed $':>12} {'Self-host $':>12} {'Cheaper'}")
print("-" * 50)
for tokens in [10e6, 50e6, 200e6, 500e6, 1e9, 5e9]:
    managed = managed_api_cost(int(tokens), price_per_1m=3.0)
    # Self-host cost is fixed; only justified at sufficient volume
    cheaper = "Self-host" if gpu_cost < managed else "Managed"
    print(f"{tokens/1e6:>12.0f}M {managed:>12,.0f} {gpu_cost:>12,.0f}  {cheaper}")</cell id="cell-4">
<cell id="cell-5"><cell_type>markdown</cell_type>## 3. Multi-Cloud AI Risk Assessment</cell id="cell-5">
<cell id="cell-6">from dataclasses import dataclass, field

@dataclass
class ServiceDependency:
    name: str
    cloud: str
    lock_in: str      # "high", "medium", "low"
    alternative: str

def assess_lock_in(dependencies: list[ServiceDependency]) -> dict:
    high = [d for d in dependencies if d.lock_in == "high"]
    medium = [d for d in dependencies if d.lock_in == "medium"]
    low = [d for d in dependencies if d.lock_in == "low"]
    risk_score = len(high) * 3 + len(medium) * 1

    return {
        "total_services": len(dependencies),
        "high_lock_in": [(d.name, d.alternative) for d in high],
        "medium_lock_in": [(d.name, d.alternative) for d in medium],
        "risk_score": risk_score,
        "risk_level": "HIGH" if risk_score > 8 else ("MEDIUM" if risk_score > 3 else "LOW"),
    }

stack = [
    ServiceDependency("SageMaker Pipelines",     "aws", "high",   "Kubeflow, Prefect"),
    ServiceDependency("SageMaker Feature Store",  "aws", "high",   "Feast (open source)"),
    ServiceDependency("Amazon Bedrock",           "aws", "medium", "Direct Anthropic API"),
    ServiceDependency("S3 Object Storage",        "aws", "low",    "GCS, Azure Blob"),
    ServiceDependency("OpenSearch (vector)",      "aws", "medium", "Qdrant, Elasticsearch"),
    ServiceDependency("Lambda Functions",         "aws", "medium", "Cloud Run, containers"),
    ServiceDependency("CloudWatch Monitoring",    "aws", "low",    "Grafana + Prometheus"),
]

result = assess_lock_in(stack)
print(f"Lock-in Assessment:")
print(f"  Total services: {result['total_services']}")
print(f"  Risk level: {result['risk_level']} (score={result['risk_score']})")
print(f"\n  High lock-in services (migrate first if needed):")
for name, alt in result["high_lock_in"]:
    print(f"    • {name} → {alt}")
print(f"\n  Medium lock-in services:")
for name, alt in result["medium_lock_in"]:
    print(f"    • {name} → {alt}")</cell id="cell-6">
