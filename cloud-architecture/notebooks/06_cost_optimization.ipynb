# ── Cell 3: Inference Cost Model (Batching vs No Batching) ────────────────────
from typing import List, Tuple
import math

@dataclass
class InferenceConfig:
    model_name: str
    cost_per_1k_input_tokens: float   # USD
    cost_per_1k_output_tokens: float  # USD
    latency_ms_per_token: float       # generation latency
    cold_start_ms: float = 0.0        # serverless cold start

@dataclass
class Request:
    prompt_tokens: int
    max_output_tokens: int

def simulate_requests(n: int, seed: int = 0) -> List[Request]:
    random.seed(seed)
    return [Request(
        prompt_tokens=random.randint(50, 500),
        max_output_tokens=random.randint(50, 300),
    ) for _ in range(n)]

def cost_no_batching(requests: List[Request], cfg: InferenceConfig) -> Tuple[float, float]:
    """Process each request individually."""
    total_cost = sum(
        r.prompt_tokens  / 1000 * cfg.cost_per_1k_input_tokens +
        r.max_output_tokens / 1000 * cfg.cost_per_1k_output_tokens
        for r in requests
    )
    total_latency_ms = sum(
        cfg.cold_start_ms + r.max_output_tokens * cfg.latency_ms_per_token
        for r in requests
    )
    return total_cost, total_latency_ms

def cost_batched(requests: List[Request], cfg: InferenceConfig, batch_size: int) -> Tuple[float, float]:
    """Process in batches — cost same, latency reduced via parallelism."""
    total_cost = sum(
        r.prompt_tokens / 1000 * cfg.cost_per_1k_input_tokens +
        r.max_output_tokens / 1000 * cfg.cost_per_1k_output_tokens
        for r in requests
    )
    n_batches = math.ceil(len(requests) / batch_size)
    # Latency = batches * max(output tokens in batch) * latency_per_token + cold_start
    total_latency_ms = 0.0
    for i in range(n_batches):
        batch = requests[i*batch_size:(i+1)*batch_size]
        max_out = max(r.max_output_tokens for r in batch)
        total_latency_ms += cfg.cold_start_ms + max_out * cfg.latency_ms_per_token
    return total_cost, total_latency_ms

gpt4_cfg = InferenceConfig(
    model_name="gpt-4o",
    cost_per_1k_input_tokens=0.005,
    cost_per_1k_output_tokens=0.015,
    latency_ms_per_token=25,
)

reqs = simulate_requests(100)
c_single, l_single = cost_no_batching(reqs, gpt4_cfg)
c_batch,  l_batch  = cost_batched(reqs, gpt4_cfg, batch_size=8)

print("Inference Cost Model (100 requests, gpt-4o pricing)")
print(f"  No batching : cost=${c_single:.4f}  latency={l_single/1000:.1f}s total")
print(f"  Batch=8     : cost=${c_batch:.4f}  latency={l_batch/1000:.1f}s total")
print(f"  Latency gain: {l_single/l_batch:.2f}×  (cost identical — batching saves GPU idle time)")
