# ── Cell 1: Reserved Instance Savings Calculator ──────────────────────────────
from dataclasses import dataclass, field
from typing import Dict, List, Optional
import math

@dataclass
class InstancePlan:
    name: str
    on_demand_hourly: float   # USD
    ri_1yr_hourly: float
    ri_3yr_hourly: float
    spot_hourly: float

# Representative instance costs (illustrative)
CATALOG: Dict[str, InstancePlan] = {
    "p3.2xlarge":   InstancePlan("p3.2xlarge",   3.06,  1.84,  1.22,  0.91),
    "p3.8xlarge":   InstancePlan("p3.8xlarge",  12.24,  7.34,  4.87,  3.67),
    "g4dn.xlarge":  InstancePlan("g4dn.xlarge",  0.526, 0.316, 0.209, 0.158),
    "g5.xlarge":    InstancePlan("g5.xlarge",    1.006, 0.604, 0.401, 0.302),
    "a2-highgpu-1g":InstancePlan("a2-highgpu-1g",3.67,  2.31,  1.65,  1.10),
}

def savings_report(instance_key: str, hours_per_month: float = 720) -> None:
    """Print monthly and yearly savings vs on-demand for all commitment levels."""
    plan = CATALOG[instance_key]
    baseline = plan.on_demand_hourly * hours_per_month

    def pct(cost): return 100 * (1 - cost / baseline)

    print(f"\n{'='*55}")
    print(f"  Savings Report: {plan.name}  ({hours_per_month}h/month)")
    print(f"{'='*55}")
    print(f"  On-Demand   : ${baseline:>8.2f}/mo  (${baseline*12:>9.2f}/yr)")

    ri1 = plan.ri_1yr_hourly * hours_per_month
    print(f"  1-yr RI     : ${ri1:>8.2f}/mo  save {pct(ri1):.0f}%  (${ri1*12:>9.2f}/yr)")

    ri3 = plan.ri_3yr_hourly * hours_per_month
    print(f"  3-yr RI     : ${ri3:>8.2f}/mo  save {pct(ri3):.0f}%  (${ri3*12:>9.2f}/yr)")

    spot = plan.spot_hourly * hours_per_month
    print(f"  Spot        : ${spot:>8.2f}/mo  save {pct(spot):.0f}%  (${spot*12:>9.2f}/yr)")
    print(f"{'='*55}")

savings_report("p3.2xlarge")
savings_report("g4dn.xlarge")
savings_report("g5.xlarge")
