# ── Cell 5: FinOps Unit Economics Tracker ─────────────────────────────────────
from datetime import date, timedelta
from collections import defaultdict

@dataclass
class CostEntry:
    date: date
    service: str          # e.g. "inference", "training", "storage"
    team: str
    project: str
    usd: float
    units: float          # API calls, GPU hours, GB-days
    unit_label: str       # "api_calls", "gpu_hours", "gb_days"

class FinOpsTracker:
    def __init__(self, monthly_budget: float):
        self.monthly_budget = monthly_budget
        self.entries: List[CostEntry] = []

    def add(self, entry: CostEntry) -> None:
        self.entries.append(entry)

    def monthly_summary(self) -> None:
        by_service: Dict[str, float] = defaultdict(float)
        by_team: Dict[str, float] = defaultdict(float)
        by_project: Dict[str, float] = defaultdict(float)
        total = 0.0
        unit_costs: Dict[str, List[float]] = defaultdict(list)

        for e in self.entries:
            by_service[e.service] += e.usd
            by_team[e.team] += e.usd
            by_project[e.project] += e.usd
            total += e.usd
            if e.units > 0:
                unit_costs[e.unit_label].append(e.usd / e.units)

        print(f"\n{'FinOps Monthly Report':=^55}")
        print(f"  Total spend : ${total:,.2f}  /  Budget ${self.monthly_budget:,.2f}  ({total/self.monthly_budget:.0%})")
        if total > self.monthly_budget * 0.8:
            print(f"  ⚠️  WARNING: Above 80% threshold!")

        print(f"\n  By Service:")
        for svc, cost in sorted(by_service.items(), key=lambda x: -x[1]):
            print(f"    {svc:<25} ${cost:>8,.2f}  ({cost/total:.0%})")

        print(f"\n  By Team:")
        for team, cost in sorted(by_team.items(), key=lambda x: -x[1]):
            print(f"    {team:<25} ${cost:>8,.2f}")

        print(f"\n  Unit Economics:")
        for label, costs in unit_costs.items():
            avg = sum(costs) / len(costs)
            print(f"    cost per {label:<20} ${avg:.6f}")
        print("="*55)

# Simulate a month of entries
tracker = FinOpsTracker(monthly_budget=15_000)
today = date(2025, 1, 1)
random.seed(7)

services = [
    ("inference", "ml-platform", "rag-search", 1.20, 1000, "api_calls"),
    ("training",  "research",    "llm-finetune", 8.50, 1, "gpu_hours"),
    ("storage",   "data-eng",    "feature-store", 0.023, 1000, "gb_days"),
    ("inference", "product",     "chat-ui", 0.80, 1000, "api_calls"),
]

for day_offset in range(30):
    d = today + timedelta(days=day_offset)
    for svc, team, proj, base_cost, units, label in services:
        noise = 1 + random.uniform(-0.2, 0.3)
        tracker.add(CostEntry(d, svc, team, proj,
                               base_cost * noise * 10,
                               units * random.randint(8, 15),
                               label))

tracker.monthly_summary()
