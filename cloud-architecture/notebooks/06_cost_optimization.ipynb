# ── Cell 4: Prompt Token Optimiser ────────────────────────────────────────────

def estimate_tokens(text: str) -> int:
    """Rough estimate: 1 token ≈ 4 chars for English text."""
    return max(1, len(text) // 4)

def token_cost(tokens: int, cost_per_1k: float) -> float:
    return tokens / 1000 * cost_per_1k

class PromptOptimiser:
    """Tracks prompt components and suggests token savings."""

    def __init__(self, cost_per_1k_input: float = 0.005, calls_per_day: int = 10_000):
        self.cost_per_1k_input = cost_per_1k_input
        self.calls_per_day = calls_per_day
        self.components: List[dict] = []

    def add_component(self, name: str, text: str, cacheable: bool = False) -> None:
        tokens = estimate_tokens(text)
        self.components.append({"name": name, "tokens": tokens,
                                "cacheable": cacheable, "text": text})

    def report(self) -> None:
        total_tokens = sum(c["tokens"] for c in self.components)
        cacheable_tokens = sum(c["tokens"] for c in self.components if c["cacheable"])
        dynamic_tokens = total_tokens - cacheable_tokens

        daily_cost_no_cache = token_cost(total_tokens, self.cost_per_1k_input) * self.calls_per_day
        # Assume cached tokens cost 10% (Anthropic prompt caching model)
        daily_cost_cached = (
            token_cost(dynamic_tokens, self.cost_per_1k_input) +
            token_cost(cacheable_tokens, self.cost_per_1k_input * 0.1)
        ) * self.calls_per_day

        print(f"\n{'Prompt Token Analysis':=^55}")
        for c in self.components:
            flag = " [CACHED]" if c["cacheable"] else ""
            print(f"  {c['name']:<30} {c['tokens']:>5} tokens{flag}")
        print(f"  {'─'*45}")
        print(f"  {'Total':<30} {total_tokens:>5} tokens")
        print(f"  {'Cacheable':<30} {cacheable_tokens:>5} tokens ({cacheable_tokens/total_tokens:.0%})")
        print(f"\n  Calls/day         : {self.calls_per_day:,}")
        print(f"  Daily cost (no cache)  : ${daily_cost_no_cache:>8.2f}")
        print(f"  Daily cost (w/ cache)  : ${daily_cost_cached:>8.2f}")
        print(f"  Monthly savings        : ${(daily_cost_no_cache - daily_cost_cached)*30:>8.2f}")
        print("="*55)

opt = PromptOptimiser(cost_per_1k_input=0.003, calls_per_day=50_000)
opt.add_component("System prompt (persona)", "You are an expert financial advisor..." * 20, cacheable=True)
opt.add_component("Tool definitions (20 tools)", "tool1: {description...}" * 30, cacheable=True)
opt.add_component("Few-shot examples (5)", "Q: ... A: ..." * 15, cacheable=True)
opt.add_component("User query (dynamic)", "What is my portfolio allocation?", cacheable=False)
opt.add_component("Conversation history", "User: ... Assistant: ..." * 10, cacheable=False)
opt.report()
