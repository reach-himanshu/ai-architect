# ── Cell 2: Spot Checkpointing Simulator ──────────────────────────────────────
import random
import time as _time

class CheckpointStore:
    """Simple in-memory checkpoint store (simulate S3 / GCS)."""
    def __init__(self):
        self._store: Dict[str, dict] = {}

    def save(self, job_id: str, step: int, loss: float) -> None:
        self._store[job_id] = {"step": step, "loss": loss}
        print(f"  [Checkpoint] job={job_id}  step={step}  loss={loss:.4f}")

    def load(self, job_id: str) -> Optional[dict]:
        return self._store.get(job_id)


def simulate_spot_training(
    job_id: str,
    total_steps: int,
    checkpoint_every: int,
    preemption_prob: float,
    store: CheckpointStore,
) -> int:
    """
    Train with spot instance.
    Returns total number of steps actually computed (including retries).
    """
    checkpoint = store.load(job_id)
    start_step = checkpoint["step"] if checkpoint else 0
    loss = checkpoint["loss"] if checkpoint else 1.0

    total_computed = 0
    step = start_step

    print(f"\n[Job {job_id}] Resuming from step {start_step}/{total_steps}")

    while step < total_steps:
        # Simulate one step
        loss *= 0.999 + random.uniform(-0.0005, 0.0005)
        step += 1
        total_computed += 1

        # Checkpoint
        if step % checkpoint_every == 0 or step == total_steps:
            store.save(job_id, step, loss)

        # Random preemption
        if random.random() < preemption_prob and step < total_steps:
            wasted = step % checkpoint_every or checkpoint_every
            print(f"  [PREEMPTED] at step {step}. Wasted {wasted} steps. Restarting...")
            # Reload last checkpoint
            ckpt = store.load(job_id)
            step = ckpt["step"]
            loss = ckpt["loss"]

    print(f"[Job {job_id}] Done. Final loss={loss:.4f}. Total steps computed={total_computed}")
    return total_computed

random.seed(42)
store = CheckpointStore()
total = simulate_spot_training(
    job_id="finetune-llama-001",
    total_steps=50,
    checkpoint_every=10,
    preemption_prob=0.08,
    store=store,
)
print(f"\nEfficiency: {50}/{total} = {50/total:.1%} useful work")
