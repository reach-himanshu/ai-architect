<cell id="cell-0"><cell_type>markdown</cell_type># Managed ML Services

Simulating MLOps pipelines, endpoint scaling, and cost comparison.</cell id="cell-0">
<cell id="cell-1"><cell_type>markdown</cell_type>## 1. MLOps Pipeline Simulator</cell id="cell-1">
<cell id="cell-2">import time, uuid, random
from dataclasses import dataclass, field
from typing import Callable, Optional

@dataclass
class PipelineStep:
    name: str
    fn: Callable
    depends_on: list[str] = field(default_factory=list)

@dataclass
class StepResult:
    step: str
    status: str         # success | failed | skipped
    duration_s: float
    output: dict = field(default_factory=dict)
    error: Optional[str] = None

class MLPipeline:
    """Simple DAG-based ML pipeline orchestrator."""

    def __init__(self, name: str, steps: list[PipelineStep]):
        self.name = name
        self.steps = {s.name: s for s in steps}
        self.run_id = str(uuid.uuid4())[:8]
        self.results: dict[str, StepResult] = {}

    def _can_run(self, step_name: str) -> bool:
        step = self.steps[step_name]
        return all(
            self.results.get(dep, StepResult(dep, "skipped", 0)).status == "success"
            for dep in step.depends_on
        )

    def run(self, context: dict = None) -> dict:
        context = context or {}
        print(f"Pipeline '{self.name}' started (run_id={self.run_id})")
        for step_name, step in self.steps.items():
            if not self._can_run(step_name):
                self.results[step_name] = StepResult(step_name, "skipped", 0.0)
                print(f"  [SKIP ] {step_name}")
                continue
            start = time.time()
            try:
                output = step.fn(context)
                context.update(output or {})
                dur = time.time() - start
                self.results[step_name] = StepResult(step_name, "success", dur, output or {})
                print(f"  [OK   ] {step_name} ({dur:.2f}s)")
            except Exception as e:
                dur = time.time() - start
                self.results[step_name] = StepResult(step_name, "failed", dur, error=str(e))
                print(f"  [FAIL ] {step_name}: {e}")

        succeeded = sum(1 for r in self.results.values() if r.status == "success")
        return {"run_id": self.run_id, "succeeded": succeeded, "total": len(self.steps),
                "status": "success" if succeeded == len(self.steps) else "failed"}

# Define pipeline steps
def preprocess(ctx):
    time.sleep(0.02)
    return {"dataset_uri": "s3://bucket/preprocessed/", "n_samples": 50000}

def train(ctx):
    time.sleep(0.05)
    return {"model_uri": "s3://bucket/models/run123/", "train_loss": 0.23, "val_f1": 0.87}

def evaluate(ctx):
    if ctx.get("val_f1", 0) < 0.80:
        raise ValueError(f"F1 {ctx['val_f1']:.2f} below threshold 0.80")
    return {"eval_passed": True, "f1": ctx["val_f1"]}

def register(ctx):
    if not ctx.get("eval_passed"):
        raise ValueError("Evaluation gate not passed")
    return {"model_version": "v3.1.0", "registry": "SageMaker"}

def deploy(ctx):
    time.sleep(0.02)
    return {"endpoint": "ml-classifier-prod", "traffic_pct": 10}

pipeline = MLPipeline("churn-prediction", [
    PipelineStep("preprocess", preprocess),
    PipelineStep("train",      train,     depends_on=["preprocess"]),
    PipelineStep("evaluate",   evaluate,  depends_on=["train"]),
    PipelineStep("register",   register,  depends_on=["evaluate"]),
    PipelineStep("deploy",     deploy,    depends_on=["register"]),
])

result = pipeline.run()
print(f"\nPipeline result: {result}")</cell id="cell-2">
<cell id="cell-3"><cell_type>markdown</cell_type>## 2. Endpoint Autoscaling Simulator</cell id="cell-3">
<cell id="cell-4">import math, time
from dataclasses import dataclass, field

@dataclass
class InferenceEndpoint:
    name: str
    min_instances: int = 1
    max_instances: int = 10
    target_rps_per_instance: float = 50.0
    scale_up_cooldown_s: float = 60.0
    scale_down_cooldown_s: float = 300.0
    _instances: int = field(init=False)
    _last_scale_up: float = field(init=False)
    _last_scale_down: float = field(init=False)

    def __post_init__(self):
        self._instances = self.min_instances
        self._last_scale_up = 0.0
        self._last_scale_down = 0.0

    def autoscale(self, current_rps: float, now: float) -> dict:
        needed = math.ceil(current_rps / self.target_rps_per_instance)
        needed = max(self.min_instances, min(self.max_instances, needed))
        action = "none"

        if needed > self._instances and now - self._last_scale_up > self.scale_up_cooldown_s:
            self._instances = min(needed, self._instances + 2)   # Scale up by 2
            self._last_scale_up = now
            action = f"SCALE UP → {self._instances}"
        elif needed < self._instances and now - self._last_scale_down > self.scale_down_cooldown_s:
            self._instances = max(needed, self._instances - 1)   # Scale down by 1
            self._last_scale_down = now
            action = f"SCALE DOWN → {self._instances}"

        utilization = current_rps / (self._instances * self.target_rps_per_instance)
        return {"instances": self._instances, "utilization": utilization, "action": action}

endpoint = InferenceEndpoint("fraud-detector", min_instances=1, max_instances=8)

traffic_pattern = [
    (0, 20), (60, 80), (120, 200), (180, 350), (240, 200),
    (600, 100), (900, 40), (1200, 15),
]

print(f"{'Time':>6} {'RPS':>5} {'Instances':>10} {'Util':>7} {'Action'}")
print("-" * 50)
for ts, rps in traffic_pattern:
    result = endpoint.autoscale(rps, ts)
    print(f"{ts:>6}s {rps:>5} {result['instances']:>10} {result['utilization']:>6.0%}  {result['action']}")</cell id="cell-4">
