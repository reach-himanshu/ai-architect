<cell id="cell-0"><cell_type>markdown</cell_type># Serverless for AI

Cold start simulation, serverless vs. always-on cost analysis, and async job queue pattern.</cell id="cell-0">
<cell id="cell-1"><cell_type>markdown</cell_type>## 1. Cold Start Simulator</cell id="cell-1">
<cell id="cell-2">import time, random, math
from dataclasses import dataclass, field

@dataclass
class ServerlessFunction:
    name: str
    model_load_s: float = 3.0       # Time to load model on cold start
    handler_s: float = 0.5          # Time to handle request
    scale_to_zero_after_s: float = 60.0
    provisioned_instances: int = 0  # Warm instances kept alive
    _warm_until: float = field(init=False, default=0.0)
    _warm_count: int = field(init=False, default=0)

    def __post_init__(self):
        self._warm_count = self.provisioned_instances
        self._warm_until = time.time() + self.scale_to_zero_after_s * self._warm_count

    def invoke(self, now: float) -> dict:
        is_cold = self._warm_count == 0 and now > self._warm_until
        if is_cold:
            latency = self.model_load_s + self.handler_s
            self._warm_until = now + self.scale_to_zero_after_s
            self._warm_count = max(1, self._warm_count)
        else:
            latency = self.handler_s
        return {
            "cold_start": is_cold,
            "latency_s": latency,
            "total_ms": round(latency * 1000),
        }

# Simulate bursty traffic (sparse requests)
funcs = [
    ServerlessFunction("no-provisioning",    model_load_s=4.0, provisioned_instances=0),
    ServerlessFunction("1-warm-instance",    model_load_s=4.0, provisioned_instances=1),
]

traffic = [0, 5, 10, 80, 85, 90, 95, 300, 305, 310]  # Request timestamps (s)

for fn in funcs:
    print(f"\n{fn.name}:")
    print(f"  {'Req':>4} {'Cold':>6} {'Latency':>10}")
    print("  " + "-" * 25)
    fn._warm_until = 0.0  # Reset
    fn._warm_count = fn.provisioned_instances
    for ts in traffic:
        result = fn.invoke(float(ts))
        cold_flag = "COLD" if result["cold_start"] else "warm"
        print(f"  {ts:>4}s {cold_flag:>6} {result['total_ms']:>8}ms")</cell id="cell-2">
<cell id="cell-3"><cell_type>markdown</cell_type>## 2. Serverless vs. Always-On Cost Model</cell id="cell-3">
<cell id="cell-4">def serverless_cost(
    requests_per_day: int,
    avg_duration_s: float,
    memory_gb: float = 4.0,
    price_per_gb_s: float = 0.0000166,   # Lambda price
    request_price: float = 0.0000002,    # Lambda: $0.20 per 1M requests
) -> float:
    compute = requests_per_day * avg_duration_s * memory_gb * price_per_gb_s
    requests_cost = requests_per_day * request_price
    return (compute + requests_cost) * 30   # Monthly

def always_on_cost(
    n_instances: int,
    instance_hourly: float = 0.526,   # g4dn.xlarge
) -> float:
    return n_instances * instance_hourly * 24 * 30   # Monthly

print("Monthly Cost Comparison: Serverless vs. Always-On (g4dn.xlarge)")
print(f"{'RPS':>6} {'Daily Req':>10} {'Serverless':>12} {'Always-On 1x':>14} {'Always-On 2x':>14} {'Winner'}")
print("-" * 70)
for rps in [0.01, 0.1, 1, 5, 10, 50, 100, 500]:
    daily_req = int(rps * 86400)
    sl = serverless_cost(daily_req, avg_duration_s=1.0, memory_gb=4.0)
    ao1 = always_on_cost(1)
    ao2 = always_on_cost(2)
    winner = "Serverless" if sl < ao1 else "Always-On"
    print(f"{rps:>6.2f} {daily_req:>10,} ${sl:>11,.2f} ${ao1:>13,.2f} ${ao2:>13,.2f}  {winner}")</cell id="cell-4">
<cell id="cell-5"><cell_type>markdown</cell_type>## 3. Async LLM Job Queue Pattern</cell id="cell-5">
<cell id="cell-6">import uuid, time, random
from dataclasses import dataclass, field
from collections import deque
from typing import Optional

@dataclass
class Job:
    id: str
    prompt: str
    status: str = "queued"    # queued | processing | done | failed
    result: Optional[str] = None
    created_at: float = field(default_factory=time.time)
    completed_at: Optional[float] = None

class AsyncLLMService:
    """Async job queue pattern for long-running LLM inference."""

    def __init__(self, workers: int = 2):
        self._queue: deque = deque()
        self._jobs: dict[str, Job] = {}
        self.workers = workers

    def submit(self, prompt: str) -> str:
        """Submit job — returns immediately with a job ID."""
        job_id = str(uuid.uuid4())[:8]
        job = Job(id=job_id, prompt=prompt)
        self._jobs[job_id] = job
        self._queue.append(job_id)
        return job_id

    def process_next(self) -> Optional[str]:
        """Worker: process one job from the queue."""
        if not self._queue:
            return None
        job_id = self._queue.popleft()
        job = self._jobs[job_id]
        job.status = "processing"

        # Simulate LLM call (variable duration)
        time.sleep(random.uniform(0.01, 0.05))

        if random.random() < 0.1:   # 10% failure rate
            job.status = "failed"
            job.result = None
        else:
            job.status = "done"
            job.result = f"Generated response for: {job.prompt[:30]}..."

        job.completed_at = time.time()
        return job_id

    def status(self, job_id: str) -> dict:
        job = self._jobs.get(job_id)
        if not job:
            return {"error": "Job not found"}
        return {
            "id": job.id,
            "status": job.status,
            "result": job.result,
            "wait_s": round(job.completed_at - job.created_at, 3) if job.completed_at else None,
        }

service = AsyncLLMService(workers=2)
random.seed(42)

# Submit 8 jobs
job_ids = [service.submit(f"Tell me about topic {i}") for i in range(8)]
print(f"Submitted {len(job_ids)} jobs")

# Process all
while service._queue:
    service.process_next()

print("\nJob results:")
done = sum(1 for jid in job_ids if service.status(jid)["status"] == "done")
failed = sum(1 for jid in job_ids if service.status(jid)["status"] == "failed")
avg_wait = sum(service.status(jid)["wait_s"] or 0 for jid in job_ids) / len(job_ids)
print(f"  Done: {done}, Failed: {failed}, Avg wait: {avg_wait:.3f}s")
for jid in job_ids[:3]:
    s = service.status(jid)
    print(f"  [{s['status']:>10}] {jid}: {str(s['result'])[:50]}")</cell id="cell-6">
