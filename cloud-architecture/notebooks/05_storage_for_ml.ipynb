<cell id="cell-0"><cell_type>markdown</cell_type># Storage for ML

Data format analysis, storage cost estimation, and dataset versioning system.</cell id="cell-0">
<cell id="cell-1"><cell_type>markdown</cell_type>## 1. Data Format Performance Comparison</cell id="cell-1">
<cell id="cell-2">import random, time, json
from dataclasses import dataclass

@dataclass
class FormatBenchmark:
    name: str
    storage_type: str   # row | columnar
    compression_ratio: float   # size relative to raw
    read_full_speed: float    # relative speed (1.0 = baseline)
    read_col_speed: float     # columnar read (2 cols of 100)
    write_speed: float
    schema_evolution: bool
    streaming_friendly: bool

FORMATS = [
    FormatBenchmark("CSV",      "row",      1.0,  1.0, 0.8, 1.0, False, True),
    FormatBenchmark("JSON",     "row",      1.5,  0.7, 0.7, 0.8, False, True),
    FormatBenchmark("Parquet",  "columnar", 0.25, 1.5, 8.0, 0.9, True,  False),
    FormatBenchmark("Avro",     "row",      0.4,  1.2, 0.9, 1.1, True,  True),
    FormatBenchmark("Arrow",    "columnar", 0.5,  3.0, 9.0, 2.0, True,  False),
]

# Simulate data at 1GB raw
raw_size_gb = 1.0
print(f"Format comparison for {raw_size_gb}GB raw data:")
print(f"{'Format':<10} {'Type':>9} {'Stored(GB)':>11} {'Read All':>9} {'Read 2 cols':>12} {'Schema Evol'}")
print("-" * 60)
for f in FORMATS:
    stored = raw_size_gb * f.compression_ratio
    read_t = f"x{f.read_full_speed:.1f}"
    col_t  = f"x{f.read_col_speed:.1f}"
    schema = "Yes" if f.schema_evolution else "No"
    print(f"{f.name:<10} {f.storage_type:>9} {stored:>11.2f} {read_t:>9} {col_t:>12}  {schema}")</cell id="cell-2">
<cell id="cell-3"><cell_type>markdown</cell_type>## 2. S3 Storage Cost Estimator</cell id="cell-3">
<cell id="cell-4">def storage_cost(
    data_tb: float,
    storage_tier: str = "standard",
    monthly_reads_million: float = 1.0,
    monthly_writes_million: float = 0.1,
    data_transfer_tb: float = 0.0,
) -> dict:
    """
    Estimate monthly S3 costs.
    Prices approximate as of 2025.
    """
    STORAGE_PRICE = {"standard": 0.023, "intelligent": 0.023, "glacier": 0.004, "deep_archive": 0.00099}
    storage_cost = data_tb * 1024 * STORAGE_PRICE.get(storage_tier, 0.023)  # $/TB-month
    get_cost = monthly_reads_million * 0.0004   # $0.0004 per 1K GET requests
    put_cost = monthly_writes_million * 0.005   # $0.005 per 1K PUT requests
    transfer = data_transfer_tb * 90             # $0.09/GB → $90/TB

    return {
        "storage_class": storage_tier,
        "data_tb": data_tb,
        "storage_usd": round(storage_cost, 2),
        "requests_usd": round(get_cost + put_cost, 2),
        "transfer_usd": round(transfer, 2),
        "total_usd": round(storage_cost + get_cost + put_cost + transfer, 2),
    }

print("S3 Cost Comparison for 10TB ML Dataset:")
print(f"{'Tier':<15} {'Storage $':>10} {'Requests $':>12} {'Total/mo $':>12}")
print("-" * 52)
for tier in ["standard", "intelligent", "glacier", "deep_archive"]:
    r = storage_cost(10, tier, monthly_reads_million=5.0, monthly_writes_million=0.5)
    print(f"{r['storage_class']:<15} ${r['storage_usd']:>9.2f} ${r['requests_usd']:>11.2f} ${r['total_usd']:>11.2f}")

print()
print("Cost by dataset size (Standard tier):")
print(f"{'Size':>8} {'Cost/mo':>12}")
for tb in [0.1, 1, 10, 100, 1000]:
    r = storage_cost(tb, "standard", monthly_reads_million=1.0)
    print(f"{tb:>7}TB ${r['total_usd']:>11,.2f}")</cell id="cell-4">
<cell id="cell-5"><cell_type>markdown</cell_type>## 3. Dataset Version Manager</cell id="cell-5">
<cell id="cell-6">import uuid, hashlib
from datetime import datetime
from dataclasses import dataclass, field
from typing import Optional

@dataclass
class DatasetVersion:
    name: str
    version: str
    path: str
    checksum: str
    n_rows: int
    schema: dict
    created_at: str = field(default_factory=lambda: datetime.now().strftime("%Y-%m-%d %H:%M"))
    tags: list[str] = field(default_factory=list)
    parent_version: Optional[str] = None
    description: str = ""

class DatasetRegistry:
    """Track dataset versions for reproducibility."""

    def __init__(self):
        self._versions: dict[str, list[DatasetVersion]] = {}

    def register(self, name: str, path: str, n_rows: int, schema: dict,
                 description: str = "", tags: list = None, parent: str = None) -> DatasetVersion:
        versions = self._versions.setdefault(name, [])
        version = f"v{len(versions) + 1}.0.0"
        checksum = hashlib.md5(f"{path}{n_rows}{schema}".encode()).hexdigest()[:8]
        dv = DatasetVersion(
            name=name, version=version, path=path, checksum=checksum,
            n_rows=n_rows, schema=schema, tags=tags or [],
            parent_version=parent, description=description,
        )
        versions.append(dv)
        print(f"Registered {name}@{version} ({n_rows:,} rows, checksum={checksum})")
        return dv

    def get(self, name: str, version: str) -> Optional[DatasetVersion]:
        return next((v for v in self._versions.get(name, []) if v.version == version), None)

    def lineage(self, name: str, version: str) -> list[str]:
        chain = []
        v = self.get(name, version)
        while v:
            chain.append(f"{v.version} ({v.checksum}): {v.description or 'no description'}")
            v = self.get(name, v.parent_version) if v.parent_version else None
        return chain

    def show(self, name: str) -> None:
        print(f"\nDataset: {name}")
        print(f"  {'Version':>9} {'Rows':>10} {'Checksum':>10} {'Created':>17}  {'Tags'}")
        print("  " + "-" * 60)
        for v in self._versions.get(name, []):
            print(f"  {v.version:>9} {v.n_rows:>10,} {v.checksum:>10} {v.created_at:>17}  {v.tags}")

registry = DatasetRegistry()
v1 = registry.register("user-features", "s3://ml-bucket/features/v1/",
                        n_rows=500_000, schema={"user_id": "str", "age": "int", "purchases_30d": "int"},
                        description="Initial dataset", tags=["baseline"])
v2 = registry.register("user-features", "s3://ml-bucket/features/v2/",
                        n_rows=750_000, schema={"user_id": "str", "age": "int", "purchases_30d": "int", "clv": "float"},
                        description="Added CLV feature", tags=["production"], parent=v1.version)
v3 = registry.register("user-features", "s3://ml-bucket/features/v3/",
                        n_rows=750_000, schema={"user_id": "str", "age": "int", "purchases_30d": "int", "clv": "float"},
                        description="Fixed age null bug", tags=["production", "bugfix"], parent=v2.version)

registry.show("user-features")
print("\nLineage for v3:")
for entry in registry.lineage("user-features", "v3.0.0"):
    print(f"  ← {entry}")</cell id="cell-6">
